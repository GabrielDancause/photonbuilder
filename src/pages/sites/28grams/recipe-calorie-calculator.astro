      acList.classList.remove('show');
    });
  });
});

ingName.addEventListener('keydown', function(e) {
  const items = acList.querySelectorAll('.autocomplete-item');
  if (!items.length) return;
  if (e.key === 'ArrowDown') {
    e.preventDefault();
    acIndex = Math.min(acIndex + 1, items.length - 1);
    items.forEach((el, i) => el.classList.toggle('active', i === acIndex));
  } else if (e.key === 'ArrowUp') {
    e.preventDefault();
    acIndex = Math.max(acIndex - 1, 0);
    items.forEach((el, i) => el.classList.toggle('active', i === acIndex));
  } else if (e.key === 'Enter') {
    e.preventDefault();
    if (acIndex >= 0 && items[acIndex]) {
      ingName.value = items[acIndex].dataset.name;
      acList.classList.remove('show');
    } else if (items.length > 0) {
      ingName.value = items[0].dataset.name;
      acList.classList.remove('show');
    }
  }
});

ingName.addEventListener('blur', () => { setTimeout(() => acList.classList.remove('show'), 150); });

// ── Add Ingredient ──
function findInDB(name) {
  const n = name.toLowerCase().trim();
  return DB.find(d => d[0].toLowerCase() === n);
}

function convertToGrams(qty, unit, ingredientName) {
  if (unit === 'g') return qty;
  if (unit === 'oz') return qty * 28.3495;
  if (unit === 'each') return qty * 100;
  if (unit === 'ml') return qty; // approximate 1ml = 1g for most ingredients

  // Volume units: use density if available
  const key = ingredientName.toLowerCase();
  const density = DENSITY[key];
  const cupMl = 236.588;
  let mlAmount;
  if (unit === 'cup') mlAmount = qty * cupMl;
  else if (unit === 'tbsp') mlAmount = qty * 14.7868;
  else if (unit === 'tsp') mlAmount = qty * 4.92892;
  else mlAmount = qty;

  if (density) {
    // density is g per cup
    return (mlAmount / cupMl) * density;
  }
  // fallback: assume density of water
  return mlAmount;
}

addBtn.addEventListener('click', addIngredient);
ingName.addEventListener('keydown', function(e) {
  if (e.key === 'Enter' && !acList.classList.contains('show')) {
    addIngredient();
  }
});

function addIngredient() {
  const name = ingName.value.trim();
  const qty = parseFloat(ingQty.value);
  const unit = ingUnit.value;
  if (!name || isNaN(qty) || qty <= 0) return;

  const dbEntry = findInDB(name);
  if (!dbEntry) { ingName.style.borderColor = '#f44'; setTimeout(() => ingName.style.borderColor = '', 1000); return; }

  const grams = convertToGrams(qty, unit, name);
  const factor = grams / 100;

  ingredients.push({
    name: dbEntry[0],
    qty, unit, grams,
    cal: dbEntry[1] * factor,
    protein: dbEntry[2] * factor,
    carbs: dbEntry[3] * factor,
    fat: dbEntry[4] * factor,
    fiber: dbEntry[5] * factor,
    sugar: dbEntry[6] * factor,
    sodium: dbEntry[7] * factor
  });

  ingName.value = '';
  ingQty.value = '100';
  ingUnit.value = 'g';
  ingName.focus();
  render();
}

// ── Remove / Reorder ──
function removeIngredient(idx) {
  ingredients.splice(idx, 1);
  render();
}

// ── Render ──
function render() {
  renderList();
  renderNutrition();
  renderChart();
  renderLabel();
}

function renderList() {
  if (ingredients.length === 0) {
    ingListEl.innerHTML = '<div class="empty-state">No ingredients added yet. Search and add ingredients above.</div>';
    return;
  }
  ingListEl.innerHTML = ingredients.map((ing, i) =>
    `<div class="ing-row" draggable="true" data-idx="${i}">
      <span class="drag-handle">⠿</span>
      <span class="ing-name">${ing.name}</span>
      <span class="ing-qty">${ing.qty} ${ing.unit}</span>
      <span class="ing-cal">${Math.round(ing.cal)} cal</span>
      <button class="remove-btn" onclick="removeIngredient(${i})">✕</button>
    </div>`
  ).join('');

  // Drag & drop
  const rows = ingListEl.querySelectorAll('.ing-row');
  rows.forEach(row => {
    row.addEventListener('dragstart', function(e) {
      dragIdx = +this.dataset.idx;
      this.classList.add('dragging');
      e.dataTransfer.effectAllowed = 'move';
    });
    row.addEventListener('dragend', function() { this.classList.remove('dragging'); });
    row.addEventListener('dragover', function(e) { e.preventDefault(); this.classList.add('drag-over'); });
    row.addEventListener('dragleave', function() { this.classList.remove('drag-over'); });
    row.addEventListener('drop', function(e) {
      e.preventDefault();
      this.classList.remove('drag-over');
      const toIdx = +this.dataset.idx;
      if (dragIdx === toIdx) return;
      const [moved] = ingredients.splice(dragIdx, 1);
      ingredients.splice(toIdx, 0, moved);
      render();
    });
  });
}

function getTotals() {
  const t = { cal: 0, protein: 0, carbs: 0, fat: 0, fiber: 0, sugar: 0, sodium: 0 };
  ingredients.forEach(ing => {
    t.cal += ing.cal; t.protein += ing.protein; t.carbs += ing.carbs;
    t.fat += ing.fat; t.fiber += ing.fiber; t.sugar += ing.sugar; t.sodium += ing.sodium;
  });
  return t;
}

function renderNutrition() {
  if (ingredients.length === 0) { nutriCard.style.display = 'none'; return; }
  nutriCard.style.display = '';

  const total = getTotals();
  const servings = Math.max(1, parseInt(servingsInput.value) || 1);
  const ps = k => total[k] / servings;

  const grid = document.getElementById('nutriGrid');
  const tiles = [
    { name: 'Calories', val: Math.round(ps('cal')), unit: 'kcal', cls: 'cal-tile' },
    { name: 'Protein', val: ps('protein').toFixed(1), unit: 'g' },
    { name: 'Carbs', val: ps('carbs').toFixed(1), unit: 'g' },
    { name: 'Fat', val: ps('fat').toFixed(1), unit: 'g' },
    { name: 'Fiber', val: ps('fiber').toFixed(1), unit: 'g' },
    { name: 'Sugar', val: ps('sugar').toFixed(1), unit: 'g' },
    { name: 'Sodium', val: Math.round(ps('sodium')), unit: 'mg' }
  ];
  grid.innerHTML = tiles.map(t =>
    `<div class="nutri-tile ${t.cls || ''}"><div class="val">${t.val}</div><div class="unit-label">${t.unit}</div><div class="nutri-name">${t.name}</div></div>`
  ).join('');

  document.getElementById('perServingNote').textContent =
    `Total recipe: ${Math.round(total.cal)} cal · ${servings} serving${servings > 1 ? 's' : ''}`;
}

function renderChart() {
  if (ingredients.length === 0) { chartCard.style.display = 'none'; return; }
  chartCard.style.display = '';

  const total = getTotals();
  const servings = Math.max(1, parseInt(servingsInput.value) || 1);
  const carbCal = (total.carbs / servings) * 4;
  const protCal = (total.protein / servings) * 4;
  const fatCal = (total.fat / servings) * 9;
  const totalMacroCal = carbCal + protCal + fatCal || 1;

  const data = [
    { label: 'Carbs', g: (total.carbs / servings).toFixed(1), pct: ((carbCal / totalMacroCal) * 100).toFixed(0), color: '#3b82f6' },
    { label: 'Protein', g: (total.protein / servings).toFixed(1), pct: ((protCal / totalMacroCal) * 100).toFixed(0), color: '#10b981' },
    { label: 'Fat', g: (total.fat / servings).toFixed(1), pct: ((fatCal / totalMacroCal) * 100).toFixed(0), color: '#f59e0b' }
  ];

  // Donut
  const canvas = document.getElementById('donutCanvas');
  const ctx = canvas.getContext('2d');
  const dpr = window.devicePixelRatio || 1;
  canvas.width = 360 * dpr;
  canvas.height = 360 * dpr;
  ctx.scale(dpr, dpr);
  ctx.clearRect(0, 0, 360, 360);

  const cx = 180, cy = 180, r = 72, lw = 28;
  let startAngle = -Math.PI / 2;
  data.forEach(d => {
    const slice = (parseFloat(d.pct) / 100) * 2 * Math.PI;
    ctx.beginPath();
    ctx.arc(cx, cy, r, startAngle, startAngle + slice);
    ctx.strokeStyle = d.color;
    ctx.lineWidth = lw;
    ctx.lineCap = 'butt';
    ctx.stroke();
    startAngle += slice;
  });

  // If no data, draw grey ring
  if (totalMacroCal <= 1) {
    ctx.beginPath();
    ctx.arc(cx, cy, r, 0, 2 * Math.PI);
    ctx.strokeStyle = '#1e2030';
    ctx.lineWidth = lw;
    ctx.stroke();
  }

  document.getElementById('dcCalVal').textContent = Math.round(total.cal / servings);

  // Legend
  const legend = document.getElementById('macroLegend');
  legend.innerHTML = data.map(d =>
    `<div class="macro-legend-item">
      <div class="macro-dot" style="background:${d.color}"></div>
      <span class="ml-name">${d.label}</span>
      <span class="ml-val">${d.g}g</span>
      <span class="ml-pct">${d.pct}%</span>
    </div>`
  ).join('');
}

function renderLabel() {
  if (ingredients.length === 0) { labelCard.style.display = 'none'; return; }
  labelCard.style.display = '';

  const total = getTotals();
  const s = Math.max(1, parseInt(servingsInput.value) || 1);
  const p = k => total[k] / s;

  // Daily values (FDA 2000 cal diet)
  const dv = { fat: 78, saturatedFat: 20, cholesterol: 300, sodium: 2300, carbs: 275, fiber: 28, sugar: 50, protein: 50, vitD: 20, calcium: 1300, iron: 18, potassium: 4700 };

  const fatDV = Math.round((p('fat') / dv.fat) * 100);
  const sodiumDV = Math.round((p('sodium') / dv.sodium) * 100);
  const carbDV = Math.round((p('carbs') / dv.carbs) * 100);
  const fiberDV = Math.round((p('fiber') / dv.fiber) * 100);
  const proteinDV = Math.round((p('protein') / dv.protein) * 100);

  const nfLabel = document.getElementById('nfLabel');
  nfLabel.innerHTML = `
    <div class="nf-title">Nutrition Facts</div>
    <div class="nf-bar-thick"></div>
    <div class="nf-serving">Serving size: 1/${s} of recipe</div>
    <div class="nf-bar-med"></div>
    <div class="nf-header-row">
      <span class="nf-amount-label">Amount per serving</span>
    </div>
    <div class="nf-row">
      <span class="nf-bold" style="font-size:1.5rem;">Calories</span>
      <span class="nf-val nf-bold" style="font-size:1.5rem;">${Math.round(p('cal'))}</span>
    </div>
    <div class="nf-bar-med"></div>
    <div class="nf-row" style="justify-content:flex-end;font-size:0.72rem;font-weight:700;">% Daily Value*</div>
    <div class="nf-bar-thin"></div>
    <div class="nf-row"><span><span class="nf-bold">Total Fat</span> ${p('fat').toFixed(1)}g</span><span class="nf-val nf-bold">${fatDV}%</span></div>
    <div class="nf-bar-thin"></div>
    <div class="nf-row"><span><span class="nf-bold">Total Carbohydrate</span> ${p('carbs').toFixed(1)}g</span><span class="nf-val nf-bold">${carbDV}%</span></div>
    <div class="nf-bar-thin"></div>
    <div class="nf-row indent"><span>Dietary Fiber ${p('fiber').toFixed(1)}g</span><span class="nf-val nf-bold">${fiberDV}%</span></div>
    <div class="nf-bar-thin"></div>
    <div class="nf-row indent"><span>Total Sugars ${p('sugar').toFixed(1)}g</span><span class="nf-val"></span></div>
    <div class="nf-bar-thin"></div>
    <div class="nf-row"><span><span class="nf-bold">Protein</span> ${p('protein').toFixed(1)}g</span><span class="nf-val nf-bold">${proteinDV}%</span></div>
    <div class="nf-bar-med"></div>
    <div class="nf-row"><span>Sodium ${Math.round(p('sodium'))}mg</span><span class="nf-val nf-bold">${sodiumDV}%</span></div>
    <div class="nf-bar-thin"></div>
    <div class="nf-dv-note">* The % Daily Value tells you how much a nutrient in a serving of food contributes to a daily diet. 2,000 calories a day is used for general nutrition advice.</div>
  `;
}

// ── Copy Nutrition ──
document.getElementById('copyNutriBtn').addEventListener('click', function() {
  const total = getTotals();
  const s = Math.max(1, parseInt(servingsInput.value) || 1);
  const text = `Per serving (1/${s}):\nCalories: ${Math.round(total.cal/s)}\nProtein: ${(total.protein/s).toFixed(1)}g\nCarbs: ${(total.carbs/s).toFixed(1)}g\nFat: ${(total.fat/s).toFixed(1)}g\nFiber: ${(total.fiber/s).toFixed(1)}g\nSugar: ${(total.sugar/s).toFixed(1)}g\nSodium: ${Math.round(total.sodium/s)}mg`;
  navigator.clipboard.writeText(text).then(() => {
    const btn = document.getElementById('copyNutriBtn');
    btn.textContent = '✓ Copied'; btn.classList.add('copied');
    setTimeout(() => { btn.textContent = 'Copy'; btn.classList.remove('copied'); }, 1500);
  });
});

document.getElementById('copyLabelBtn').addEventListener('click', function() {
  const label = document.getElementById('nfLabel');
  navigator.clipboard.writeText(label.innerText).then(() => {
    const btn = document.getElementById('copyLabelBtn');
    btn.textContent = '✓ Copied'; btn.classList.add('copied');
    setTimeout(() => { btn.textContent = 'Copy Text'; btn.classList.remove('copied'); }, 1500);
  });
});

// ── Servings Change ──
servingsInput.addEventListener('input', () => { renderNutrition(); renderChart(); renderLabel(); });

// Init
render();
</script>

