---
import SiteLayout from '../../../layouts/SiteLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Recipe Calorie Calculator",
  "url": "https://28grams.vip/recipe-calorie-calculator",
  "description": "Calculate calories, protein, carbs, fat, and full nutrition for any recipe. Add ingredients, set servings, and get an FDA-style nutrition label instantly.",
  "applicationCategory": "UtilitiesApplication",
  "operatingSystem": "Any",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  },
  "author": {
    "@type": "Organization",
    "name": "GAB Ventures",
    "url": "https://gab.ae"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How do I calculate calories in a homemade recipe?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Add each ingredient with its quantity to the calculator, and it automatically sums the calories from a nutritional database. Divide total calories by the number of servings to get per-serving calories. Our tool uses USDA-based nutrition data for 100+ common cooking and baking ingredients."
      }
    },
    {
      "@type": "Question",
      "name": "How accurate is a recipe calorie calculator?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Recipe calorie calculators are generally accurate to within 5-10% when ingredients are measured by weight (grams). Volume measurements like cups can vary. For best accuracy, weigh your ingredients on a kitchen scale. Our database uses standard USDA nutritional values per 100g of each ingredient."
      }
    },
    {
      "@type": "Question",
      "name": "Does cooking change the calorie count of food?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Cooking generally does not change the total calorie content of food — it changes the weight through water loss or absorption. Enter the raw weight of ingredients for the most accurate calculation. If a recipe includes oil for frying, add the amount of oil actually absorbed, not what you poured into the pan."
      }
    },
    {
      "@type": "Question",
      "name": "How many calories should one serving of a meal have?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A typical main meal ranges from 400 to 700 calories for most adults. Snacks are usually 100–300 calories. The right amount depends on your daily calorie goal, which for most adults is 1,600–2,400 calories per day depending on age, sex, and activity level."
      }
    },
    {
      "@type": "Question",
      "name": "What is the difference between total calories and calories from fat?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Total calories include energy from all macronutrients: carbohydrates (4 cal/g), protein (4 cal/g), and fat (9 cal/g). Calories from fat specifically measures energy contributed by fat alone. Fat is more calorie-dense per gram, which is why high-fat recipes tend to be higher in calories overall."
      }
    },
    {
      "@type": "Question",
      "name": "Can I use this calculator for keto, low-carb, or macro tracking?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. The calculator shows a full macro breakdown including net carbs, protein, and fat in grams and percentages. The donut chart visualizes your macro split, making it easy to see if a recipe fits keto (typically under 5-10% carbs), low-carb, high-protein, or other dietary targets."
      }
    }
  ]
};

export const meta = {
  title: "Recipe Calorie Calculator — Free Nutrition Analysis",
  description: "Calculate calories, protein, carbs, fat, fiber, sugar, and sodium for any recipe. Add ingredients, set servings, view macro chart and FDA nutrition label. Free, no signup.",
  category: "tool",
  published: "2026-03-21",
};
