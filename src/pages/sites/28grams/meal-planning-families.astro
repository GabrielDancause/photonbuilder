---
import SiteLayout from '../../../layouts/SiteLayout.astro';

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Meal Planning for Families",
    "description": "A complete weekly meal planning system for families. Covering theme nights, batch cooking, kid-friendly meals, a 4-week rotating plan, and budget tips.",
    "url": "https://28grams.vip/meal-planning-families",
    "author": {
      "@type": "Organization",
      "name": "28grams"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How do I start meal planning for my family?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Start small by picking 2-3 dinners for the week, building a grocery list around those meals, and checking what you already have in the pantry. Use theme nights like Taco Tuesday to simplify decision-making."
        }
      },
      {
        "@type": "Question",
        "name": "What are some good kid-friendly meals that adults enjoy?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Meals that allow for customization are perfect, such as build-your-own taco bars, homemade personal pizzas, stir-fries where veggies can be picked around, and hearty pasta bakes."
        }
      },
      {
        "@type": "Question",
        "name": "How much time does batch cooking on Sunday take?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A good batch cooking session takes about 1-2 hours. Focus on chopping all your vegetables, cooking a large batch of grains (like rice or quinoa), and preparing one versatile protein like shredded chicken."
        }
      },
      {
        "@type": "Question",
        "name": "How do I make a 4-week rotating meal plan?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "List 20-28 of your family's favorite dinners. Assign 5-7 to each week of the month. Save the plan, and next month, start back at week 1, rotating the same meals to completely eliminate decision fatigue."
        }
      },
      {
        "@type": "Question",
        "name": "What is a good grocery budget for a family?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "While it varies by location and dietary needs, a moderate USDA budget averages about $1,000 to $1,300 a month for a family of four. Sticking to a meal plan drastically reduces food waste and cuts down this cost."
        }
      }
    ]
  }
];

const mainEntityArray = schema[1].mainEntity;
---

<SiteLayout
  site="28grams"
  title="Meal Planning for Families"
  description="A complete weekly meal planning system for families. Covering theme nights, batch cooking, kid-friendly meals, a 4-week rotating plan, and budget tips."
  canonical="https://28grams.vip/meal-planning-families"
  schema={JSON.stringify(schema)}
>
  <style>
* { margin: 0; padding: 0; box-sizing: border-box; }
.page-wrapper {
  font-family: 'Inter', sans-serif;
  background: #0a060a;
  color: #e0d0d8;
  min-height: 100vh;
  --card-bg: #120c10;
  --border-color: #2a1820;
  --accent-color: #C2185B;
  --text-secondary: #888;
}

code, .mono { font-family: 'JetBrains Mono', monospace; }

.hero { text-align: center; padding: 48px 24px 24px; background: linear-gradient(180deg, #1a0a14 0%, #0a060a 100%); }
.hero h1 { font-size: 2.4rem; font-weight: 900; color: #fff; margin-bottom: 6px; }
.hero h1 span { background: linear-gradient(135deg, var(--accent-color), #ff6b9d); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
.hero p { color: #666; font-size: 0.95rem; max-width: 560px; margin: 0 auto; }
.main { max-width: 1000px; margin: 0 auto; padding: 32px 20px 40px; }

/* Formula Card */
.formula-card, .guide-card {
  background: var(--card-bg);
  border: 2px solid var(--border-color);
  border-radius: 16px;
  overflow: hidden;
  margin-bottom: 32px;
}
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 20px;
  background: #150d12;
  border-bottom: 1px solid var(--border-color);
}
.card-header h2 { font-size: 1.2rem; font-weight: 700; color: #fff; margin: 0; }
.card-content { padding: 20px; }
.card-content p { color: #c8b8c0; line-height: 1.6; margin-bottom: 12px; }
.card-content ul { padding-left: 20px; margin-bottom: 12px; color: #c8b8c0; line-height: 1.6; }
.card-content li { margin-bottom: 6px; }

/* SEO content */
.content h2 { font-size: 1.4rem; font-weight: 800; color: #fff; margin: 40px 0 14px; }
.content h3 { font-size: 1.1rem; font-weight: 700; color: #ddd; margin: 24px 0 10px; }
.content p { font-size: 0.9rem; color: #777; line-height: 1.8; margin-bottom: 14px; }

/* Recipe Details */
.recipe-section { margin-bottom: 40px; padding-bottom: 24px; border-bottom: 1px solid var(--border-color); }
.recipe-section:last-of-type { border-bottom: none; }
.recipe-header { display: flex; align-items: baseline; gap: 12px; margin-bottom: 16px; }
.recipe-header h3 { margin: 0; font-size: 1.3rem; color: var(--accent-color); }
.recipe-meta { font-size: 0.85rem; color: var(--text-secondary); background: #1a1015; padding: 4px 8px; border-radius: 4px; border: 1px solid var(--border-color); }

.recipe-info-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 16px;
    margin-bottom: 16px;
}
.recipe-info-card {
    background: #150d12;
    padding: 12px 16px;
    border-radius: 8px;
    border: 1px solid var(--border-color);
}
.recipe-info-label {
    font-size: 0.75rem;
    color: var(--text-secondary);
    text-transform: uppercase;
    font-weight: 600;
    margin-bottom: 4px;
}
.recipe-info-value {
    color: #e0d0d8;
    font-size: 0.95rem;
    line-height: 1.4;
}

/* FAQ */
.faq-list { margin-top: 24px; }
.faq-item { margin-bottom: 24px; }
.faq-q { font-weight: 700; color: #fff; margin-bottom: 8px; font-size: 1.05rem; }
.faq-a { color: #777; font-size: 0.95rem; line-height: 1.6; }

@media (max-width: 600px) {
  .hero h1 { font-size: 1.8rem; }
  .recipe-header { flex-direction: column; gap: 4px; }
}
  </style>

<div class="page-wrapper">
<div class="hero">
  <h1>Family <span>Meal Planning</span> 🍽️</h1>
  <p>Your complete system to weekly meal planning. From theme nights and batch cooking to budget tips and freezer-friendly meals that the whole family will love.</p>
</div>

<div class="main">

  <h2 style="font-size: 1.8rem; font-weight: 800; color: #fff; margin: 40px 0 20px;">The Planning Method</h2>

  <div class="recipe-section">
    <div class="recipe-header">
      <h3>Theme Nights</h3>
      <span class="recipe-meta">Structure</span>
    </div>
    <div class="recipe-info-grid">
        <div class="recipe-info-card"><div class="recipe-info-label">Meatless Monday</div><div class="recipe-info-value">Focus on beans, lentils, and fresh vegetables for a healthy, budget-friendly start to the week.</div></div>
        <div class="recipe-info-card"><div class="recipe-info-label">Taco Tuesday</div><div class="recipe-info-value">A universal family favorite. Tacos, burritos, fajitas, or taco bowls. High customization.</div></div>
        <div class="recipe-info-card"><div class="recipe-info-label">Pasta Wednesday</div><div class="recipe-info-value">Spaghetti, baked ziti, or a quick mac and cheese. Easy to sneak hidden veggies into the sauce.</div></div>
        <div class="recipe-info-card"><div class="recipe-info-label">Throwback Thursday</div><div class="recipe-info-value">Re-heat leftovers or transform them into something new, like turning chili into baked potato toppings.</div></div>
        <div class="recipe-info-card"><div class="recipe-info-label">Stir-Fry Friday</div><div class="recipe-info-value">Clean out the fridge! Toss leftover vegetables and proteins into a pan with soy sauce and serve over rice.</div></div>
        <div class="recipe-info-card"><div class="recipe-info-label">Pizza Saturday</div><div class="recipe-info-value">Make homemade dough or buy pre-made crusts for a fun, interactive family dinner night.</div></div>
    </div>
  </div>

  <div class="recipe-section">
    <div class="recipe-header">
      <h3>The 4-Week Rotating Meal Plan</h3>
      <span class="recipe-meta">Automation</span>
    </div>
    <div class="recipe-info-grid">
        <div class="recipe-info-card"><div class="recipe-info-label">The Concept</div><div class="recipe-info-value">Create 4 weeks of meal plans. When week 4 is over, start back at week 1. Eliminates decision fatigue entirely.</div></div>
        <div class="recipe-info-card"><div class="recipe-info-label">The Master List</div><div class="recipe-info-value">Write down 20-25 of your family's favorite meals. Slot them into the 4-week calendar.</div></div>
        <div class="recipe-info-card"><div class="recipe-info-label">Seasonal Swaps</div><div class="recipe-info-value">Create a "Summer" rotation (grilling, salads) and a "Winter" rotation (soups, casseroles) for variety.</div></div>
    </div>
  </div>

  <h2 style="font-size: 1.8rem; font-weight: 800; color: #fff; margin: 40px 0 20px;">Execution & Preparation</h2>

  <div class="recipe-section">
    <div class="recipe-header">
      <h3>Shopping List from Meal Plan</h3>
      <span class="recipe-meta">Organization</span>
    </div>
    <div class="recipe-info-grid">
        <div class="recipe-info-card"><div class="recipe-info-label">Inventory First</div><div class="recipe-info-value">Always "shop your pantry" before making a list to avoid buying duplicates of spices or grains.</div></div>
        <div class="recipe-info-card"><div class="recipe-info-label">Categorize</div><div class="recipe-info-value">Organize your list by grocery store aisles (Produce, Dairy, Meat) to get in and out quickly.</div></div>
        <div class="recipe-info-card"><div class="recipe-info-label">Stick to the List</div><div class="recipe-info-value">The meal plan dictates the list. If it's not on the list, don't buy it. Reduces impulse spending.</div></div>
    </div>
  </div>

  <div class="recipe-section">
    <div class="recipe-header">
      <h3>Batch Cooking Sunday Prep</h3>
      <span class="recipe-meta">Efficiency</span>
    </div>
    <div class="recipe-info-grid">
        <div class="recipe-info-card"><div class="recipe-info-label">Chop Veggies</div><div class="recipe-info-value">Wash and chop onions, peppers, and carrots for the week. Store in airtight containers.</div></div>
        <div class="recipe-info-card"><div class="recipe-info-label">Cook Grains</div><div class="recipe-info-value">Make a large pot of rice, quinoa, or pasta. They reheat perfectly and save 30 mins on weeknights.</div></div>
        <div class="recipe-info-card"><div class="recipe-info-label">Protein Prep</div><div class="recipe-info-value">Cook off ground beef or shred chicken to be quickly thrown into tacos, pastas, or salads later.</div></div>
    </div>
  </div>

  <h2 style="font-size: 1.8rem; font-weight: 800; color: #fff; margin: 40px 0 20px;">Meal Categories & Strategies</h2>

  <div class="formula-card">
    <div class="card-header">
      <h2>Kid-Friendly Meals (Adults Love Too)</h2>
    </div>
    <div class="card-content">
      <p>The secret is customization. Serve meals "deconstructed" so picky eaters feel in control.</p>
      <ul>
        <li><strong>Nacho Bar:</strong> Sheet pan of chips and cheese. Let everyone add their own meat, beans, salsa, and veggies.</li>
        <li><strong>Baked Potato Bar:</strong> Fluffy russet potatoes with sides of chili, broccoli, cheese, and sour cream.</li>
        <li><strong>Homemade Pizzas:</strong> Use naan bread or English muffins as mini crusts. Everyone makes their own.</li>
      </ul>
    </div>
  </div>

  <div class="formula-card">
    <div class="card-header">
      <h2>Freezer-Friendly Meals</h2>
    </div>
    <div class="card-content">
      <p>Double the recipe and freeze half for a chaotic night when you don't have time to cook.</p>
      <ul>
        <li><strong>Lasagna/Baked Ziti:</strong> Assemble fully in an aluminum pan. Freeze unbaked. Bake straight from frozen.</li>
        <li><strong>Soups and Stews:</strong> Chili and minestrone freeze perfectly in quart-sized containers for up to 3 months.</li>
        <li><strong>Breakfast Burritos:</strong> Roll eggs, cheese, and sausage in tortillas. Wrap in foil and freeze for quick mornings.</li>
      </ul>
    </div>
  </div>

  <div class="formula-card">
    <div class="card-header">
      <h2>Slow Cooker Dump Meals</h2>
    </div>
    <div class="card-content">
      <p>Throw ingredients in a bag, freeze, then dump directly into the slow cooker in the morning.</p>
      <ul>
        <li><strong>Salsa Chicken:</strong> Chicken breasts + jar of salsa + taco seasoning. Cook on low 6 hrs. Shred for tacos.</li>
        <li><strong>Pot Roast:</strong> Chuck roast + baby carrots + potatoes + onion soup mix. Cook on low 8 hrs.</li>
        <li><strong>Pulled Pork:</strong> Pork shoulder + BBQ sauce + apple cider vinegar. Cook on low 8 hrs.</li>
      </ul>
    </div>
  </div>

  <div class="formula-card">
    <div class="card-header">
      <h2>15-Minute Weeknight Dinners</h2>
    </div>
    <div class="card-content">
      <p>For nights when everything goes wrong and you need food on the table immediately.</p>
      <ul>
        <li><strong>Sheet Pan Sausage & Peppers:</strong> Slice pre-cooked sausage and peppers. Roast at 400°F for 15 mins.</li>
        <li><strong>Breakfast for Dinner:</strong> Scrambled eggs, toast, and fresh fruit. Fast, cheap, and kids love it.</li>
        <li><strong>Quesadillas:</strong> Tortillas, cheese, and leftover chicken or black beans. Crisp in a pan for 3 mins per side.</li>
      </ul>
    </div>
  </div>

  <div class="formula-card">
    <div class="card-header">
      <h2>Leftover Transformation Recipes</h2>
    </div>
    <div class="card-content">
      <p>Don't throw away yesterday's dinner. Turn it into something entirely new.</p>
      <ul>
        <li><strong>Leftover Chicken?</strong> Turn it into chicken salad sandwiches, chicken quesadillas, or top a green salad.</li>
        <li><strong>Leftover Rice?</strong> Perfect for making fried rice the next day (cold rice fries better than warm rice).</li>
        <li><strong>Leftover Roast Veggies?</strong> Blend them with broth into a creamy soup, or fold them into a morning frittata.</li>
      </ul>
    </div>
  </div>

  <div class="recipe-section">
    <div class="recipe-header">
      <h3>Budget Per Family Size</h3>
      <span class="recipe-meta">Finance</span>
    </div>
    <div class="recipe-info-grid">
        <div class="recipe-info-card"><div class="recipe-info-label">Family of 2</div><div class="recipe-info-value">$400 - $600/month. Focus on reducing food waste by freezing extra portions before they go bad.</div></div>
        <div class="recipe-info-card"><div class="recipe-info-label">Family of 4</div><div class="recipe-info-value">$800 - $1,200/month. Buying in bulk (rice, beans, family-packs of meat) starts to pay off heavily.</div></div>
        <div class="recipe-info-card"><div class="recipe-info-label">Family of 6+</div><div class="recipe-info-value">$1,200 - $1,800+/month. Rely heavily on stretching meals with cheap bases like pasta, potatoes, and lentils.</div></div>
    </div>
  </div>

  <h2 style="font-size: 1.8rem; font-weight: 800; color: #fff; margin: 40px 0 20px;">Frequently Asked Questions</h2>
  <div class="faq-list">
    {mainEntityArray.map((faq) => (
      <div class="faq-item">
        <div class="faq-q">{faq.name}</div>
        <div class="faq-a">{faq.acceptedAnswer.text}</div>
      </div>
    ))}
  </div>
</div>
</div>
</SiteLayout>
