---
import SiteLayout from '../../../layouts/SiteLayout.astro';

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebApplication",
    "name": "Sourdough Bread Timer",
    "url": "https://28grams.vip/sourdough-timer",
    "description": "Generate a complete sourdough baking timeline. Choose your bake time, room temperature, and method to get exact step-by-step times from feeding starter to pulling bread from the oven.",
    "applicationCategory": "UtilitiesApplication",
    "operatingSystem": "Any",
    "offers": {
      "@type": "Offer",
      "price": "0",
      "priceCurrency": "USD"
    },
    "author": {
      "@type": "Organization",
      "name": "GAB Ventures",
      "url": "https://gab.ae"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How long does sourdough bread take from start to finish?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A same-day sourdough bake takes 10-14 hours total depending on room temperature. A cold retard method spans 24-36 hours but most of that is hands-off fridge time. The active work is only about 30-45 minutes spread across the day."
        }
      },
      {
        "@type": "Question",
        "name": "How does room temperature affect sourdough fermentation time?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Fermentation speed roughly doubles for every 15°F increase. At 65°F bulk fermentation may take 6-8 hours, at 72°F it takes about 4-5 hours, and at 78°F it can finish in 3-4 hours. Always watch the dough, not the clock."
        }
      },
      {
        "@type": "Question",
        "name": "What is the cold retard method for sourdough?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Cold retard means shaping your dough and placing it in the refrigerator (38-42°F) overnight or up to 72 hours. The cold slows fermentation dramatically, developing more complex sour flavors and making it easier to score. You bake straight from the fridge."
        }
      },
      {
        "@type": "Question",
        "name": "When should I start my sourdough if I want fresh bread in the morning?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "For morning bread using the cold retard method, start your dough around 8-10 AM the previous day. You'll mix, bulk ferment, shape by evening, refrigerate overnight, and bake first thing in the morning. Use this timer tool to generate exact times."
        }
      },
      {
        "@type": "Question",
        "name": "How many stretch and folds does sourdough need?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Most recipes call for 4-6 sets of stretch and folds spaced 30 minutes apart during the first half of bulk fermentation. Each set involves stretching the dough from all four sides and folding it over itself to build gluten strength without heavy kneading."
        }
      }
    ]
  }
];

export const meta = {
  title: "Sourdough Bread Timer — Baking Schedule Generator",
  description: "Generate a complete sourdough baking timeline with exact times for every step. Adjusts for room temperature, same-day or cold retard method, and sends browser notifications.",
  category: "tool",
  published: "2026-03-21",
};
