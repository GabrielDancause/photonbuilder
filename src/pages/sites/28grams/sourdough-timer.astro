  <script is:inline>
// Elements
var elBakeTime = document.getElementById('bakeTime');
var elRoomTemp = document.getElementById('roomTemp');
var elMethod = document.getElementById('method');
var elFoldCount = document.getElementById('foldCount');
var elTimeline = document.getElementById('timelineList');
var elVisualBar = document.getElementById('visualBar');
var elClipboard = document.getElementById('clipboardData');
var elNotifToggle = document.getElementById('notifToggle');
var elNotifStatus = document.getElementById('notifStatus');

var sumStart = document.getElementById('sumStart');
var sumBake = document.getElementById('sumBake');
var sumTotal = document.getElementById('sumTotal');
var sumActive = document.getElementById('sumActive');

var scheduleData = [];
var notificationsEnabled = false;
var notifTimers = [];

function formatTime(d) {
  var h = d.getHours();
  var m = d.getMinutes();
  var ampm = h >= 12 ? 'PM' : 'AM';
  h = h % 12;
  h = h ? h : 12;
  var mm = m < 10 ? '0' + m : m;
  return h + ':' + mm + ' ' + ampm;
}

function getTempFactor(tempF) {
  // Base at 72°F = 1.0. Every degree above/below adjusts by ~3%
  return Math.pow(1.03, tempF - 72);
}

function buildSteps(tempF, method, folds) {
  var factor = getTempFactor(tempF);
  var baseBulk = 240; // 4 hours base at 72°F
  var foldInterval = 30;
  var foldPhase = folds * foldInterval;
  var remainingBulk = Math.max(60, Math.round((baseBulk - foldPhase) / factor));
  var adjustedFoldInterval = foldInterval; // folds stay at 30 min

  var steps = [];
  var cat; // category for coloring

  // 1. Feed starter (8-12 hours before, but we simplify to 4-6h before mixing)
  var starterTime = Math.round(240 / factor);
  steps.push({ title: "Feed Starter", desc: "Feed your starter 1:1:1 (equal parts starter, flour, water). It should double in " + Math.round(starterTime / 60) + "-" + Math.round(starterTime / 60 + 2) + " hours.", durMins: 0, cat: "prep", activeMins: 5 });

  // 2. Autolyse
  steps.push({ title: "Autolyse", desc: "Mix flour and water until no dry bits remain. Cover and rest.", durMins: starterTime - 30, cat: "prep", activeMins: 5 });

  // 3. Mix in starter & salt
  steps.push({ title: "Mix Starter & Salt", desc: "Add active starter and salt. Pinch and fold until fully incorporated.", durMins: 30, cat: "mix", activeMins: 10 });

  // 4. Stretch & folds
  for (var i = 1; i <= folds; i++) {
    var foldDesc = i === 1 ? "Wet hands. Stretch from each side and fold over. Builds gluten." :
                   i === folds ? "Final set. Dough should feel strong and smooth. Let it rest." :
                   "Stretch and fold from all 4 sides. Dough gets tighter each time.";
    steps.push({ title: "Stretch & Fold " + i, desc: foldDesc, durMins: adjustedFoldInterval, cat: "fold", activeMins: 2 });
  }

  // 5. Remaining bulk ferment
  steps.push({ title: "Bulk Ferment (Rest)", desc: "Leave dough undisturbed. Look for 30-50% rise, bubbles on sides, jiggly texture.", durMins: remainingBulk, cat: "ferment", activeMins: 0 });

  // 6. Pre-shape
  steps.push({ title: "Pre-shape", desc: "Turn dough onto unfloured surface. Use bench scraper to shape into loose round. Rest.", durMins: 0, cat: "shape", activeMins: 5 });

  // 7. Bench rest
  steps.push({ title: "Bench Rest", desc: "Let the dough relax 20-30 minutes. It should spread slightly but hold shape.", durMins: 25, cat: "shape", activeMins: 0 });

  // 8. Final shape
  steps.push({ title: "Final Shape", desc: "Shape tightly into batard or boule. Place seam-side up in floured banneton.", durMins: 0, cat: "shape", activeMins: 5 });

  if (method === 'cold') {
    // 9. Cold retard
    steps.push({ title: "Cold Retard (Fridge)", desc: "Cover and refrigerate 12-18 hours. Develops flavor, easier to score.", durMins: 0, cat: "ferment", activeMins: 0 });

    // 10. Preheat
    steps.push({ title: "Preheat Oven", desc: "Preheat to 500°F (260°C) with dutch oven inside. Allow 45-60 min.", durMins: 12 * 60, cat: "bake", activeMins: 2 });

    // 11. Score & bake
    steps.push({ title: "Score & Bake (Lid On)", desc: "Score cold dough. Place in dutch oven. Bake 20 min at 500°F with lid.", durMins: 60, cat: "bake", activeMins: 5 });

    // 12. Remove lid
    steps.push({ title: "Remove Lid", desc: "Take off dutch oven lid. Reduce to 450°F (230°C). Bake 20-25 min until deep brown.", durMins: 20, cat: "bake", activeMins: 1 });

    // 13. Cool
    steps.push({ title: "Cool on Rack", desc: "Remove from oven. Cool on wire rack for at least 1 hour before slicing.", durMins: 22, cat: "bake", activeMins: 0 });
  } else {
    // Same-day proof
    var proofTime = Math.round(90 / factor);
    steps.push({ title: "Room Temp Proof", desc: "Cover banneton. Proof at room temp until puffy. Poke test: indent should spring back slowly.", durMins: proofTime, cat: "ferment", activeMins: 0 });

    // Preheat (overlap with proof end)
    steps.push({ title: "Preheat Oven", desc: "Preheat to 500°F (260°C) with dutch oven inside. Start this 45-60 min before bake.", durMins: 0, cat: "bake", activeMins: 2 });

    // Score & bake
    steps.push({ title: "Score & Bake (Lid On)", desc: "Score dough. Place in dutch oven. Bake 20 min at 500°F with lid on.", durMins: 60, cat: "bake", activeMins: 5 });

    // Remove lid
    steps.push({ title: "Remove Lid", desc: "Remove lid. Reduce to 450°F (230°C). Bake 20-25 min until deep golden brown.", durMins: 20, cat: "bake", activeMins: 1 });

    // Cool
    steps.push({ title: "Cool on Rack", desc: "Cool on wire rack at least 1 hour. The bread is still baking inside.", durMins: 22, cat: "bake", activeMins: 0 });
  }

  return steps;
}

function generate() {
  var bakeTimeStr = elBakeTime.value;
  if (!bakeTimeStr) return;

  var tempF = parseInt(elRoomTemp.value) || 72;
  var method = elMethod.value;
  var folds = parseInt(elFoldCount.value) || 4;

  var steps = buildSteps(tempF, method, folds);

  // Calculate total minutes (working backward from bake time)
  var totalMins = 0;
  steps.forEach(function(s) { totalMins += s.durMins; });

  // Parse desired bake time (this is when bread goes IN the oven = Score & Bake step)
  var parts = bakeTimeStr.split(':');
  var bakeDate = new Date();
  bakeDate.setHours(parseInt(parts[0]), parseInt(parts[1]), 0, 0);

  // We want the last "Score & Bake" step to land at bakeDate
  // Calculate total time from start to Score & Bake step
  var minsToScoreBake = 0;
  for (var i = 0; i < steps.length; i++) {
    minsToScoreBake += steps[i].durMins;
    if (steps[i].title.indexOf("Score") === 0) break;
  }

  // Work backward: start time = bake time - minsToScoreBake
  // Actually, minsToScoreBake includes the Score step's own durMins which is the time AFTER score
  // Let's recalculate: sum durMins of all steps up to but not including the Score step
  minsToScoreBake = 0;
  for (var j = 0; j < steps.length; j++) {
    if (steps[j].title.indexOf("Score") === 0) break;
    minsToScoreBake += steps[j].durMins;
  }

  var startTime = new Date(bakeDate.getTime() - minsToScoreBake * 60000);

  // Build schedule forward from startTime
  scheduleData = [];
  var currentTime = startTime.getTime();
  var totalActive = 0;
  var segmentData = [];

  clearNotifTimers();

  steps.forEach(function(step, idx) {
    currentTime += step.durMins * 60000;
    var d = new Date(currentTime);
    totalActive += step.activeMins;

    // Day offset
    var dayDiff = Math.floor((currentTime - startTime.getTime()) / (24 * 60 * 60000));
    var dayLabel = dayDiff === 0 ? "" : dayDiff === 1 ? "Next Day" : "Day " + (dayDiff + 1);

    var durStr = "";
    if (step.durMins > 0 && step.durMins < 60) durStr = "+" + step.durMins + "m";
    if (step.durMins >= 60) {
      var hrs = Math.round(step.durMins / 60 * 10) / 10;
      durStr = "+" + hrs + "h";
    }

    scheduleData.push({
      time: formatTime(d),
      day: dayLabel,
      title: step.title,
      desc: step.desc,
      dur: durStr,
      cat: step.cat,
      timestamp: currentTime
    });

    if (step.durMins > 0) {
      segmentData.push({ label: step.title, mins: step.durMins, cat: step.cat });
    }

    // Schedule notification
    if (notificationsEnabled && Notification.permission === 'granted') {
      var msUntil = currentTime - Date.now();
      if (msUntil > 0) {
        var timer = setTimeout(function(s) {
          new Notification("Sourdough Timer: " + s.title, { body: s.desc, icon: "⏱️" });
        }, msUntil, step);
        notifTimers.push(timer);
      }
    }
  });

  // Update summary
  var endTime = new Date(currentTime);
  var totalDuration = (currentTime - startTime.getTime()) / 60000;
  var totalHrs = Math.floor(totalDuration / 60);
  var totalRem = Math.round(totalDuration % 60);

  sumStart.innerHTML = formatTime(startTime);
  sumBake.innerHTML = formatTime(bakeDate);
  sumTotal.innerHTML = totalHrs + '<small>h</small> ' + totalRem + '<small>m</small>';
  sumActive.innerHTML = '~' + totalActive + '<small>min</small>';

  renderTimeline();
  renderVisualBar(segmentData, totalDuration);
}

function renderTimeline() {
  elTimeline.innerHTML = '';
  scheduleData.forEach(function(s) {
    var row = document.createElement('div');
    row.className = 'time-row';
    row.innerHTML =
      '<div class="t-time">' + s.time + (s.day ? '<span class="t-day">' + s.day + '</span>' : '') + '</div>' +
      '<div>' +
        '<div class="t-step"><span class="t-icon ' + s.cat + '"></span>' + s.title + '</div>' +
        '<div class="t-desc">' + s.desc + '</div>' +
      '</div>' +
      (s.dur ? '<div class="t-dur">' + s.dur + '</div>' : '<div></div>');
    elTimeline.appendChild(row);
  });
}

var catColors = {
  prep: '#ff9800',
  mix: '#2196F3',
  fold: '#9C27B0',
  ferment: '#4CAF50',
  shape: '#E91E63',
  bake: '#f44336'
};

function renderVisualBar(segments, totalMins) {
  if (!segments.length) return;
  var html = '<div class="bar-track">';
  segments.forEach(function(seg) {
    var pct = (seg.mins / totalMins * 100);
    var color = catColors[seg.cat] || '#555';
    html += '<div class="bar-seg" style="width:' + pct + '%;background:' + color + ';" title="' + seg.label + ' (' + seg.mins + 'min)">';
    if (pct > 6) html += seg.label.replace('Stretch & Fold ', 'S&F ');
    html += '</div>';
  });
  html += '</div>';
  html += '<div class="bar-legend">';
  var cats = { prep: 'Prep', mix: 'Mixing', fold: 'Folds', ferment: 'Fermentation', shape: 'Shaping', bake: 'Baking' };
  for (var c in cats) {
    html += '<div class="bar-legend-item"><div class="bar-legend-dot" style="background:' + catColors[c] + '"></div>' + cats[c] + '</div>';
  }
  html += '</div>';
  elVisualBar.innerHTML = html;
}

function setQuickTime(time, btn) {
  elBakeTime.value = time;
  var btns = document.querySelectorAll('.quick-btn');
  btns.forEach(function(b) { b.classList.remove('active'); });
  btn.classList.add('active');
  generate();
}

function toggleNotifications() {
  if (!notificationsEnabled) {
    if (!('Notification' in window)) {
      elNotifStatus.textContent = 'Not supported';
      return;
    }
    Notification.requestPermission().then(function(perm) {
      if (perm === 'granted') {
        notificationsEnabled = true;
        elNotifToggle.classList.add('on');
        elNotifStatus.textContent = 'On — will alert before each step';
        generate(); // reschedule with notifications
      } else {
        elNotifStatus.textContent = 'Denied by browser';
      }
    });
  } else {
    notificationsEnabled = false;
    elNotifToggle.classList.remove('on');
    elNotifStatus.textContent = 'Off';
    clearNotifTimers();
  }
}

function clearNotifTimers() {
  notifTimers.forEach(function(t) { clearTimeout(t); });
  notifTimers = [];
}

function copySchedule() {
  var txt = "Sourdough Baking Schedule\n========================\n";
  scheduleData.forEach(function(s) {
    var line = (s.time + (s.day ? ' (' + s.day + ')' : '')).padEnd(22, ' ');
    txt += line + " | " + s.title + "\n";
    txt += "                       " + s.desc + "\n\n";
  });

  if (navigator.clipboard && navigator.clipboard.writeText) {
    navigator.clipboard.writeText(txt);
  } else {
    elClipboard.value = txt;
    elClipboard.select();
    document.execCommand('copy');
  }

  var btn = document.getElementById('copySchedBtn');
  btn.textContent = '✓ Copied';
  btn.classList.add('copied');
  setTimeout(function() { btn.textContent = 'Copy Timeline'; btn.classList.remove('copied'); }, 1500);
}

// Listeners
elBakeTime.addEventListener('input', function() {
  document.querySelectorAll('.quick-btn').forEach(function(b) { b.classList.remove('active'); });
  generate();
});
elRoomTemp.addEventListener('input', generate);
elMethod.addEventListener('change', generate);
elFoldCount.addEventListener('change', generate);

// Init
generate();
  </script>

