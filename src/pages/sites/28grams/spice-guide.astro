---
import SiteLayout from '../../../layouts/SiteLayout.astro';

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Spice Guide for Beginners",
    "description": "Discover 30 essential spices, their flavor profiles, cuisine pairings, storage tips, and homemade spice blends like Garam Masala and Za'atar.",
    "url": "https://28grams.vip/spice-guide",
    "author": {
      "@type": "Organization",
      "name": "28grams"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How long do spices actually last?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Whole spices can last 3-4 years, while ground spices typically lose their potency after 6-12 months. Store them in a cool, dark place away from the stove to maximize their lifespan."
        }
      },
      {
        "@type": "Question",
        "name": "Should I buy whole or ground spices?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Whenever possible, buy whole spices and grind them yourself using a mortar and pestle or spice grinder. Whole spices retain their essential oils and flavor much longer than pre-ground spices."
        }
      },
      {
        "@type": "Question",
        "name": "What does 'blooming' spices mean?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Blooming refers to frying spices in a fat (like oil or butter) for a few seconds until fragrant. This process releases fat-soluble flavor compounds, making the spices taste much richer and more complex."
        }
      },
      {
        "@type": "Question",
        "name": "How do I toast spices without burning them?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Heat a dry skillet over medium-low heat. Add whole spices and toss frequently for 1-2 minutes just until you can smell their aroma. Remove them from the pan immediately so they don't continue cooking and burn."
        }
      },
      {
        "@type": "Question",
        "name": "How can I tell if a spice has gone bad?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Spices don't usually spoil in a way that makes you sick, but they do lose flavor. Crush a small amount in your hand and smell it; if there's no strong aroma, it's time to replace it."
        }
      }
    ]
  }
];

const mainEntityArray = schema[1].mainEntity;
---

<SiteLayout
  site="28grams"
  canonical="https://28grams.vip/spice-guide"
  schema={JSON.stringify(schema)}
>
  <style>
* { margin: 0; padding: 0; box-sizing: border-box; }
.page-wrapper {
  font-family: 'Inter', sans-serif;
  background: #0a060a;
  color: #e0d0d8;
  min-height: 100vh;
  --card-bg: #120c10;
  --border-color: #2a1820;
  --accent-color: #C2185B;
  --text-secondary: #888;
}

code, .mono { font-family: 'JetBrains Mono', monospace; }

.hero { text-align: center; padding: 48px 24px 24px; background: linear-gradient(180deg, #1a0a14 0%, #0a060a 100%); }
.hero h1 { font-size: 2.4rem; font-weight: 900; color: #fff; margin-bottom: 6px; }
.hero h1 span { background: linear-gradient(135deg, var(--accent-color), #ff6b9d); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
.hero p { color: #666; font-size: 0.95rem; max-width: 560px; margin: 0 auto; }
.main { max-width: 1000px; margin: 0 auto; padding: 32px 20px 40px; }

/* Formula Card */
.formula-card, .guide-card {
  background: var(--card-bg);
  border: 2px solid var(--border-color);
  border-radius: 16px;
  overflow: hidden;
  margin-bottom: 32px;
}
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 20px;
  background: #150d12;
  border-bottom: 1px solid var(--border-color);
}
.card-header h2 { font-size: 1.2rem; font-weight: 700; color: #fff; margin: 0; }
.card-content { padding: 20px; }
.card-content p { color: #c8b8c0; line-height: 1.6; margin-bottom: 12px; }

/* SEO content */
.content h2 { font-size: 1.4rem; font-weight: 800; color: #fff; margin: 40px 0 14px; }
.content h3 { font-size: 1.1rem; font-weight: 700; color: #ddd; margin: 24px 0 10px; }
.content p { font-size: 0.9rem; color: #777; line-height: 1.8; margin-bottom: 14px; }

/* Recipe Details */
.recipe-section { margin-bottom: 40px; padding-bottom: 24px; border-bottom: 1px solid var(--border-color); }
.recipe-section:last-of-type { border-bottom: none; }
.recipe-header { display: flex; align-items: baseline; gap: 12px; margin-bottom: 16px; }
.recipe-header h3 { margin: 0; font-size: 1.3rem; color: var(--accent-color); }
.recipe-meta { font-size: 0.85rem; color: var(--text-secondary); background: #1a1015; padding: 4px 8px; border-radius: 4px; border: 1px solid var(--border-color); }

.recipe-info-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 16px;
    margin-bottom: 16px;
}
.recipe-info-card {
    background: #150d12;
    padding: 12px 16px;
    border-radius: 8px;
    border: 1px solid var(--border-color);
}
.recipe-info-label {
    font-size: 0.75rem;
    color: var(--text-secondary);
    text-transform: uppercase;
    font-weight: 600;
    margin-bottom: 4px;
}
.recipe-info-value {
    color: #fff;
    font-size: 0.95rem;
}

/* FAQ */
.faq-list { margin-top: 24px; }
.faq-item { margin-bottom: 24px; }
.faq-q { font-weight: 700; color: #fff; margin-bottom: 8px; font-size: 1.05rem; }
.faq-a { color: #777; font-size: 0.95rem; line-height: 1.6; }

@media (max-width: 600px) {
  .hero h1 { font-size: 1.8rem; }
  .recipe-header { flex-direction: column; gap: 4px; }
}
  </style>

