<script is:inline>
  const searchInput = document.getElementById('searchInput');
  const filterBtns = document.querySelectorAll('.filter-btn');
  const rows = document.querySelectorAll('.pepper-row');
  const headers = document.querySelectorAll('th[data-sort]');
  const tableBody = document.getElementById('tableBody');
  const heatMarkers = document.querySelectorAll('.heat-marker');

  let currentFilter = 'all';
  let searchQuery = '';

  function applyFilters() {
    rows.forEach(row => {
      const category = row.getAttribute('data-category');
      const text = row.innerText.toLowerCase();
      const matchesFilter = currentFilter === 'all' || category.includes(currentFilter);
      const matchesSearch = text.includes(searchQuery);
      if (matchesFilter && matchesSearch) {
        row.classList.remove('hidden');
      } else {
        row.classList.add('hidden');
      }
    });
  }

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      currentFilter = btn.getAttribute('data-filter');
      heatMarkers.forEach(m => m.classList.remove('active'));
      applyFilters();
    });
  });

  heatMarkers.forEach(marker => {
    marker.addEventListener('click', () => {
      const level = marker.getAttribute('data-level');
      const isActive = marker.classList.contains('active');
      heatMarkers.forEach(m => m.classList.remove('active'));
      filterBtns.forEach(b => b.classList.remove('active'));
      if (isActive) {
        currentFilter = 'all';
        filterBtns[0].classList.add('active');
      } else {
        marker.classList.add('active');
        currentFilter = level;
      }
      applyFilters();
    });
  });

  searchInput.addEventListener('input', (e) => {
    searchQuery = e.target.value.toLowerCase();
    applyFilters();
  });

  headers.forEach(header => {
    header.addEventListener('click', () => {
      const sortType = header.getAttribute('data-sort');
      const isAsc = !header.classList.contains('asc');
      headers.forEach(h => { h.classList.remove('asc', 'desc'); });
      header.classList.add(isAsc ? 'asc' : 'desc');
      const rowsArray = Array.from(rows);
      rowsArray.sort((a, b) => {
        let aVal, bVal;
        if (sortType === 'name') {
          aVal = a.children[0].innerText.trim();
          bVal = b.children[0].innerText.trim();
        } else if (sortType === 'shu') {
          aVal = parseInt(a.getAttribute('data-shu'));
          bVal = parseInt(b.getAttribute('data-shu'));
        } else if (sortType === 'level') {
          aVal = parseInt(a.getAttribute('data-level'));
          bVal = parseInt(b.getAttribute('data-level'));
        }
        if (aVal < bVal) return isAsc ? -1 : 1;
        if (aVal > bVal) return isAsc ? 1 : -1;
        return 0;
      });
      rowsArray.forEach(row => tableBody.appendChild(row));
    });
  });

  // Quiz Logic
  const questions = document.querySelectorAll('.quiz-question');
  const dots = document.querySelectorAll('.quiz-dot');
  const quizResult = document.getElementById('quizResult');
  let currentQ = 0;
  let quizScore = 0;

  document.querySelectorAll('.quiz-opt').forEach(opt => {
    opt.addEventListener('click', () => {
      const pts = parseInt(opt.getAttribute('data-pts'));
      quizScore += pts;
      const siblings = opt.parentElement.querySelectorAll('.quiz-opt');
      siblings.forEach(s => s.classList.remove('selected'));
      opt.classList.add('selected');

      setTimeout(() => {
        questions[currentQ].classList.remove('active');
        dots[currentQ].classList.remove('current');
        dots[currentQ].classList.add('done');
        currentQ++;

        if (currentQ < questions.length) {
          questions[currentQ].classList.add('active');
          dots[currentQ].classList.add('current');
        } else {
          showQuizResult();
        }
      }, 400);
    });
  });

  function showQuizResult() {
    const results = [
      { min: 5, max: 8, emoji: '&#x1F7E2;', title: 'Mild Explorer', range: '0 - 2,500 SHU', desc: 'You prefer flavor over fire. Start with poblanos, banana peppers, and pepperoncini. Try Frank\'s RedHot as your gateway sauce!', peppers: ['Bell Pepper', 'Poblano', 'Banana Pepper', 'Anaheim'] },
      { min: 9, max: 12, emoji: '&#x1F7E1;', title: 'Medium Maverick', range: '2,500 - 30,000 SHU', desc: 'You enjoy a nice kick without the pain. Jalape\u00f1os, serranos, and Sriracha are your sweet spot. Try chipotles for smoky depth!', peppers: ['Jalape\u00f1o', 'Serrano', 'Chipotle', 'Sriracha'] },
      { min: 13, max: 17, emoji: '&#x1F7E0;', title: 'Heat Seeker', range: '30,000 - 100,000 SHU', desc: 'You actively seek out spicy food and can handle serious heat. Cayenne, piri piri, and chile de arbol are your playground.', peppers: ['Cayenne', 'Piri Piri', 'Chile de Arbol', 'Aji Amarillo'] },
      { min: 18, max: 21, emoji: '&#x1F534;', title: 'Flame Warrior', range: '100,000 - 500,000 SHU', desc: 'You live for the burn. Habaneros and Scotch bonnets are your daily drivers. You probably grow your own hot peppers.', peppers: ['Habanero', 'Scotch Bonnet', 'Bird\'s Eye', 'Datil'] },
      { min: 22, max: 25, emoji: '&#x1F525;', title: 'Nuclear Certified', range: '500,000+ SHU', desc: 'You\'re a capsaicin machine. Ghost peppers are a snack, Carolina Reapers are a challenge accepted. Your endorphin tolerance is legendary.', peppers: ['Ghost Pepper', 'Carolina Reaper', 'Trinidad Scorpion', 'Pepper X'] }
    ];

    const result = results.find(r => quizScore >= r.min && quizScore <= r.max) || results[results.length - 1];
    document.getElementById('resultEmoji').innerHTML = result.emoji;
    document.getElementById('resultTitle').textContent = result.title;
    document.getElementById('resultRange').textContent = result.range;
    document.getElementById('resultDesc').textContent = result.desc;
    document.getElementById('resultPeppers').innerHTML = result.peppers.map(p => '<span class="rp">' + p + '</span>').join('');
    quizResult.classList.add('visible');
  }

  document.getElementById('quizRestart').addEventListener('click', () => {
    currentQ = 0;
    quizScore = 0;
    quizResult.classList.remove('visible');
    questions.forEach(q => q.classList.remove('active'));
    questions[0].classList.add('active');
    dots.forEach(d => { d.classList.remove('done', 'current'); });
    dots[0].classList.add('current');
    document.querySelectorAll('.quiz-opt').forEach(o => o.classList.remove('selected'));
  });
</script>


