---
import SiteLayout from '../../../layouts/SiteLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      "name": "Scoville Heat Scale Reference",
      "description": "Interactive Scoville heat scale showing 40+ peppers and hot sauces from mild to extreme. Visual heat meter, sortable table, heat tolerance quiz, and capsaicin science facts.",
      "url": "https://28grams.vip/scoville-scale",
      "applicationCategory": "UtilitiesApplication",
      "operatingSystem": "All",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      },
      "author": {
        "@type": "Organization",
        "name": "28grams"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is the Scoville scale and how is it measured?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "The Scoville scale measures the pungency (spiciness) of chili peppers and spicy foods in Scoville Heat Units (SHU). Originally created by pharmacist Wilbur Scoville in 1912 using a taste test panel, modern measurements use High-Performance Liquid Chromatography (HPLC) to precisely quantify capsaicinoid concentration. A bell pepper scores 0 SHU while pure capsaicin reaches 16,000,000 SHU."
          }
        },
        {
          "@type": "Question",
          "name": "What is the hottest pepper in the world?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Pepper X currently holds the Guinness World Record at 2,693,000 SHU, surpassing the Carolina Reaper (2,200,000 SHU). Both were created by Ed Currie of PuckerButt Pepper Company. The Dragon's Breath and Apollo peppers have claimed higher unofficial measurements but lack verified Guinness records."
          }
        },
        {
          "@type": "Question",
          "name": "Why do some people enjoy eating extremely spicy food?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Capsaicin triggers pain receptors (TRPV1) which causes the brain to release endorphins and dopamine, creating a natural 'high' similar to a runner's high. Over time, repeated exposure desensitizes these receptors, allowing spice lovers to tolerate and enjoy increasingly hotter foods. This is sometimes called 'benign masochism' — the thrill of pain in a safe context."
          }
        },
        {
          "@type": "Question",
          "name": "What helps cool your mouth after eating something too spicy?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Dairy products like milk, yogurt, and ice cream are most effective because casein protein binds to capsaicin and washes it away. Sugar and starchy foods like bread or rice also help absorb capsaicin. Avoid water — capsaicin is oil-soluble, not water-soluble, so water just spreads the heat around your mouth."
          }
        },
        {
          "@type": "Question",
          "name": "Is eating very spicy food dangerous or harmful?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "For most healthy adults, eating spicy food is safe and may even have health benefits including boosted metabolism, anti-inflammatory effects, and improved cardiovascular health. However, extremely hot peppers (1M+ SHU) can cause intense pain, nausea, vomiting, and in rare cases, capsaicin cramps. People with GERD, IBS, or stomach ulcers should be cautious with very spicy foods."
          }
        }
      ]
    }
  ]
};

export const meta = {
  title: "Scoville Heat Scale | Pepper & Hot Sauce Reference Guide",
  description: "Interactive Scoville heat scale for 40+ peppers and hot sauces. Visual heat meter, sortable table, heat tolerance quiz, and capsaicin science fun facts.",
  category: "guide",
  published: "2026-03-21",
};
