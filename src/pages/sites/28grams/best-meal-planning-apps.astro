            <td>Built-in</td>
            <td class="check-icon">✓ Yes</td>
            <td class="check-icon">✓ Yes</td>
            <td>Web, iOS, Android</td>
          </tr>
          <tr class="app-row">
            <td class="app-name">Paprika</td>
            <td class="x-icon">✗ No</td>
            <td class="price-tag mono">$4.99 (one-time)</td>
            <td>Import Only</td>
            <td class="check-icon">✓ Yes</td>
            <td class="x-icon">✗ No</td>
            <td>Web, iOS, Android, Mac, Win</td>
          </tr>
          <tr class="app-row">
            <td class="app-name">Plan to Eat</td>
            <td class="x-icon">✗ No</td>
            <td class="price-tag mono">$4.95/mo</td>
            <td>Import Only</td>
            <td class="check-icon">✓ Yes</td>
            <td class="x-icon">✗ No</td>
            <td>Web, iOS, Android</td>
          </tr>
          <tr class="app-row">
            <td class="app-name">Yummly</td>
            <td class="check-icon">✓ Yes</td>
            <td class="price-tag mono">$4.99/mo</td>
            <td>Built-in</td>
            <td class="check-icon">✓ Yes</td>
            <td class="check-icon">✓ Yes</td>
            <td>iOS, Android</td>
          </tr>
          <tr class="app-row">
            <td class="app-name">Whisk</td>
            <td class="check-icon">✓ Yes (100% Free)</td>
            <td class="price-tag mono">Free</td>
            <td>Import/Built-in</td>
            <td class="check-icon">✓ Yes</td>
            <td class="check-icon">✓ Yes</td>
            <td>Web, iOS, Android</td>
          </tr>
          <tr class="app-row">
            <td class="app-name">MealPrepPro</td>
            <td class="x-icon">✗ No</td>
