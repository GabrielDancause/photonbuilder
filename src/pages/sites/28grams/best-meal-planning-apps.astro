          </tr>
        </thead>
        <tbody id="tableBody">
          <tr class="app-row">
            <td class="app-name">Mealime</td>
            <td class="check-icon">✓ Yes</td>
            <td class="price-tag mono">$2.99/mo</td>
            <td>Built-in</td>
            <td class="check-icon">✓ Yes</td>
            <td class="check-icon">✓ Yes</td>
            <td>iOS, Android</td>
          </tr>
          <tr class="app-row">
            <td class="app-name">Eat This Much</td>
