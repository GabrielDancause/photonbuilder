            <td class="app-name">SideChef</td>
            <td class="check-icon">✓ Yes</td>
            <td class="price-tag mono">$4.99/mo</td>
            <td>Built-in</td>
            <td class="check-icon">✓ Yes</td>
            <td class="check-icon">✓ Yes</td>
            <td>Web, iOS, Android</td>
          </tr>
          <tr class="app-row">
            <td class="app-name">Cooklist</td>
            <td class="check-icon">✓ Yes</td>
            <td class="price-tag mono">$5.99/mo</td>
            <td>Import/Built-in</td>
            <td class="check-icon">✓ Yes</td>
            <td class="check-icon">✓ Yes</td>
