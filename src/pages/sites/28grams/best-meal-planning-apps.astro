<script is:inline>
  const headers = document.querySelectorAll('th[data-sort]');
  const rows = document.querySelectorAll('.app-row');
  const tableBody = document.getElementById('tableBody');

  headers.forEach(header => {
    header.addEventListener('click', () => {
      const sortType = header.getAttribute('data-sort');
      const isAsc = !header.classList.contains('asc');

      headers.forEach(h => { h.classList.remove('asc', 'desc'); });
      header.classList.add(isAsc ? 'asc' : 'desc');

      const rowsArray = Array.from(rows);

      rowsArray.sort((a, b) => {
        let aVal, bVal;

        if (sortType === 'app') {
          aVal = a.children[0].innerText.toLowerCase();
          bVal = b.children[0].innerText.toLowerCase();
        } else if (sortType === 'freetier' || sortType === 'grocery' || sortType === 'dietary') {
          const colIndex = sortType === 'freetier' ? 1 : (sortType === 'grocery' ? 4 : 5);
          aVal = a.children[colIndex].innerText.includes('✓') ? 1 : 0;
          bVal = b.children[colIndex].innerText.includes('✓') ? 1 : 0;
        } else if (sortType === 'price') {
          // simple sort for price string
          aVal = a.children[2].innerText.includes('Free') ? 0 : parseFloat(a.children[2].innerText.replace(/[^0-9.]/g, '')) || 100;
          bVal = b.children[2].innerText.includes('Free') ? 0 : parseFloat(b.children[2].innerText.replace(/[^0-9.]/g, '')) || 100;
        } else if (sortType === 'database') {
          aVal = a.children[3].innerText.toLowerCase();
          bVal = b.children[3].innerText.toLowerCase();
        } else if (sortType === 'platforms') {
          aVal = a.children[6].innerText.toLowerCase();
          bVal = b.children[6].innerText.toLowerCase();
        }

        if (aVal < bVal) return isAsc ? -1 : 1;
        if (aVal > bVal) return isAsc ? 1 : -1;
        return 0;
      });

      rowsArray.forEach(row => tableBody.appendChild(row));
    });
  });
</script>

