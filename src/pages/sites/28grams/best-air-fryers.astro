    <div class="faq-item">
      <div class="faq-q">Do I need to preheat my air fryer?</div>
      <div class="faq-a">While not strictly necessary for all recipes, preheating for 3-5 minutes generally results in more even cooking and a crispier texture, similar to preheating a traditional oven.</div>
    </div>
    <div class="faq-item">
      <div class="faq-q">Can I use aluminum foil or parchment paper in an air fryer?</div>
      <div class="faq-a">Yes, you can use both, but make sure they don't cover the entire bottom to allow air circulation. Never preheat the air fryer with just the paper or foil inside, as the fan can blow it into the heating element and cause a fire.</div>
    </div>
  </div>
</div>

<script is:inline>
  const headers = document.querySelectorAll('th[data-sort]');
  const rows = document.querySelectorAll('.brand-row');
  const tableBody = document.getElementById('tableBody');

  // Sort logic
  headers.forEach(header => {
    header.addEventListener('click', () => {
      const sortType = header.getAttribute('data-sort');
      const isAsc = !header.classList.contains('asc');

      headers.forEach(h => { h.classList.remove('asc', 'desc'); });
      header.classList.add(isAsc ? 'asc' : 'desc');

      const rowsArray = Array.from(rows);

      rowsArray.sort((a, b) => {
        let aVal, bVal;

        if (sortType === 'brand') {
          aVal = a.children[0].innerText.toLowerCase();
          bVal = b.children[0].innerText.toLowerCase();
        } else if (sortType === 'type') {
          aVal = a.children[1].innerText.toLowerCase();
          bVal = b.children[1].innerText.toLowerCase();
        } else if (sortType === 'capacity') {
          aVal = parseFloat(a.children[2].innerText) || 0;
          bVal = parseFloat(b.children[2].innerText) || 0;
        } else if (sortType === 'power') {
          aVal = parseFloat(a.children[3].innerText) || 0;
          bVal = parseFloat(b.children[3].innerText) || 0;
        } else if (sortType === 'presets') {
          aVal = parseFloat(a.children[4].innerText) || 0;
          bVal = parseFloat(b.children[4].innerText) || 0;
        } else if (sortType === 'clean') {
          aVal = a.children[5].innerText.toLowerCase();
          bVal = b.children[5].innerText.toLowerCase();
        } else if (sortType === 'price') {
          aVal = a.children[6].innerText.length; // Compare number of '$'
          bVal = b.children[6].innerText.length;
        }

        if (aVal < bVal) return isAsc ? -1 : 1;
        if (aVal > bVal) return isAsc ? 1 : -1;
        return 0;
      });

      rowsArray.forEach(row => tableBody.appendChild(row));
    });
  });
</script>

</SiteLayout>
