---
import SiteLayout from '../../../layouts/SiteLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      "name": "Spice Blend Builder — Create Custom Spice Mixes",
      "description": "Interactive spice blend builder with 20 classic blends, 10 cuisine bases, adjustable ratio sliders, and printable recipe cards. Create your perfect custom spice mix.",
      "url": "https://28grams.vip/spice-blend-builder",
      "applicationCategory": "UtilitiesApplication",
      "operatingSystem": "Any",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      },
      "author": {
        "@type": "Organization",
        "name": "28grams"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "How do I create a custom spice blend?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Start by selecting a cuisine base (like Mexican, Indian, or Italian) to get a starter blend with the right foundation spices. Then adjust the ratio sliders for each spice to customize the proportions to your taste. You can also add or remove individual spices. Once satisfied, generate a printable recipe card with your exact measurements."
          }
        },
        {
          "@type": "Question",
          "name": "What is the difference between whole and ground spices in a blend?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Whole spices retain their flavor longer and are best toasted before grinding for maximum aroma. Ground spices are more convenient and distribute evenly in a blend, but lose potency faster. For the best results, buy whole spices and grind them fresh. A general rule: 1 teaspoon whole spice yields about 1.5 teaspoons ground."
          }
        },
        {
          "@type": "Question",
          "name": "How long do homemade spice blends last?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Homemade ground spice blends stay potent for 3-6 months when stored in airtight containers away from heat, light, and moisture. Whole spice blends last up to a year. Label your blends with the date made. If a blend loses its strong aroma when you open the jar, it is time to make a fresh batch."
          }
        },
        {
          "@type": "Question",
          "name": "Can I substitute dried herbs for fresh in a spice blend?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, but adjust the ratio. Use 1 teaspoon dried herbs for every 1 tablespoon of fresh (a 1:3 ratio). Dried herbs are more concentrated in flavor. For spice blends meant for storage, always use dried herbs since fresh herbs will introduce moisture and spoil quickly."
          }
        },
        {
          "@type": "Question",
          "name": "What dishes work best with homemade spice blends?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Homemade spice blends work with almost any dish. Use them as dry rubs for grilled meats, stir into soups and stews, season roasted vegetables, mix into marinades with oil and acid, sprinkle on popcorn or roasted nuts, or blend into compound butters. The key is matching the blend's cuisine origin to complementary ingredients."
          }
        }
      ]
    }
  ]
};

export const meta = {
  title: "Spice Blend Builder | Create Custom Spice Mixes",
  description: "Build custom spice blends with adjustable ratios. 20 classic blends including garam masala, za'atar, ras el hanout, and more. Printable recipe cards and dish pairing suggestions.",
  category: "tool",
  published: "2024-06-10",
};
---

<SiteLayout
  site="28grams"
  title="Spice Blend Builder | Create Custom Spice Mixes"
  description="Build custom spice blends with adjustable ratios. 20 classic blends including garam masala, za'atar, ras el hanout, and more. Printable recipe cards and dish pairing suggestions."
  canonical="https://28grams.vip/spice-blend-builder"
  schema={schema}
>
  <style>
* { margin: 0; padding: 0; box-sizing: border-box; }
body { font-family: 'Inter', sans-serif; background: #0a060a; color: #e0d0d8; min-height: 100vh; }
code, .mono { font-family: 'JetBrains Mono', monospace; }
.hero { text-align: center; padding: 48px 24px 24px; background: linear-gradient(180deg, #1a0a14 0%, #0a060a 100%); }
.hero h1 { font-size: 2.4rem; font-weight: 900; color: #fff; margin-bottom: 6px; }
.hero h1 span { background: linear-gradient(135deg, #C2185B, #ff6b9d); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
.hero p { color: #666; font-size: 0.95rem; max-width: 560px; margin: 0 auto; }
.main { max-width: 1100px; margin: 0 auto; padding: 32px 20px 40px; }

/* Cuisine Selector */
.cuisine-section { margin-bottom: 24px; }
.cuisine-label {
  font-size: 0.75rem;
  color: #666;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  font-weight: 600;
  text-align: center;
  margin-bottom: 10px;
}
.cuisine-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 8px;
}
.cuisine-btn {
  background: #120c10;
  border: 1px solid #2a1820;
  color: #c8b8c0;
  padding: 10px 18px;
  border-radius: 20px;
  font-size: 0.85rem;
  font-weight: 600;
  cursor: pointer;
  font-family: 'Inter', sans-serif;
  transition: all 0.2s;
}
.cuisine-btn:hover { border-color: #C2185B; color: #fff; }
.cuisine-btn.active { background: #C2185B; border-color: #C2185B; color: #fff; }

/* Preset Blends */
.preset-card {
  background: #120c10;
  border: 2px solid #2a1820;
  border-radius: 16px;
  padding: 24px;
  margin-bottom: 24px;
}
.preset-card h3 { font-size: 1rem; font-weight: 700; color: #fff; margin-bottom: 12px; text-align: center; }
.preset-select {
  background: #1a1015;
  border: 1px solid #2a1820;
  border-radius: 8px;
  padding: 10px 16px;
  color: #fff;
  font-family: 'Inter', sans-serif;
  font-size: 0.9rem;
  width: 100%;
  max-width: 400px;
  outline: none;
  cursor: pointer;
  display: block;
  margin: 0 auto;
}
.preset-select:focus { border-color: #C2185B; }

/* Builder Card */
.builder-card {
  background: #120c10;
  border: 2px solid #2a1820;
  border-radius: 16px;
  overflow: hidden;
  margin-bottom: 24px;
}
.builder-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 20px;
  background: #150d12;
  border-bottom: 1px solid #2a1820;
}
.builder-header h2 { font-size: 1rem; font-weight: 700; color: #fff; }
.blend-name-input {
  background: #1a1015;
  border: 1px solid #2a1820;
  border-radius: 8px;
  padding: 8px 12px;
  color: #fff;
  font-family: 'Inter', sans-serif;
  font-size: 0.85rem;
  outline: none;
  width: 200px;
}
.blend-name-input:focus { border-color: #C2185B; }

.builder-body { padding: 20px; }

/* Spice Rows */
.spice-list { display: flex; flex-direction: column; gap: 12px; }
.spice-row {
  display: grid;
  grid-template-columns: 160px 1fr 60px 36px;
  align-items: center;
  gap: 12px;
  background: #1a1015;
  border: 1px solid #2a1820;
  border-radius: 10px;
  padding: 12px 16px;
}
.spice-name { font-size: 0.88rem; font-weight: 600; color: #fff; }
.spice-slider {
  -webkit-appearance: none;
  appearance: none;
  width: 100%;
  height: 6px;
  background: #2a1820;
  border-radius: 3px;
  outline: none;
}
.spice-slider::-webkit-slider-thumb {
  -webkit-appearance: none;
  appearance: none;
  width: 18px;
  height: 18px;
  background: #C2185B;
  border-radius: 50%;
  cursor: pointer;
}
.spice-slider::-moz-range-thumb {
  width: 18px;
  height: 18px;
  background: #C2185B;
  border-radius: 50%;
  cursor: pointer;
  border: none;
}
.spice-value {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.82rem;
  color: #f97316;
  font-weight: 600;
  text-align: center;
}
.spice-remove {
  background: none;
  border: 1px solid #2a1820;
  color: #666;
  width: 28px;
  height: 28px;
  border-radius: 6px;
  cursor: pointer;
  font-size: 1rem;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
}
.spice-remove:hover { border-color: #e53935; color: #e53935; }

/* Add Spice */
.add-spice-row {
  display: flex;
  gap: 8px;
  margin-top: 16px;
  justify-content: center;
  flex-wrap: wrap;
}
.add-spice-select {
  background: #1a1015;
  border: 1px solid #2a1820;
  border-radius: 8px;
  padding: 8px 12px;
  color: #fff;
  font-family: 'Inter', sans-serif;
  font-size: 0.85rem;
  outline: none;
  min-width: 200px;
}
.add-spice-select:focus { border-color: #C2185B; }
.add-btn {
  background: #C2185B;
  border: none;
  color: #fff;
  padding: 8px 20px;
  border-radius: 8px;
  font-size: 0.85rem;
  font-weight: 600;
  cursor: pointer;
  font-family: 'Inter', sans-serif;
  transition: all 0.2s;
}
.add-btn:hover { background: #d81b60; }

/* Actions */
.actions-row {
  display: flex;
  gap: 10px;
  margin-top: 20px;
  justify-content: center;
  flex-wrap: wrap;
}
.action-btn {
  background: #120c10;
  border: 1px solid #2a1820;
  color: #c8b8c0;
  padding: 10px 20px;
  border-radius: 10px;
  font-size: 0.85rem;
  font-weight: 600;
  cursor: pointer;
  font-family: 'Inter', sans-serif;
  transition: all 0.2s;
}
.action-btn:hover { border-color: #C2185B; color: #fff; }
.action-btn.primary { background: #C2185B; border-color: #C2185B; color: #fff; }
.action-btn.primary:hover { background: #d81b60; }

/* Recipe Card Preview */
.recipe-card-preview {
  background: #1a1015;
  border: 2px solid #2a1820;
  border-radius: 16px;
  padding: 28px;
  margin-bottom: 24px;
  display: none;
}
.recipe-card-preview.visible { display: block; }
.recipe-card-preview h3 {
  font-size: 1.3rem;
  font-weight: 800;
  color: #fff;
  margin-bottom: 4px;
  text-align: center;
}
.recipe-card-preview .recipe-subtitle {
  text-align: center;
  font-size: 0.8rem;
  color: #666;
  margin-bottom: 20px;
}
.recipe-ingredients {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: 8px;
  margin-bottom: 20px;
}
.recipe-ingredient {
  display: flex;
  justify-content: space-between;
  padding: 8px 12px;
  background: #120c10;
  border-radius: 8px;
  border: 1px solid #2a1820;
}
.recipe-ingredient .ri-name { font-size: 0.85rem; color: #ccc; }
.recipe-ingredient .ri-amount { font-size: 0.85rem; color: #f97316; font-weight: 600; font-family: 'JetBrains Mono', monospace; }
.recipe-total {
  text-align: center;
  font-size: 0.82rem;
  color: #888;
  margin-bottom: 16px;
  padding: 10px;
  background: #120c10;
  border-radius: 8px;
  border: 1px solid #2a1820;
}
.recipe-dishes h4 { font-size: 0.9rem; font-weight: 700; color: #ccc; margin-bottom: 8px; }
.dish-tags { display: flex; flex-wrap: wrap; gap: 6px; }
.dish-tag {
  background: #2a1820;
  color: #e0d0d8;
  padding: 5px 12px;
  border-radius: 16px;
  font-size: 0.78rem;
  font-weight: 500;
}

/* Chart Card — Classic Blends Table */
.chart-card {
  background: #120c10;
  border: 2px solid #2a1820;
  border-radius: 16px;
  overflow: hidden;
  margin-bottom: 32px;
}
.chart-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 20px;
  background: #150d12;
  border-bottom: 1px solid #2a1820;
}
.chart-header h2 { font-size: 1rem; font-weight: 700; color: #fff; }
.result-count { font-size: 0.8rem; color: #888; margin-left: 8px; }
.search-wrap { position: relative; width: 100%; max-width: 300px; }
.search-input {
  width: 100%;
  background: #1a1015;
  border: 1px solid #2a1820;
  border-radius: 8px;
  padding: 8px 12px 8px 32px;
  color: #fff;
  font-family: 'Inter', sans-serif;
  font-size: 0.85rem;
  outline: none;
}
.search-input:focus { border-color: #C2185B; }
.search-icon { position: absolute; left: 10px; top: 50%; transform: translateY(-50%); color: #888; font-size: 0.85rem; }

.table-container { width: 100%; overflow-x: auto; }
.blend-table { width: 100%; border-collapse: collapse; min-width: 700px; }
.blend-table th {
  text-align: left;
  font-size: 0.75rem;
  color: #888;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  padding: 12px 16px;
  background: #1a1015;
  border-bottom: 2px solid #2a1820;
}
.blend-table td {
  padding: 12px 16px;
  font-size: 0.88rem;
  color: #c8b8c0;
  border-bottom: 1px solid #1a1015;
}
.blend-table tr:hover td { background: #1a1015; }
.blend-table tr.hidden { display: none; }
.blend-table td:first-child { font-weight: 600; color: #fff; }
.origin-cell { font-size: 0.8rem; }
.spices-cell { font-size: 0.8rem; color: #aaa; }
.use-cell { font-size: 0.8rem; }
.load-btn {
  background: #1a1015;
  border: 1px solid #C2185B;
  color: #C2185B;
  padding: 4px 12px;
  border-radius: 6px;
  font-size: 0.75rem;
  font-weight: 600;
  cursor: pointer;
  font-family: 'Inter', sans-serif;
  transition: all 0.2s;
}
.load-btn:hover { background: #C2185B; color: #fff; }

/* Tips Card */
.tips-card {
  background: #120c10;
  border: 2px solid #2a1820;
  border-radius: 16px;
  padding: 24px;
  margin-bottom: 32px;
}
.tips-card h3 { font-size: 1.1rem; font-weight: 700; color: #fff; margin-bottom: 16px; }
.tips-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 16px;
}
.tip-item {
  background: #1a1015;
  border-radius: 12px;
  padding: 16px;
  border: 1px solid #2a1820;
}
.tip-item h4 { font-size: 0.9rem; color: #ccc; margin-bottom: 8px; }
.tip-item p { font-size: 0.82rem; color: #888; line-height: 1.6; }

/* SEO content */
.content { max-width: 800px; margin: 0 auto; padding: 0 20px; }
.content h2 { font-size: 1.4rem; font-weight: 800; color: #fff; margin: 40px 0 14px; }
.content h2:first-child { margin-top: 0; }
.content h3 { font-size: 1.1rem; font-weight: 700; color: #ddd; margin: 24px 0 10px; }
.content p { font-size: 0.9rem; color: #777; line-height: 1.8; margin-bottom: 14px; }
.content ul, .content ol { padding-left: 20px; margin-bottom: 14px; }
.content li { font-size: 0.88rem; color: #777; line-height: 1.8; margin-bottom: 4px; }
.content strong { color: #ccc; }

/* FAQ */
.faq-list { margin-bottom: 40px; }
.faq-item { border-bottom: 1px solid #1a1015; padding: 16px 0; }
.faq-item:last-child { border-bottom: none; }
.faq-q { font-size: 0.95rem; font-weight: 700; color: #ddd; margin-bottom: 8px; }
.faq-a { font-size: 0.88rem; color: #777; line-height: 1.8; }

/* Related */
.related-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 12px;
  margin-top: 12px;
}
.related-link {
  display: block;
  background: #120c10;
  border: 1px solid #2a1820;
  border-radius: 12px;
  padding: 16px;
  text-decoration: none;
  transition: all 0.2s;
}
.related-link:hover { border-color: #C2185B; transform: translateY(-2px); }
.related-link h4 { font-size: 0.85rem; color: #fff; font-weight: 700; margin-bottom: 4px; }
.related-link p { font-size: 0.75rem; color: #666; }

/* Print */
@media print {
  body { background: #fff !important; color: #000 !important; }
  .hero, .cuisine-section, .preset-card, .builder-card, .chart-card, .tips-card, .content, .related-grid, .actions-row { display: none !important; }
  .recipe-card-preview { display: block !important; background: #fff !important; border: 2px solid #333 !important; color: #000 !important; }
  .recipe-card-preview h3 { color: #000 !important; }
  .recipe-card-preview .recipe-subtitle { color: #666 !important; }
  .recipe-ingredient { background: #f5f5f5 !important; border-color: #ddd !important; }
  .recipe-ingredient .ri-name { color: #333 !important; }
  .recipe-ingredient .ri-amount { color: #c62828 !important; }
  .recipe-total { background: #f5f5f5 !important; border-color: #ddd !important; color: #333 !important; }
  .recipe-dishes h4 { color: #333 !important; }
  .dish-tag { background: #eee !important; color: #333 !important; }
}

@media (max-width: 600px) {
  .hero h1 { font-size: 1.8rem; }
  .spice-row { grid-template-columns: 120px 1fr 50px 32px; gap: 8px; padding: 10px 12px; }
  .chart-header { flex-direction: column; gap: 12px; align-items: flex-start; }
  .search-wrap { max-width: 100%; }
  .builder-header { flex-direction: column; gap: 10px; align-items: flex-start; }
  .blend-name-input { width: 100%; }
}
  </style>

<div class="hero">
  <h1>Spice <span>Blend</span> Builder</h1>
  <p>Create custom spice blends from 10 cuisine bases, explore 20 classic blends, adjust ratios with sliders, and generate printable recipe cards.</p>
</div>

<div class="main">

  <!-- Cuisine Base Selector -->
  <div class="cuisine-section">
    <div class="cuisine-label">Start with a Cuisine Base</div>
    <div class="cuisine-grid" id="cuisineGrid">
      <button class="cuisine-btn" data-cuisine="mexican">Mexican</button>
      <button class="cuisine-btn" data-cuisine="indian">Indian</button>
      <button class="cuisine-btn" data-cuisine="italian">Italian</button>
      <button class="cuisine-btn" data-cuisine="middle-eastern">Middle Eastern</button>
      <button class="cuisine-btn" data-cuisine="chinese">Chinese</button>
      <button class="cuisine-btn" data-cuisine="thai">Thai</button>
      <button class="cuisine-btn" data-cuisine="ethiopian">Ethiopian</button>
      <button class="cuisine-btn" data-cuisine="cajun">Cajun</button>
      <button class="cuisine-btn" data-cuisine="japanese">Japanese</button>
      <button class="cuisine-btn" data-cuisine="mediterranean">Mediterranean</button>
    </div>
  </div>

  <!-- Preset Classic Blends -->
  <div class="preset-card">
    <h3>Or Load a Classic Blend</h3>
    <select class="preset-select" id="presetSelect">
      <option value="">Choose a classic blend...</option>
      <option value="garam-masala">Garam Masala</option>
      <option value="zaatar">Za'atar</option>
      <option value="ras-el-hanout">Ras el Hanout</option>
      <option value="herbes-de-provence">Herbes de Provence</option>
      <option value="five-spice">Chinese Five-Spice</option>
      <option value="chili-powder">Chili Powder</option>
      <option value="taco-seasoning">Taco Seasoning</option>
      <option value="curry-powder">Curry Powder</option>
      <option value="jerk-seasoning">Jerk Seasoning</option>
      <option value="italian-seasoning">Italian Seasoning</option>
      <option value="cajun-seasoning">Cajun Seasoning</option>
      <option value="berbere">Berbere</option>
      <option value="baharat">Baharat</option>
      <option value="shichimi-togarashi">Shichimi Togarashi</option>
      <option value="dukkah">Dukkah</option>
      <option value="old-bay">Old Bay Style</option>
      <option value="pumpkin-spice">Pumpkin Spice</option>
      <option value="chinese-13-spice">Chinese 13-Spice</option>
      <option value="advieh">Advieh (Persian)</option>
      <option value="quatre-epices">Quatre Epices</option>
    </select>
  </div>

  <!-- Blend Builder -->
  <div class="builder-card">
    <div class="builder-header">
      <h2>Your Blend</h2>
      <input type="text" class="blend-name-input" id="blendName" placeholder="Name your blend..." value="My Custom Blend">
    </div>
    <div class="builder-body">
      <div class="spice-list" id="spiceList">
        <!-- Spice rows inserted by JS -->
      </div>
      <div class="add-spice-row">
        <select class="add-spice-select" id="addSpiceSelect">
          <option value="">Add a spice...</option>
        </select>
        <button class="add-btn" id="addSpiceBtn">+ Add</button>
      </div>
      <div class="actions-row">
        <button class="action-btn" id="resetBtn">Reset</button>
        <button class="action-btn" id="randomBtn">Randomize</button>
        <button class="action-btn primary" id="generateBtn">Generate Recipe Card</button>
      </div>
    </div>
  </div>

  <!-- Recipe Card Preview -->
  <div class="recipe-card-preview" id="recipeCard">
    <h3 id="recipeTitle">My Custom Blend</h3>
    <div class="recipe-subtitle">Custom Spice Blend &mdash; 28grams.vip</div>
    <div class="recipe-ingredients" id="recipeIngredients"></div>
    <div class="recipe-total" id="recipeTotal"></div>
    <div class="recipe-dishes">
      <h4>Suggested Dishes</h4>
      <div class="dish-tags" id="recipeDishes"></div>
    </div>
    <div class="actions-row" style="margin-top: 16px;">
      <button class="action-btn primary" id="printBtn">Print Recipe Card</button>
    </div>
  </div>

  <!-- Classic Blends Reference Table -->
  <div class="chart-card">
    <div class="chart-header">
      <h2>20 Classic Blends <span class="result-count" id="blendResultCount"></span></h2>
      <div class="search-wrap">
        <span class="search-icon">&#128269;</span>
        <input type="text" id="blendSearch" class="search-input" placeholder="Search blends...">
      </div>
    </div>
    <div class="table-container">
      <table class="blend-table">
        <thead>
          <tr>
            <th>Blend</th>
            <th>Origin</th>
            <th>Key Spices</th>
            <th>Best For</th>
            <th></th>
          </tr>
