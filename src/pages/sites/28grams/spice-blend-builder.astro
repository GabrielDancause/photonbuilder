    const entries = Object.entries(currentSpices);
    if (entries.length === 0) {
      spiceListEl.innerHTML = '<div style="text-align:center;color:#666;padding:20px;font-size:0.9rem;">Select a cuisine base or classic blend to get started, or add spices manually.</div>';
      return;
    }
    entries.forEach(([name, value]) => {
      const row = document.createElement('div');
      row.className = 'spice-row';
      row.innerHTML =
        '<div class="spice-name">' + name + '</div>' +
        '<input type="range" class="spice-slider" min="0" max="10" value="' + value + '" data-spice="' + name + '">' +
        '<div class="spice-value">' + value + ' parts</div>' +
        '<button class="spice-remove" data-spice="' + name + '">&times;</button>';
      spiceListEl.appendChild(row);
    });

    spiceListEl.querySelectorAll('.spice-slider').forEach(slider => {
      slider.addEventListener('input', (e) => {
        const spice = e.target.getAttribute('data-spice');
        const val = parseInt(e.target.value);
        currentSpices[spice] = val;
        e.target.parentElement.querySelector('.spice-value').textContent = val + ' parts';
      });
    });

    spiceListEl.querySelectorAll('.spice-remove').forEach(btn => {
      btn.addEventListener('click', (e) => {
        const spice = e.target.getAttribute('data-spice');
        delete currentSpices[spice];
        renderSpices();
        populateAddSelect();
      });
    });

    populateAddSelect();
  }

  function loadBlend(spices, dishes, name) {
    currentSpices = { ...spices };
    currentDishes = [...dishes];
    currentBlendName = name;
    blendNameInput.value = name;
    renderSpices();
    recipeCard.classList.remove('visible');
    window.scrollTo({ top: document.querySelector('.builder-card').offsetTop - 20, behavior: 'smooth' });
  }

  cuisineBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      cuisineBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const cuisine = btn.getAttribute('data-cuisine');
      const base = CUISINE_BASES[cuisine];
      presetSelect.value = '';
      loadBlend(base.spices, base.dishes, base.name);
    });
  });

  presetSelect.addEventListener('change', () => {
    if (!presetSelect.value) return;
    cuisineBtns.forEach(b => b.classList.remove('active'));
    const blend = PRESET_BLENDS[presetSelect.value];
    loadBlend(blend.spices, blend.dishes, blend.name);
  });

  loadBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const key = btn.getAttribute('data-load');
      presetSelect.value = key;
      cuisineBtns.forEach(b => b.classList.remove('active'));
      const blend = PRESET_BLENDS[key];
      loadBlend(blend.spices, blend.dishes, blend.name);
    });
  });

  addSpiceBtn.addEventListener('click', () => {
    const spice = addSpiceSelect.value;
    if (!spice || spice in currentSpices) return;
    currentSpices[spice] = 2;
    renderSpices();
  });

  blendNameInput.addEventListener('input', () => {
    currentBlendName = blendNameInput.value || 'My Custom Blend';
  });

  resetBtn.addEventListener('click', () => {
    currentSpices = {};
    currentDishes = [];
    currentBlendName = 'My Custom Blend';
    blendNameInput.value = currentBlendName;
    cuisineBtns.forEach(b => b.classList.remove('active'));
    presetSelect.value = '';
    renderSpices();
    recipeCard.classList.remove('visible');
  });

  randomBtn.addEventListener('click', () => {
    const shuffled = ALL_SPICES.slice().sort(() => Math.random() - 0.5);
    const count = 5 + Math.floor(Math.random() * 4);
    const picked = {};
    for (let i = 0; i < count; i++) {
      picked[shuffled[i]] = 1 + Math.floor(Math.random() * 5);
    }
    currentSpices = picked;
    currentDishes = ['Roasted Vegetables','Grilled Meats','Soups','Stews','Rice Dishes','Marinades'];
    currentBlendName = 'Mystery Blend';
    blendNameInput.value = currentBlendName;
    cuisineBtns.forEach(b => b.classList.remove('active'));
    presetSelect.value = '';
    renderSpices();
    recipeCard.classList.remove('visible');
  });

  generateBtn.addEventListener('click', () => {
    const entries = Object.entries(currentSpices).filter(([,v]) => v > 0);
    if (entries.length === 0) return;
    const totalParts = entries.reduce((s, [,v]) => s + v, 0);
    const title = blendNameInput.value || 'My Custom Blend';

    document.getElementById('recipeTitle').textContent = title;
    const ingredientsEl = document.getElementById('recipeIngredients');
    ingredientsEl.innerHTML = '';
    entries.sort((a, b) => b[1] - a[1]).forEach(([name, parts]) => {
      const tsp = (parts / totalParts * 12).toFixed(1);
      const div = document.createElement('div');
      div.className = 'recipe-ingredient';
      div.innerHTML = '<span class="ri-name">' + name + '</span><span class="ri-amount">' + tsp + ' tsp (' + parts + ' parts)</span>';
      ingredientsEl.appendChild(div);
    });

    document.getElementById('recipeTotal').textContent = 'Total: ' + totalParts + ' parts \u2022 Makes ~' + (totalParts * 0.5).toFixed(0) + ' tsp (' + (totalParts * 0.5 / 3).toFixed(1) + ' Tbsp) \u2022 Scale up or down by multiplying all parts equally';

    const dishesEl = document.getElementById('recipeDishes');
    dishesEl.innerHTML = '';
    const dishes = currentDishes.length > 0 ? currentDishes : ['Roasted Vegetables','Grilled Meats','Soups','Stews','Marinades','Rice Dishes'];
    dishes.forEach(d => {
      const tag = document.createElement('span');
      tag.className = 'dish-tag';
      tag.textContent = d;
      dishesEl.appendChild(tag);
    });

    recipeCard.classList.add('visible');
    recipeCard.scrollIntoView({ behavior: 'smooth', block: 'center' });
  });

  printBtn.addEventListener('click', () => {
    window.print();
  });

  // Blend table search
  function filterBlendTable() {
    const query = blendSearch.value.toLowerCase();
    let visible = 0;
    blendRows.forEach(row => {
      const text = row.innerText.toLowerCase();
      if (text.includes(query)) {
        row.classList.remove('hidden');
        visible++;
      } else {
        row.classList.add('hidden');
      }
    });
    blendResultCount.textContent = '(' + visible + ' results)';
  }
  blendSearch.addEventListener('input', filterBlendTable);

  // Init
  renderSpices();
  populateAddSelect();
  filterBlendTable();
</script>

</SiteLayout>