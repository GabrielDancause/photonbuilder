---
import SiteLayout from '../../../layouts/SiteLayout.astro';

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Homemade Pasta Guide",
    "description": "Complete pasta-making guide covering basic egg pasta dough, semolina pasta, gluten-free pasta, hand-rolling vs pasta machine, 8 shapes to make by hand, sauce pairings, drying and storing, and cooking fresh vs dried timing.",
    "url": "https://28grams.vip/homemade-pasta-guide",
    "author": {
      "@type": "Organization",
      "name": "28grams"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How long does fresh pasta take to cook?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Fresh pasta cooks much faster than dried pasta. Typically, it takes just 2-3 minutes in rapidly boiling salted water, depending on the thickness of the shape."
        }
      },
      {
        "@type": "Question",
        "name": "What is the best flour for homemade pasta?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "For traditional egg pasta, '00' (doppio zero) flour is preferred because it's finely milled. For extruded or eggless pasta, semolina flour (made from durum wheat) provides the best texture and structure."
        }
      },
      {
        "@type": "Question",
        "name": "Can I freeze fresh homemade pasta?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, you can freeze fresh pasta. Arrange the shapes in a single layer on a baking sheet to freeze, then transfer them to an airtight container or freezer bag for up to 2-3 months."
        }
      },
      {
        "@type": "Question",
        "name": "Why is my pasta dough tough?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Tough dough often results from insufficient resting or over-kneading. Resting the dough for at least 30 minutes allows the gluten to relax and the moisture to evenly hydrate the flour."
        }
      },
      {
        "@type": "Question",
        "name": "Do I need a pasta machine?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No, a pasta machine is helpful for consistent sheets but not strictly necessary. You can roll out dough by hand using a long rolling pin, though it requires more effort to achieve thin, even sheets."
        }
      }
    ]
  }
];

const mainEntityArray = schema[1].mainEntity;
---

<SiteLayout
  site="28grams"
  title="Homemade Pasta Guide"
  description="Complete pasta-making guide covering basic egg pasta dough, semolina pasta, gluten-free pasta, hand-rolling vs pasta machine, 8 shapes to make by hand, sauce pairings, drying and storing, and cooking fresh vs dried timing."
  canonical="https://28grams.vip/homemade-pasta-guide"
  schema={JSON.stringify(schema)}
>
  <style>
* { margin: 0; padding: 0; box-sizing: border-box; }
.page-wrapper {
  font-family: 'Inter', sans-serif;
  background: #0a060a;
  color: #e0d0d8;
  min-height: 100vh;
  --card-bg: #120c10;
  --border-color: #2a1820;
  --accent-color: #C2185B;
  --text-secondary: #888;
}

code, .mono { font-family: 'JetBrains Mono', monospace; }

.hero { text-align: center; padding: 48px 24px 24px; background: linear-gradient(180deg, #1a0a14 0%, #0a060a 100%); }
.hero h1 { font-size: 2.4rem; font-weight: 900; color: #fff; margin-bottom: 6px; }
.hero h1 span { background: linear-gradient(135deg, var(--accent-color), #ff6b9d); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
.hero p { color: #666; font-size: 0.95rem; max-width: 560px; margin: 0 auto; }
.main { max-width: 1000px; margin: 0 auto; padding: 32px 20px 40px; }

.formula-card, .guide-card {
  background: var(--card-bg);
  border: 2px solid var(--border-color);
  border-radius: 16px;
  overflow: hidden;
  margin-bottom: 32px;
}
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 20px;
  background: #150d12;
  border-bottom: 1px solid var(--border-color);
}
.card-header h2 { font-size: 1.2rem; font-weight: 700; color: #fff; margin: 0; }
.card-content { padding: 20px; }
.card-content p { color: #c8b8c0; line-height: 1.6; margin-bottom: 12px; }
.card-content ul { padding-left: 20px; margin-bottom: 12px; color: #c8b8c0; line-height: 1.6; }
.card-content li { margin-bottom: 6px; }

.content p { font-size: 0.9rem; color: #777; line-height: 1.8; margin-bottom: 14px; }

.recipe-section { margin-bottom: 40px; padding-bottom: 24px; border-bottom: 1px solid var(--border-color); }
.recipe-section:last-of-type { border-bottom: none; }
.recipe-header { display: flex; align-items: baseline; gap: 12px; margin-bottom: 16px; }
.recipe-header h3 { margin: 0; font-size: 1.3rem; color: var(--accent-color); }
.recipe-meta { font-size: 0.85rem; color: var(--text-secondary); background: #1a1015; padding: 4px 8px; border-radius: 4px; border: 1px solid var(--border-color); }

.recipe-info-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 16px;
    margin-bottom: 16px;
}
.recipe-info-card {
    background: #150d12;
    padding: 12px 16px;
    border-radius: 8px;
    border: 1px solid var(--border-color);
}
.recipe-info-label {
    font-size: 0.75rem;
    color: var(--text-secondary);
    text-transform: uppercase;
    font-weight: 600;
    margin-bottom: 4px;
}
.recipe-info-value {
    color: #e0d0d8;
    font-size: 0.95rem;
    line-height: 1.4;
}

.faq-list { margin-top: 24px; }
.faq-item { margin-bottom: 24px; }
.faq-q { font-weight: 700; color: #fff; margin-bottom: 8px; font-size: 1.05rem; }
.faq-a { color: #777; font-size: 0.95rem; line-height: 1.6; }

@media (max-width: 600px) {
  .hero h1 { font-size: 1.8rem; }
  .recipe-header { flex-direction: column; gap: 4px; }
}
  </style>

<div class="page-wrapper">
<div class="hero">
  <h1>Homemade Pasta <span>Guide</span> 🍝</h1>
  <p>Complete pasta-making guide covering basic egg pasta dough, semolina pasta, gluten-free pasta, hand-rolling vs pasta machine, 8 shapes to make by hand, sauce pairings, drying and storing, and cooking fresh vs dried timing.</p>
</div>

<div class="main">
  <h2 style="font-size: 1.8rem; font-weight: 800; color: #fff; margin: 40px 0 20px;">Dough Types</h2>

  <div class="formula-card">
    <div class="card-header">
      <h2>Basic Egg Pasta Dough</h2>
    </div>
    <div class="card-content">
      <p>The classic fresh pasta dough used in Northern Italy, perfect for ribbons and stuffed pastas.</p>
      <ul>
        <li><b>Ingredients:</b> '00' flour (or all-purpose), whole eggs, a pinch of salt, and a dash of olive oil.</li>
        <li><b>Ratio:</b> Typically 1 egg per 100g of flour.</li>
        <li><b>Method:</b> Mound flour, create a well, add eggs/oil/salt. Whisk eggs, gradually incorporating flour until a shaggy dough forms. Knead for 10 mins until smooth and elastic. Rest 30 mins wrapped in plastic before rolling.</li>
      </ul>
    </div>
  </div>

  <div class="formula-card">
    <div class="card-header">
      <h2>Semolina Pasta Dough</h2>
    </div>
    <div class="card-content">
      <p>A vegan, eggless dough common in Southern Italy, ideal for shaped pastas.</p>
      <ul>
        <li><b>Ingredients:</b> Semolina flour (durum wheat), warm water, salt.</li>
        <li><b>Ratio:</b> Roughly 2 parts semolina to 1 part water by weight.</li>
        <li><b>Method:</b> Mix semolina and water until a stiff dough forms. Knead aggressively until smooth. Rest for 30 minutes. This dough is firmer and holds complex shapes well.</li>
      </ul>
    </div>
  </div>

  <div class="formula-card">
    <div class="card-header">
      <h2>Gluten-Free Pasta Dough</h2>
    </div>
    <div class="card-content">
      <p>An alternative dough requiring binders to replace gluten structure.</p>
      <ul>
        <li><b>Ingredients:</b> Gluten-free flour blend (containing rice flour, tapioca, etc.), xanthan gum (if not in blend), eggs, olive oil, water.</li>
        <li><b>Method:</b> Mix dry ingredients. Add wet ingredients and knead until a cohesive dough forms. It may require slightly more moisture or oil than wheat dough. Keep covered, as it dries out quickly.</li>
      </ul>
    </div>
  </div>

  <h2 style="font-size: 1.8rem; font-weight: 800; color: #fff; margin: 40px 0 20px;">Rolling: Hand vs. Machine</h2>

  <div class="formula-card">
    <div class="card-header">
      <h2>Hand-Rolling (Mattarello)</h2>
    </div>
    <div class="card-content">
      <p>Traditional rolling uses a long wooden pin (mattarello). It creates a slightly rougher, more porous surface texture on the pasta (sfoglia), which grabs sauces exceptionally well. It requires practice, pressure, and rotating the dough frequently to maintain a circular shape and even thickness.</p>
    </div>
  </div>

  <div class="formula-card">
    <div class="card-header">
      <h2>Pasta Machine</h2>
    </div>
    <div class="card-content">
      <p>A mechanical roller (manual crank or electric attachment) ensures perfectly uniform thickness and is much faster. Dough is passed through progressively narrower settings. While efficient, the resulting pasta is smoother and slightly less porous than hand-rolled dough.</p>
    </div>
  </div>

  <h2 style="font-size: 1.8rem; font-weight: 800; color: #fff; margin: 40px 0 20px;">8 Shapes to Make by Hand</h2>

  <div class="recipe-section">
    <div class="recipe-header"><h3>1. Fettuccine</h3><span class="recipe-meta">Ribbon</span></div>
    <div class="recipe-info-grid">
      <div class="recipe-info-card"><div class="recipe-info-label">Dough</div><div class="recipe-info-value">Egg Pasta</div></div>
      <div class="recipe-info-card"><div class="recipe-info-label">Method</div><div class="recipe-info-value">Roll flat, fold or loosely roll, cut into 1/4-inch strips.</div></div>
      <div class="recipe-info-card"><div class="recipe-info-label">Pairing</div><div class="recipe-info-value">Cream sauces (Alfredo), rich meat ragù.</div></div>
    </div>
  </div>

  <div class="recipe-section">
    <div class="recipe-header"><h3>2. Pappardelle</h3><span class="recipe-meta">Wide Ribbon</span></div>
    <div class="recipe-info-grid">
      <div class="recipe-info-card"><div class="recipe-info-label">Dough</div><div class="recipe-info-value">Egg Pasta</div></div>
      <div class="recipe-info-card"><div class="recipe-info-label">Method</div><div class="recipe-info-value">Roll flat, cut into broad 3/4-inch to 1-inch strips.</div></div>
      <div class="recipe-info-card"><div class="recipe-info-label">Pairing</div><div class="recipe-info-value">Heavy, hearty meat sauces (wild boar, beef ragù).</div></div>
    </div>
  </div>

  <div class="recipe-section">
    <div class="recipe-header"><h3>3. Ravioli</h3><span class="recipe-meta">Stuffed Square</span></div>
    <div class="recipe-info-grid">
      <div class="recipe-info-card"><div class="recipe-info-label">Dough</div><div class="recipe-info-value">Egg Pasta</div></div>
      <div class="recipe-info-card"><div class="recipe-info-label">Method</div><div class="recipe-info-value">Place filling dots on sheet, cover with second sheet, press air out, cut.</div></div>
      <div class="recipe-info-card"><div class="recipe-info-label">Pairing</div><div class="recipe-info-value">Brown butter & sage, light tomato sauce, broth.</div></div>
    </div>
  </div>

  <div class="recipe-section">
    <div class="recipe-header"><h3>4. Tortellini</h3><span class="recipe-meta">Stuffed Ring</span></div>
    <div class="recipe-info-grid">
      <div class="recipe-info-card"><div class="recipe-info-label">Dough</div><div class="recipe-info-value">Egg Pasta</div></div>
      <div class="recipe-info-card"><div class="recipe-info-label">Method</div><div class="recipe-info-value">Cut circles/squares, add filling, fold into triangle/half-moon, wrap ends around finger.</div></div>
      <div class="recipe-info-card"><div class="recipe-info-label">Pairing</div><div class="recipe-info-value">Brodo (meat broth), cream sauces.</div></div>
    </div>
  </div>

  <div class="recipe-section">
    <div class="recipe-header"><h3>5. Orecchiette</h3><span class="recipe-meta">Little Ears</span></div>
    <div class="recipe-info-grid">
      <div class="recipe-info-card"><div class="recipe-info-label">Dough</div><div class="recipe-info-value">Semolina</div></div>
      <div class="recipe-info-card"><div class="recipe-info-label">Method</div><div class="recipe-info-value">Cut small nuggets, drag a butter knife over them to curl, invert over thumb.</div></div>
      <div class="recipe-info-card"><div class="recipe-info-label">Pairing</div><div class="recipe-info-value">Broccoli rabe and sausage, chunky vegetable sauces.</div></div>
    </div>
  </div>

  <div class="recipe-section">
    <div class="recipe-header"><h3>6. Cavatelli</h3><span class="recipe-meta">Hollow Shells</span></div>
    <div class="recipe-info-grid">
      <div class="recipe-info-card"><div class="recipe-info-label">Dough</div><div class="recipe-info-value">Semolina (or ricotta-based)</div></div>
      <div class="recipe-info-card"><div class="recipe-info-label">Method</div><div class="recipe-info-value">Roll dough into ropes, cut small pieces, press and drag with two fingers.</div></div>
      <div class="recipe-info-card"><div class="recipe-info-label">Pairing</div><div class="recipe-info-value">Garlic & oil, simple tomato sauces with meat or beans.</div></div>
    </div>
  </div>

  <div class="recipe-section">
    <div class="recipe-header"><h3>7. Gnocchi</h3><span class="recipe-meta">Dumplings</span></div>
    <div class="recipe-info-grid">
      <div class="recipe-info-card"><div class="recipe-info-label">Dough</div><div class="recipe-info-value">Potato/Ricotta & Flour</div></div>
      <div class="recipe-info-card"><div class="recipe-info-label">Method</div><div class="recipe-info-value">Mix riced potato with flour/egg, roll into ropes, cut into pillows, optionally roll on a fork for ridges.</div></div>
      <div class="recipe-info-card"><div class="recipe-info-label">Pairing</div><div class="recipe-info-value">Pesto, gorgonzola sauce, rich tomato sauces.</div></div>
    </div>
  </div>

  <div class="recipe-section">
    <div class="recipe-header"><h3>8. Garganelli</h3><span class="recipe-meta">Ridged Tubes</span></div>
    <div class="recipe-info-grid">
      <div class="recipe-info-card"><div class="recipe-info-label">Dough</div><div class="recipe-info-value">Egg Pasta</div></div>
      <div class="recipe-info-card"><div class="recipe-info-label">Method</div><div class="recipe-info-value">Cut small squares, wrap diagonally around a dowel, roll over a ridged board (pettine).</div></div>
      <div class="recipe-info-card"><div class="recipe-info-label">Pairing</div><div class="recipe-info-value">Prosciutto & peas, cream sauces, rich ragù.</div></div>
    </div>
  </div>

  <h2 style="font-size: 1.8rem; font-weight: 800; color: #fff; margin: 40px 0 20px;">Techniques & Tips</h2>

  <div class="formula-card">
    <div class="card-header">
      <h2>Drying & Storing Fresh Pasta</h2>
    </div>
    <div class="card-content">
      <p><b>Drying:</b> Dust heavily with semolina to prevent sticking. Ribbons can be hung on a rack or formed into loose "nests" and left to dry slightly for 15-30 minutes before cooking.</p>
      <p><b>Storing:</b> Fresh egg pasta can be stored in an airtight container in the fridge for 1-2 days. For longer storage, freeze it. Freeze shapes in a single layer on a tray, then transfer to a bag for up to 2-3 months. Cook straight from frozen; do not thaw.</p>
    </div>
  </div>

  <div class="formula-card">
    <div class="card-header">
      <h2>Cooking Fresh vs. Dried Timing</h2>
    </div>
    <div class="card-content">
      <p>Fresh pasta has high moisture content and cooks significantly faster than boxed dried pasta. While dried pasta may take 8-12 minutes, fresh egg pasta usually cooks in just 1 to 3 minutes once the water returns to a rolling boil. Stuffed pastas are ready shortly after they float to the surface.</p>
    </div>
  </div>

  <h2 style="font-size: 1.8rem; font-weight: 800; color: #fff; margin: 40px 0 20px;">Frequently Asked Questions</h2>
  <div class="faq-list">
    {mainEntityArray.map((faq) => (
      <div class="faq-item">
        <div class="faq-q">{faq.name}</div>
        <div class="faq-a">{faq.acceptedAnswer.text}</div>
      </div>
    ))}
  </div>
</div>
</div>
</SiteLayout>
