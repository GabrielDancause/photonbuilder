---
import SiteLayout from '../../../layouts/SiteLayout.astro';

export const meta = {
  title: "Recipe Scaling Calculator | Scale Recipes Instantly",
  description: "Scale any recipe up or down. Enter ingredients, set target servings, and get recalculated amounts instantly. Stop doing mental math while cooking.",
  category: "calculator",
  keywords: ["recipe scaler", "recipe multiplier", "recipe divider", "cooking calculator", "baking calculator", "scale recipe"]
};

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": meta.title,
    "description": meta.description,
    "author": { "@type": "Organization", "name": "28grams" },
    "publisher": { "@type": "Organization", "name": "28grams" },
    "datePublished": "2026-03-22",
    "dateModified": "2026-03-22"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How do you scale a recipe?",
        "acceptedAnswer": { "@type": "Answer", "text": "Divide your target servings by the original recipe servings. Multiply every ingredient by this number. For example, to make 6 servings from a 4-serving recipe, multiply every ingredient by 1.5." }
      },
      {
        "@type": "Question",
        "name": "Does baking time change when you double a recipe?",
        "acceptedAnswer": { "@type": "Answer", "text": "If you bake a doubled recipe in the same pan, it will be thicker and take longer. If you use two pans of the original size or a pan with the same surface area-to-volume ratio, the baking time will remain roughly the same." }
      },
      {
        "@type": "Question",
        "name": "Do spices scale linearly?",
        "acceptedAnswer": { "@type": "Answer", "text": "Not always. When doubling a recipe, start by multiplying spices and seasonings by 1.5 rather than 2, then taste and adjust. Strong spices can quickly overpower a dish when strictly doubled." }
      },
      {
        "@type": "Question",
        "name": "Can I double baking powder and baking soda?",
        "acceptedAnswer": { "@type": "Answer", "text": "For leavening agents like baking soda and baking powder, it's safer to multiply by 1.75 rather than 2 when doubling a recipe to prevent baked goods from rising too rapidly and collapsing." }
      },
      {
        "@type": "Question",
        "name": "How do I divide an egg for a half recipe?",
        "acceptedAnswer": { "@type": "Answer", "text": "Crack the egg into a bowl, whisk it until the yolk and white are combined, then measure out 1.5 to 2 tablespoons (or about 25 grams if using a scale) to get half an egg." }
      }
    ]
  }
];
---

<SiteLayout site="28grams" title={meta.title} description={meta.description} canonical="https://28grams.vip/recipe-scaler" schema={JSON.stringify(schema)}>
  <style is:global>
    /* ===== RECIPE SCALER ===== */
    :root {
      --accent: #C2185B;
      --accent-color: #C2185B;
      --border-color: #152040;
    }

    .mill-page { max-width: 1100px; margin: 0 auto; color: #e2e8f0; font-family: 'Inter', system-ui, sans-serif; }

    .mill-hero {
      text-align: center;
      padding: 3rem 1.5rem;
      background: linear-gradient(135deg, rgba(194,24,91,0.12) 0%, rgba(194,24,91,0.02) 60%, rgba(194,24,91,0.08) 100%);
      border-bottom: 1px solid var(--border-color);
      position: relative;
    }
    .mill-hero h1 { font-size: 2.5rem; font-weight: 800; margin-bottom: 0.5rem; color: #f8fafc; }
    .mill-hero-hook { font-size: 1.1rem; color: #cbd5e1; max-width: 600px; margin: 0 auto 1.5rem; }
    .mill-hero-hook strong { color: var(--accent-color); font-weight: 600; }

    .mill-section { padding: 3rem 1.5rem; border-bottom: 1px solid var(--border-color); }
    .mill-section-title { font-size: 1.8rem; font-weight: 700; color: #f8fafc; margin-bottom: 0.5rem; text-align: center; }
    .mill-section-sub { font-size: 1rem; color: #94a3b8; text-align: center; margin-bottom: 2rem; max-width: 600px; margin-left: auto; margin-right: auto; }

    .mill-calc-container { display: grid; grid-template-columns: 1fr; gap: 2rem; max-width: 900px; margin: 0 auto; }
    @media (min-width: 768px) {
      .mill-calc-container { grid-template-columns: 1fr 1fr; }
    }

    .mill-panel {
      background: rgba(15,23,42,0.6);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 1.5rem;
    }

    .mill-input-group { margin-bottom: 1.2rem; }
    .mill-input-group label { display: block; font-size: 0.85rem; font-weight: 600; color: #94a3b8; margin-bottom: 0.4rem; text-transform: uppercase; letter-spacing: 0.05em; }

    .mill-input, .mill-select, .mill-textarea {
      width: 100%;
      background: rgba(15,23,42,0.8);
      border: 1px solid var(--border-color);
      color: #f8fafc;
      padding: 0.8rem;
      border-radius: 6px;
      font-size: 1rem;
      font-family: inherit;
      transition: border-color 0.2s;
    }
    .mill-input:focus, .mill-select:focus, .mill-textarea:focus { outline: none; border-color: var(--accent-color); }

    .mill-textarea { min-height: 200px; resize: vertical; font-family: 'JetBrains Mono', monospace; font-size: 0.9rem; line-height: 1.5; }

    .mill-row { display: flex; gap: 1rem; }
    .mill-row > * { flex: 1; }

    .mill-quick-actions { display: flex; gap: 0.5rem; margin-top: 0.5rem; flex-wrap: wrap; }
    .mill-btn-small {
      background: rgba(15,23,42,0.8);
      border: 1px solid var(--border-color);
      color: #cbd5e1;
      padding: 0.4rem 0.8rem;
      border-radius: 4px;
      font-size: 0.8rem;
      cursor: pointer;
      transition: all 0.2s;
    }
    .mill-btn-small:hover { background: rgba(194,24,91,0.2); border-color: var(--accent-color); color: #fff; }

    .mill-btn {
      width: 100%;
      background: var(--accent-color);
      color: #fff;
      border: none;
      padding: 1rem;
      font-size: 1rem;
      font-weight: 600;
      border-radius: 6px;
      cursor: pointer;
      transition: background 0.2s;
      margin-top: 1rem;
    }
    .mill-btn:hover { background: #ad1450; }

    .mill-results-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 1rem;
      padding-bottom: 0.5rem;
      border-bottom: 1px solid var(--border-color);
    }
    .mill-results-title { font-size: 1.2rem; font-weight: 600; color: var(--accent-color); }

    .mill-recipe-output {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.95rem;
      line-height: 1.8;
      color: #e2e8f0;
      white-space: pre-wrap;
      background: rgba(10,15,28,0.5);
      padding: 1rem;
      border-radius: 6px;
      border: 1px dashed var(--border-color);
    }

    .mill-badge { display: inline-block; padding: 0.2rem 0.5rem; background: rgba(194,24,91,0.2); color: var(--accent-color); border-radius: 4px; font-size: 0.75rem; font-weight: 600; margin-left: 0.5rem; vertical-align: middle; }

    .mill-info-box {
      margin-top: 1.5rem;
      padding: 1rem;
      background: rgba(30,41,59,0.4);
      border-left: 4px solid var(--accent-color);
      border-radius: 0 6px 6px 0;
      font-size: 0.9rem;
      color: #cbd5e1;
    }

    .mill-info-box h4 { color: #f8fafc; margin-bottom: 0.5rem; font-size: 0.95rem; }
    .mill-info-box p { margin-bottom: 0.5rem; }
    .mill-info-box p:last-child { margin-bottom: 0; }

    /* Print Styles */
    @media print {
      body { background: #fff !important; color: #000 !important; }
      .mill-hero, .mill-calc-inputs, .mill-info-box, .mill-quick-actions, .site-header, .site-footer { display: none !important; }
      .mill-section { border: none !important; padding: 0 !important; }
      .mill-calc-container { display: block !important; }
      .mill-panel { border: none !important; background: transparent !important; padding: 0 !important; }
      .mill-recipe-output { color: #000 !important; background: transparent !important; border: none !important; }
      .mill-results-title { color: #000 !important; }
    }
  </style>

  <div class="mill-page">
    <section class="mill-hero">
      <h1>Recipe Scaling Calculator</h1>
      <p class="mill-hero-hook">Stop doing mental math while cooking. <strong>Scale any recipe instantly</strong> with precise conversions.</p>
    </section>

    <section class="mill-section">
      <div class="mill-calc-container">

        <!-- INPUT PANEL -->
        <div class="mill-panel mill-calc-inputs">
          <div class="mill-input-group">
            <label for="preset-recipe">Load Example Recipe (Optional)</label>
            <select id="preset-recipe" class="mill-select">
              <option value="">-- Select a recipe --</option>
              <option value="cookies">Classic Chocolate Chip Cookies</option>
              <option value="sourdough">Basic Sourdough Bread</option>
              <option value="pancakes">Fluffy Pancakes</option>
            </select>
          </div>

          <div class="mill-row">
            <div class="mill-input-group">
              <label for="orig-servings">Original Servings</label>
              <input type="number" id="orig-servings" class="mill-input" value="4" min="0.1" step="0.1" />
            </div>
            <div class="mill-input-group">
              <label for="target-servings">Target Servings</label>
              <input type="number" id="target-servings" class="mill-input" value="6" min="0.1" step="0.1" />
            </div>
          </div>

          <div class="mill-input-group">
            <label>Quick Scale</label>
            <div class="mill-quick-actions">
              <button class="mill-btn-small" data-scale="0.5">Half (0.5x)</button>
              <button class="mill-btn-small" data-scale="1">Original (1x)</button>
              <button class="mill-btn-small" data-scale="2">Double (2x)</button>
              <button class="mill-btn-small" data-scale="3">Triple (3x)</button>
            </div>
          </div>

          <div class="mill-input-group">
            <label for="recipe-input">Ingredients (Paste recipe here)</label>
            <textarea id="recipe-input" class="mill-textarea" placeholder="Paste ingredients here, one per line.&#10;Example:&#10;2 cups flour&#10;1 1/2 tsp baking soda&#10;0.5 cup butter&#10;3 eggs"></textarea>
          </div>

          <div class="mill-row" style="margin-bottom: 1rem;">
            <div class="mill-input-group" style="margin-bottom:0; display:flex; align-items:center; gap:0.5rem;">
              <input type="checkbox" id="convert-metric" style="width:16px; height:16px; accent-color:var(--accent-color);" />
              <label for="convert-metric" style="margin-bottom:0; text-transform:none; letter-spacing:0; cursor:pointer;">Convert to Metric (g/ml)</label>
            </div>
          </div>

          <button id="calc-btn" class="mill-btn">Scale Recipe</button>
        </div>

        <!-- RESULTS PANEL -->
        <div class="mill-panel">
          <div class="mill-results-header">
            <div class="mill-results-title">Scaled Recipe <span id="multiplier-badge" class="mill-badge">1.5x</span></div>
            <div class="mill-quick-actions" style="margin-top:0;">
              <button id="copy-btn" class="mill-btn-small">Copy</button>
              <button id="print-btn" class="mill-btn-small">Print</button>
            </div>
          </div>

          <div id="recipe-output" class="mill-recipe-output">Waiting for input...</div>

          <div id="smart-tips" class="mill-info-box" style="display:none;">
            <h4>👨‍🍳 Smart Adjustments</h4>
            <div id="substitutions-text"></div>
            <div id="cooking-time-text"></div>
          </div>
        </div>

      </div>
    </section>
  </div>

  <script is:inline>
    // PRESET RECIPES
    const presets = {
      cookies: {
        servings: 24,
        ingredients: "2.25 cups all-purpose flour\n1 tsp baking soda\n1 tsp salt\n1 cup butter, softened\n0.75 cup granulated sugar\n0.75 cup brown sugar\n1 tsp vanilla extract\n2 large eggs\n2 cups chocolate chips"
      },
      sourdough: {
        servings: 1,
        ingredients: "500 g bread flour\n350 g water\n100 g active sourdough starter\n10 g salt"
      },
      pancakes: {
        servings: 4,
        ingredients: "1.5 cups all-purpose flour\n3.5 tsp baking powder\n1 tsp salt\n1 tbsp white sugar\n1.25 cups milk\n1 egg\n3 tbsp butter, melted"
      }
    };

    // UNIT CONVERSIONS (approximate standard weights for 1 cup)
    const densityMap = {
      'flour': 120, 'sugar': 200, 'brown sugar': 220, 'butter': 227, 'milk': 240, 'water': 240, 'oil': 216, 'honey': 340, 'cocoa': 100
    };

    const volToMl = {
      'tsp': 4.92, 'teaspoon': 4.92, 'tbsp': 14.78, 'tablespoon': 14.78, 'cup': 236.58, 'oz': 29.57, 'fluid ounce': 29.57, 'pint': 473.17, 'quart': 946.35, 'gallon': 3785.41
    };

    // DOM Elements
    const presetSelect = document.getElementById('preset-recipe');
    const origServingsInput = document.getElementById('orig-servings');
    const targetServingsInput = document.getElementById('target-servings');
    const recipeInput = document.getElementById('recipe-input');
    const calcBtn = document.getElementById('calc-btn');
    const copyBtn = document.getElementById('copy-btn');
    const printBtn = document.getElementById('print-btn');
    const recipeOutput = document.getElementById('recipe-output');
    const multiplierBadge = document.getElementById('multiplier-badge');
    const convertMetricCheck = document.getElementById('convert-metric');
    const smartTips = document.getElementById('smart-tips');
    const subsText = document.getElementById('substitutions-text');
    const timeText = document.getElementById('cooking-time-text');

    // Load preset
    presetSelect.addEventListener('change', (e) => {
      const val = e.target.value;
      if (val && presets[val]) {
        origServingsInput.value = presets[val].servings;
        recipeInput.value = presets[val].ingredients;
        scaleRecipe();
      }
    });

    // Quick scale buttons
    document.querySelectorAll('.mill-btn-small[data-scale]').forEach(btn => {
      btn.addEventListener('click', (e) => {
        const scale = parseFloat(e.target.getAttribute('data-scale'));
        const orig = parseFloat(origServingsInput.value) || 1;
        targetServingsInput.value = +(orig * scale).toFixed(1);
        scaleRecipe();
      });
    });

    // Main calculation
    calcBtn.addEventListener('click', scaleRecipe);
    convertMetricCheck.addEventListener('change', scaleRecipe);

    // Parse fraction string to decimal
    function parseFraction(str) {
      if (!str) return 0;
      const parts = str.trim().split(/\s+/);
      let total = 0;
      for (const p of parts) {
        if (p.includes('/')) {
          const [num, den] = p.split('/');
          total += parseFloat(num) / parseFloat(den);
        } else {
          total += parseFloat(p);
        }
      }
      return total;
    }

    // Convert decimal to nice fraction string
    function toFraction(dec) {
      if (convertMetricCheck.checked) return dec.toFixed(1).replace(/\.0$/, '');
      if (dec === 0) return "0";
      const whole = Math.floor(dec);
      const frac = dec - whole;
      let fStr = "";

      const tolerance = 0.05;
      if (Math.abs(frac - 0) < tolerance) fStr = "";
      else if (Math.abs(frac - 0.125) < tolerance) fStr = "1/8";
      else if (Math.abs(frac - 0.25) < tolerance) fStr = "1/4";
      else if (Math.abs(frac - 0.333) < tolerance) fStr = "1/3";
      else if (Math.abs(frac - 0.375) < tolerance) fStr = "3/8";
      else if (Math.abs(frac - 0.5) < tolerance) fStr = "1/2";
      else if (Math.abs(frac - 0.625) < tolerance) fStr = "5/8";
      else if (Math.abs(frac - 0.666) < tolerance) fStr = "2/3";
      else if (Math.abs(frac - 0.75) < tolerance) fStr = "3/4";
      else if (Math.abs(frac - 0.875) < tolerance) fStr = "7/8";
      else fStr = frac.toFixed(2).replace(/\.00$/, ''); // fallback

      if (whole > 0 && fStr) return `${whole} ${fStr}`;
      if (whole > 0) return whole.toString();
      if (fStr) return fStr;
      return dec.toFixed(2);
    }

    // Smart tips logic
    function analyzeRecipe(text, multiplier) {
      let hasLeavener = /baking (soda|powder)|yeast/i.test(text);
      let hasSpices = /cinnamon|nutmeg|cumin|chili powder|cayenne|cloves|paprika/i.test(text);
      let tipsShow = false;

      subsText.innerHTML = '';
      timeText.innerHTML = '';

      if (multiplier > 1.5) {
        let alerts = [];
        if (hasLeavener) alerts.push("<strong>Baking Leaveners:</strong> When doubling+ baking recipes, consider scaling baking soda/powder by 1.75x instead of 2x to prevent over-rising.");
        if (hasSpices) alerts.push("<strong>Spices:</strong> Strong spices don't scale linearly. Start with 1.5x the spice amount, taste, and adjust.");

        if (alerts.length > 0) {
          subsText.innerHTML = '<p>' + alerts.join('</p><p>') + '</p>';
          tipsShow = true;
        }

        timeText.innerHTML = "<p><strong>Cooking Time:</strong> Larger volumes take longer to cook. A doubled recipe might need 20-30% more cooking time. If baking, consider splitting into two pans to keep time the same.</p>";
        tipsShow = true;
      }

      if (multiplier < 1) {
        subsText.innerHTML = "<p><strong>Dividing Eggs:</strong> If scaling results in a fraction of an egg, whisk a whole egg and measure out roughly 1.5 to 2 tablespoons (approx 25g) for 'half an egg'.</p>";
        tipsShow = true;
      }

      smartTips.style.display = tipsShow ? 'block' : 'none';
    }

    function scaleRecipe() {
      const orig = parseFloat(origServingsInput.value);
      const target = parseFloat(targetServingsInput.value);

      if (!orig || !target || orig <= 0 || target <= 0) {
        recipeOutput.textContent = "Please enter valid original and target servings.";
        return;
      }

      const multiplier = target / orig;
      multiplierBadge.textContent = multiplier.toFixed(2).replace(/\.00$/, '') + 'x';

      const text = recipeInput.value;
      if (!text.trim()) {
        recipeOutput.textContent = "Please paste ingredients first.";
        return;
      }

      analyzeRecipe(text, multiplier);
      const lines = text.split('\n');
      let result = [];

      // Regex to find leading numbers/fractions
      const numRegex = /^([\d\s\.\/]+)(.*)$/;

      for (let line of lines) {
        line = line.trim();
        if (!line) continue;

        const match = line.match(numRegex);
        if (match) {
          const numStr = match[1].trim();
          let rest = match[2];
          const val = parseFraction(numStr);

          if (val > 0) {
            let scaledVal = val * multiplier;
            let finalOutput = '';

            // Optional Metric Conversion Magic
            if (convertMetricCheck.checked) {
              let converted = false;
              const lRest = rest.toLowerCase();

              // Try Volume to ML
              for (const [unit, ml] of Object.entries(volToMl)) {
                const regex = new RegExp(`^\\s*(${unit}s?)\\b`, 'i');
                if (regex.test(lRest)) {
                  let mlVal = scaledVal * ml;

                  // If it's cups, maybe we should convert to grams instead of ml?
                  if (unit.startsWith('cup')) {
                     for (const [ing, gPerCup] of Object.entries(densityMap)) {
                       if (lRest.includes(ing)) {
                         finalOutput = `${Math.round(scaledVal * gPerCup)} g ` + rest.replace(regex, '').trim();
                         converted = true;
                         break;
                       }
                     }
                  }

                  if (!converted) {
                    finalOutput = `${Math.round(mlVal)} ml ` + rest.replace(regex, '').trim();
                    converted = true;
                  }
                  break;
                }
              }

              // Handle oz to g roughly
              if (!converted) {
                const ozRegex = /^\s*(oz|ounces?)\b/i;
                if (ozRegex.test(lRest)) {
                  finalOutput = `${Math.round(scaledVal * 28.35)} g ` + rest.replace(ozRegex, '').trim();
                  converted = true;
                }
              }

              if (!converted) {
                // Handle lbs to g roughly
                const lbRegex = /^\s*(lbs?|pounds?)\b/i;
                if (lbRegex.test(lRest)) {
                  finalOutput = `${Math.round(scaledVal * 453.59)} g ` + rest.replace(lbRegex, '').trim();
                  converted = true;
                }
              }

              if (!converted) {
                 finalOutput = `${toFraction(scaledVal)} ${rest}`;
              }

            } else {
              finalOutput = `${toFraction(scaledVal)} ${rest}`;
            }

            result.push(finalOutput);
          } else {
            result.push(line);
          }
        } else {
          // No leading number found, keep as is
          result.push(line);
        }
      }

      recipeOutput.textContent = result.join('\n');
    }

    // Copy to clipboard
    copyBtn.addEventListener('click', () => {
      navigator.clipboard.writeText(recipeOutput.textContent).then(() => {
        const origText = copyBtn.textContent;
        copyBtn.textContent = 'Copied!';
        setTimeout(() => copyBtn.textContent = origText, 2000);
      });
    });

    // Print
    printBtn.addEventListener('click', () => {
      window.print();
    });

  </script>
</SiteLayout>
