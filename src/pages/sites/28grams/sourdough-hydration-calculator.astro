<script is:inline>
var mode = 'forward';

var presets = {
  sourdough: { flour: 500, water: 325, starter: 100, starterHyd: 100, salt: 10, name: 'Classic Sourdough' },
  ciabatta:  { flour: 500, water: 400, starter: 100, starterHyd: 100, salt: 10, name: 'Ciabatta' },
  pizza:     { flour: 500, water: 275, starter: 100, starterHyd: 100, salt: 10, name: 'Pizza Dough' },
  focaccia:  { flour: 500, water: 350, starter: 100, starterHyd: 100, salt: 10, name: 'Focaccia' },
  bagels:    { flour: 500, water: 210, starter: 100, starterHyd: 100, salt: 10, name: 'Bagels' }
};

function $(id) { return document.getElementById(id); }

function setMode(m) {
  mode = m;
  $('forwardBtn').classList.toggle('active', m === 'forward');
  $('reverseBtn').classList.toggle('active', m === 'reverse');
  $('forwardSection').classList.toggle('hidden', m === 'reverse');
  $('reverseSection').classList.toggle('active', m === 'reverse');
  calculate();
}

function loadPreset(key) {
  var p = presets[key];
  document.querySelectorAll('.preset-btn').forEach(function(b) { b.classList.remove('active'); });
  event.target.classList.add('active');

  if (mode === 'forward') {
    $('flourInput').value = p.flour;
    $('waterInput').value = p.water;
    $('starterInput').value = p.starter;
    $('starterHydInput').value = p.starterHyd;
    $('saltInput').value = p.salt;
  } else {
    var totalFlour = p.flour + getStarterFlour(p.starter, p.starterHyd);
    var totalWater = p.water + getStarterWater(p.starter, p.starterHyd);
    var hyd = totalFlour > 0 ? (totalWater / totalFlour) * 100 : 0;
    $('targetHydInput').value = round(hyd);
    $('revFlourInput').value = p.flour;
    $('revStarterInput').value = p.starter;
    $('revStarterHydInput').value = p.starterHyd;
    $('revSaltInput').value = p.salt;
  }
  calculate();
}

function getStarterFlour(starterW, starterHyd) {
  if (starterHyd <= 0) return starterW;
  return starterW / (1 + starterHyd / 100);
}

function getStarterWater(starterW, starterHyd) {
  if (starterHyd <= 0) return 0;
  return starterW - getStarterFlour(starterW, starterHyd);
}

function round(v) { return Math.round(v * 10) / 10; }

function getHydrationColor(hyd) {
  if (hyd < 55) return '#3b82f6';
  if (hyd < 63) return '#06b6d4';
  if (hyd < 70) return '#22c55e';
  if (hyd < 76) return '#84cc16';
  if (hyd < 82) return '#eab308';
  if (hyd < 90) return '#f97316';
  return '#ef4444';
}

function getHydrationDesc(hyd) {
  if (hyd < 55) return 'Very stiff dough — bagels, pretzels, pasta';
  if (hyd < 63) return 'Stiff dough — sandwich bread, rolls';
  if (hyd < 68) return 'Medium dough — pizza, country loaves';
  if (hyd < 76) return 'Standard bread — good balance of structure and openness';
  if (hyd < 82) return 'High hydration — open crumb, focaccia, rustic loaves';
  if (hyd < 90) return 'Very high — ciabatta, pan de cristal';
  return 'Extreme hydration — batter-like, requires a tin or pan';
}

function calculate() {
  var flour, water, starter, starterHyd, salt;

  if (mode === 'forward') {
    flour = parseFloat($('flourInput').value) || 0;
    water = parseFloat($('waterInput').value) || 0;
    starter = parseFloat($('starterInput').value) || 0;
    starterHyd = parseFloat($('starterHydInput').value) || 0;
    salt = parseFloat($('saltInput').value) || 0;
  } else {
    var targetHyd = parseFloat($('targetHydInput').value) || 0;
    flour = parseFloat($('revFlourInput').value) || 0;
    starter = parseFloat($('revStarterInput').value) || 0;
    starterHyd = parseFloat($('revStarterHydInput').value) || 0;
    salt = parseFloat($('revSaltInput').value) || 0;

    var sFlour = getStarterFlour(starter, starterHyd);
    var sWater = getStarterWater(starter, starterHyd);
    var totalFlour = flour + sFlour;
    var neededTotalWater = (targetHyd / 100) * totalFlour;
    water = Math.max(0, neededTotalWater - sWater);
    $('revWaterOutput').value = round(water);
  }

  var sFlour = getStarterFlour(starter, starterHyd);
  var sWater = getStarterWater(starter, starterHyd);
  var totalFlour = flour + sFlour;
  var totalWater = water + sWater;
  var totalDough = flour + water + starter + salt;
  var hydration = totalFlour > 0 ? (totalWater / totalFlour) * 100 : 0;

  // Update gauge
  var clampedHyd = Math.min(Math.max(hydration, 0), 100);
  var barWidth = Math.max(2, (clampedHyd / 100) * 100);
  var color = getHydrationColor(hydration);
  $('gaugeValue').textContent = round(hydration) + '%';
  $('gaugeBar').style.width = barWidth + '%';
  $('gaugeBar').style.background = 'linear-gradient(90deg, ' + color + ', ' + color + 'cc)';
  $('gaugeDesc').textContent = getHydrationDesc(hydration);

  // Update results table
  var bp = function(w) { return totalFlour > 0 ? round((w / totalFlour) * 100) : 0; };
  var rows = '';
  rows += '<tr><td>Flour</td><td>' + round(flour) + 'g</td><td>' + bp(flour) + '%</td></tr>';
  rows += '<tr><td>Water (added)</td><td>' + round(water) + 'g</td><td>' + bp(water) + '%</td></tr>';
  rows += '<tr><td>Starter</td><td>' + round(starter) + 'g</td><td>' + bp(starter) + '%</td></tr>';
  rows += '<tr><td style="padding-left:28px;color:#888;font-size:0.8rem;">↳ flour in starter</td><td style="color:#888;font-size:0.8rem;">' + round(sFlour) + 'g</td><td style="font-size:0.8rem;">' + bp(sFlour) + '%</td></tr>';
  rows += '<tr><td style="padding-left:28px;color:#888;font-size:0.8rem;">↳ water in starter</td><td style="color:#888;font-size:0.8rem;">' + round(sWater) + 'g</td><td style="font-size:0.8rem;">' + bp(sWater) + '%</td></tr>';
  rows += '<tr><td>Salt</td><td>' + round(salt) + 'g</td><td>' + bp(salt) + '%</td></tr>';
  rows += '<tr class="total-row"><td>Total Flour</td><td>' + round(totalFlour) + 'g</td><td>100%</td></tr>';
  rows += '<tr class="total-row"><td>Total Water</td><td>' + round(totalWater) + 'g</td><td>' + round(hydration) + '%</td></tr>';
  rows += '<tr class="total-row"><td>Total Dough</td><td>' + round(totalDough) + 'g</td><td>' + bp(totalDough) + '%</td></tr>';
  $('resultsBody').innerHTML = rows;
}

// Attach listeners to all inputs
['flourInput','waterInput','starterInput','starterHydInput','saltInput',
 'targetHydInput','revFlourInput','revStarterInput','revStarterHydInput','revSaltInput'].forEach(function(id) {
  $(id).addEventListener('input', function() {
    document.querySelectorAll('.preset-btn').forEach(function(b) { b.classList.remove('active'); });
    calculate();
  });
});

// Init
calculate();
</script>

