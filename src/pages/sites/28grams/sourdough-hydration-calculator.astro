---
import SiteLayout from '../../../layouts/SiteLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Sourdough Hydration Calculator",
  "url": "https://28grams.vip/sourdough-hydration-calculator",
  "description": "Calculate dough hydration percentage from flour, water, starter, and salt weights. Reverse mode, preset recipes, and visual hydration gauge.",
  "applicationCategory": "UtilitiesApplication",
  "operatingSystem": "Any",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  },
  "author": {
    "@type": "Organization",
    "name": "GAB Ventures",
    "url": "https://gab.ae"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is dough hydration percentage?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Dough hydration percentage is the ratio of total water weight to total flour weight in a bread recipe, expressed as a percentage. For example, if you use 750g of water and 1000g of flour, your hydration is 75%. This includes water contributed by the sourdough starter."
      }
    },
    {
      "@type": "Question",
      "name": "How do I calculate hydration with a sourdough starter?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A sourdough starter is a mix of flour and water. A 100% hydration starter is equal parts flour and water by weight. To calculate total hydration, split the starter into its flour and water components: a 200g starter at 100% hydration contributes 100g flour and 100g water. Add those to your recipe's flour and water totals, then divide total water by total flour."
      }
    },
    {
      "@type": "Question",
      "name": "What hydration is best for sourdough bread?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most sourdough bread recipes use 70–78% hydration. Beginners should start around 70–72% for easier handling. As you gain experience with wet doughs, you can move toward 75–78% for a more open crumb. Higher hydrations (80%+) produce artisan-style loaves with large irregular holes but require strong shaping skills."
      }
    },
    {
      "@type": "Question",
      "name": "What is the difference between 65% and 85% hydration dough?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A 65% hydration dough is stiff and easy to shape — ideal for bagels, pizza, and sandwich bread. An 85% hydration dough is very wet, sticky, and slack — it produces ciabatta-style bread with large, irregular air pockets and a thin, crispy crust. Higher hydration doughs require stretch-and-fold techniques rather than traditional kneading."
      }
    },
    {
      "@type": "Question",
      "name": "Does starter hydration matter for the final dough?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Starter hydration changes how much flour vs. water it contributes. A 100% hydration starter is 50/50 flour and water. A stiff starter at 60% hydration contributes more flour and less water, lowering your overall dough hydration. Always account for starter hydration when calculating your final dough hydration."
      }
    },
    {
      "@type": "Question",
      "name": "How do I adjust hydration for whole wheat or rye flour?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Whole wheat and rye flours absorb significantly more water than white bread flour due to higher bran and fiber content. When substituting whole grain flours, increase hydration by 5–10% to achieve a similar dough consistency. For example, if a white flour recipe calls for 72% hydration, use 77–82% hydration with whole wheat."
      }
    }
  ]
};

export const meta = {
  title: "Sourdough Hydration Calculator — Dough Hydration % | Free Tool",
  description: "Calculate bread dough hydration percentage from flour, water, starter, and salt. Includes reverse mode, preset recipes, visual gauge, and pizza dough hydration calculator.",
  category: "tool",
  published: "2026-03-21",
};
