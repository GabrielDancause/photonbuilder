.main { max-width: 1000px; margin: 0 auto; padding: 32px 20px 40px; }

/* Chart Card */
.chart-card {
  background: var(--card-bg);
  border: 1px solid var(--border-color);
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 10px 30px rgba(0,0,0,0.5);
