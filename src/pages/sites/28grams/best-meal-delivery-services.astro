}
.chart-header {
  padding: 20px 24px;
  border-bottom: 1px solid var(--border-color);
  background: #150e12;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.chart-header h2 { font-size: 1.1rem; color: #fff; font-weight: 700; }
.chart-header p { font-size: 0.8rem; color: var(--text-secondary); margin-top: 4px; }
.table-container { overflow-x: auto; }
.compare-table {
