  <script is:inline>
    const headers = document.querySelectorAll('th[data-sort]');
    const rows = document.querySelectorAll('.brand-row');
    const tableBody = document.getElementById('tableBody');

    // Sort logic
    headers.forEach(header => {
      header.addEventListener('click', () => {
        const sortType = header.getAttribute('data-sort');
        const isAsc = !header.classList.contains('asc');

        headers.forEach(h => { h.classList.remove('asc', 'desc'); });
        header.classList.add(isAsc ? 'asc' : 'desc');

        const rowsArray = Array.from(rows);

        rowsArray.sort((a, b) => {
          let aVal, bVal;

          if (sortType === 'brand') {
            aVal = a.children[0].innerText.toLowerCase();
            bVal = b.children[0].innerText.toLowerCase();
          } else if (sortType === 'price') {
            aVal = parseFloat(a.children[1].innerText.replace('$', '').replace('+', ''));
            bVal = parseFloat(b.children[1].innerText.replace('$', '').replace('+', ''));
          } else if (sortType === 'time') {
            aVal = parseInt(a.children[2].innerText.split('-')[0].split(' ')[0]) || 0;
            bVal = parseInt(b.children[2].innerText.split('-')[0].split(' ')[0]) || 0;
          } else if (sortType === 'variety') {
            aVal = parseInt(a.children[3].innerText.split('+')[0]) || 0;
            bVal = parseInt(b.children[3].innerText.split('+')[0]) || 0;
          } else if (sortType === 'diet') {
            aVal = a.children[4].innerText.toLowerCase();
            bVal = b.children[4].innerText.toLowerCase();
          } else if (sortType === 'flex') {
            const flexMap = { 'medium': 1, 'high': 2, 'very high': 3 };
            aVal = flexMap[a.children[5].innerText.toLowerCase()] || 0;
            bVal = flexMap[b.children[5].innerText.toLowerCase()] || 0;
          }

          if (aVal < bVal) return isAsc ? -1 : 1;
          if (aVal > bVal) return isAsc ? 1 : -1;
          return 0;
        });

        rowsArray.forEach(row => tableBody.appendChild(row));
      });
    });
  </script>


