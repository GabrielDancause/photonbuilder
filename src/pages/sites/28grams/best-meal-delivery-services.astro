}
.compare-table th {
  text-align: left;
  font-size: 0.75rem;
  color: var(--text-secondary);
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  padding: 12px 16px;
  background: #1a1015;
  border-bottom: 2px solid var(--border-color);
