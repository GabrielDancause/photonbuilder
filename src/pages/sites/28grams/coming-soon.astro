---
import SiteLayout from '../../../layouts/SiteLayout.astro';
export const meta = { title: 'Coming Soon — Content Roadmap', description: 'See what tools, guides, and research are coming next to 28 Grams.', category: 'guides', published: '2026-03-15' };

const SITE_ID = '28grams';

const allPages = import.meta.glob('./*.astro', { eager: true });
const publishedCount = Object.keys(allPages).filter(k => !k.includes('index') && !k.includes('coming-soon')).length;

const categories = [
  {
    icon: '👨‍🍳',
    title: 'Recipes',
    description: 'Recipes, cooking techniques, and meal ideas',
    total: 15,
    items: [
      { name: 'Recipe Generator', searches: '5,700', status: 'building', href: '' },
      { name: 'Recipe Finder By Ingredients', searches: '1,700', status: 'building', href: '' },
      { name: 'Recipe Finder', searches: '1,600', status: 'building', href: '' },
      { name: 'Sourdough Bread Recipe', searches: '—', status: 'published', href: '/28grams/sourdough-bread-recipe' },
      { name: 'Recipe Scaler', searches: '—', status: 'published', href: '/28grams/recipe-scaler' },
      { name: 'Cooking Timer', searches: '—', status: 'published', href: '/28grams/cooking-timer' },
      { name: 'Cooking Oil Comparison', searches: '—', status: 'published', href: '/28grams/cooking-oil-comparison' },
      { name: 'Bakers Percentage', searches: '—', status: 'published', href: '/28grams/bakers-percentage' }
    ]
  },
  {
    icon: '⚖️',
    title: 'Kitchen Tools',
    description: 'Measurement converters, cooking calculators, and timers',
    total: 8,
    items: [
      { name: 'Fiber Calculator', searches: '2,200', status: 'building', href: '' },
      { name: 'Yeast Converter', searches: '—', status: 'published', href: '/28grams/yeast-converter' },
      { name: 'Oven Converter', searches: '—', status: 'published', href: '/28grams/oven-converter' },
      { name: 'Sourdough Calculator', searches: '—', status: 'published', href: '/28grams/sourdough-calculator' },
      { name: 'Abv Calculator', searches: '—', status: 'published', href: '/28grams/abv-calculator' },
      { name: 'Smoking Calculator', searches: '—', status: 'published', href: '/28grams/smoking-calculator' },
      { name: 'Baking Converter', searches: '—', status: 'published', href: '/28grams/baking-converter' },
      { name: 'Fermentation Timer', searches: '—', status: 'published', href: '/28grams/fermentation-timer' }
    ]
  },
  {
    icon: '🥗',
    title: 'Nutrition & Calories',
    description: 'Calorie counts, nutrition facts, and diet tools',
    total: 14,
    items: [
      { name: 'Carnivore Diet Food List', searches: '17,000', status: 'building', href: '' },
      { name: 'Mediterranean Diet Food List', searches: '15,000', status: 'building', href: '' },
      { name: 'Keto Food List', searches: '8,800', status: 'building', href: '' },
      { name: 'Protein Foods List', searches: '7,700', status: 'building', href: '' },
      { name: 'Keto Diet Food List', searches: '6,200', status: 'building', href: '' },
      { name: 'Aip Diet Food List', searches: '4,300', status: 'building', href: '' },
      { name: 'Keto Food List For Beginners', searches: '3,700', status: 'building', href: '' },
      { name: '14-Day No Sugar Diet Food List', searches: '3,300', status: 'building', href: '' }
    ]
  },
  {
    icon: '🍽️',
    title: 'Food Guides',
    description: 'Food guides, restaurant reviews, and cooking tips',
    total: 66,
    items: [
      { name: 'Iron Rich Foods List', searches: '13,000', status: 'building', href: '' },
      { name: 'Ikea Kitchen Planner', searches: '10,000', status: 'building', href: '' },
      { name: 'High Fiber Foods List', searches: '9,800', status: 'building', href: '' },
      { name: 'Thanksgiving Food List', searches: '7,000', status: 'building', href: '' },
      { name: 'Meal Planner', searches: '5,600', status: 'building', href: '' },
      { name: 'Low Histamine Food List', searches: '4,700', status: 'building', href: '' },
      { name: 'Whole 30 Food List', searches: '3,500', status: 'building', href: '' },
      { name: 'Weekly Meal Planner', searches: '3,300', status: 'building', href: '' }
    ]
  }
];
---
<SiteLayout title={meta.title} description={meta.description} site={SITE_ID}>
  <style is:inline>
    .coming-soon-hero { text-align: center; padding: 3rem 1rem 2rem; max-width: 800px; margin: 0 auto; }
    .coming-soon-hero h1 { font-size: 2.2rem; margin-bottom: 0.5rem; background: linear-gradient(135deg, var(--accent), #a78bfa); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .coming-soon-hero p { color: var(--text-secondary); font-size: 1.1rem; line-height: 1.6; }
    .stats-bar { display: flex; justify-content: center; gap: 2rem; padding: 1.5rem; margin: 0 auto 2rem; max-width: 700px; background: var(--card-bg); border: 1px solid var(--border); border-radius: 12px; }
    .stat { text-align: center; }
    .stat-number { font-size: 1.8rem; font-weight: 700; color: var(--accent); }
    .stat-label { font-size: 0.85rem; color: var(--text-secondary); margin-top: 0.25rem; }
    .category-section { max-width: 900px; margin: 0 auto 2.5rem; padding: 0 1rem; }
    .category-header { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.5rem; }
    .category-header h2 { font-size: 1.4rem; margin: 0; }
    .category-count { background: var(--card-bg); border: 1px solid var(--border); padding: 0.15rem 0.6rem; border-radius: 20px; font-size: 0.75rem; color: var(--text-secondary); }
    .category-desc { color: var(--text-secondary); font-size: 0.9rem; margin-bottom: 1rem; }
    .items-grid { display: grid; gap: 0.5rem; }
    .item-row { display: flex; align-items: center; justify-content: space-between; padding: 0.75rem 1rem; background: var(--card-bg); border: 1px solid var(--border); border-radius: 8px; transition: border-color 0.2s; }
    .item-row:hover { border-color: var(--accent); }
    .item-row a { color: var(--text-primary); text-decoration: none; font-weight: 500; }
    .item-row a:hover { color: var(--accent); }
    .item-name { font-weight: 500; }
    .item-right { display: flex; align-items: center; gap: 1rem; }
    .item-searches { font-size: 0.8rem; color: var(--text-secondary); }
    .badge { font-size: 0.7rem; padding: 0.2rem 0.6rem; border-radius: 20px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.03em; }
    .badge-published { background: rgba(34, 197, 94, 0.15); color: #22c55e; border: 1px solid rgba(34, 197, 94, 0.3); }
    .badge-building { background: rgba(245, 158, 11, 0.15); color: #f59e0b; border: 1px solid rgba(245, 158, 11, 0.3); }
    .more-coming { text-align: center; padding: 1rem; color: var(--text-secondary); font-size: 0.9rem; border-top: 1px solid var(--border); margin-top: 0.5rem; }
    @media (max-width: 640px) { .stats-bar { flex-wrap: wrap; gap: 1rem; } .item-searches { display: none; } .coming-soon-hero h1 { font-size: 1.6rem; } }
  </style>

  <div class="coming-soon-hero">
    <h1>📋 Content Roadmap</h1>
    <p>Here's what's published and what's coming next.</p>
  </div>

  <div class="stats-bar">
    <div class="stat">
      <div class="stat-number">{publishedCount}</div>
      <div class="stat-label">Published</div>
    </div>
    <div class="stat">
      <div class="stat-number">29</div>
      <div class="stat-label">In Pipeline</div>
    </div>
    <div class="stat">
      <div class="stat-number">4</div>
      <div class="stat-label">Categories</div>
    </div>
  </div>

  {categories.map(cat => (
    <div class="category-section">
      <div class="category-header">
        <span style="font-size:1.5rem">{cat.icon}</span>
        <h2>{cat.title}</h2>
        <span class="category-count">{cat.total} planned</span>
      </div>
      <p class="category-desc">{cat.description}</p>
      <div class="items-grid">
        {cat.items.map(item => (
          <div class="item-row">
            {item.status === 'published' && item.href ? (
              <a href={item.href}>{item.name}</a>
            ) : (
              <span class="item-name">{item.name}</span>
            )}
            <div class="item-right">
              <span class="item-searches">{item.searches}/mo</span>
              <span class={`badge ${item.status === 'published' ? 'badge-published' : 'badge-building'}`}>
                {item.status === 'published' ? '✓ Live' : '🔨 Building'}
              </span>
            </div>
          </div>
        ))}
      </div>
      {cat.total > 8 && (
        <div class="more-coming">+ {cat.total - 8} more {cat.title.toLowerCase()} coming soon</div>
      )}
    </div>
  ))}
</SiteLayout>
