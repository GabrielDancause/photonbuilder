---
import SiteLayout from '../../../layouts/SiteLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Cooking Measurement Converter",
  "url": "https://28grams.vip/unit-converter-cooking",
  "description": "Convert cooking measurements instantly — cups to grams, tablespoons to cups, fluid oz to ml, and more. Ingredient-aware conversions for 20+ common baking and cooking ingredients.",
  "applicationCategory": "UtilitiesApplication",
  "operatingSystem": "Any",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  },
  "author": {
    "@type": "Organization",
    "name": "GAB Ventures",
    "url": "https://gab.ae"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How many grams are in a cup of flour?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "One cup of all-purpose flour weighs approximately 125 grams (4.4 oz). However, this can vary depending on how you scoop the flour — spooning flour into a cup and leveling gives a more consistent measurement than scooping directly from the bag, which can pack the flour and yield up to 150g per cup."
      }
    },
    {
      "@type": "Question",
      "name": "How do I convert tablespoons to cups?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "There are 16 tablespoons in 1 US cup. So to convert tablespoons to cups, divide the number of tablespoons by 16. For example, 8 tablespoons equals ½ cup, and 4 tablespoons equals ¼ cup. This ratio is standard for all liquid and dry ingredients measured by volume."
      }
    },
    {
      "@type": "Question",
      "name": "Why do volume-to-weight conversions differ by ingredient?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Different ingredients have different densities. A cup of butter (227g) weighs almost twice as much as a cup of flour (125g) because butter is denser. This is why professional bakers prefer weighing ingredients in grams — it eliminates the variability of volume measurements and produces more consistent results."
      }
    },
    {
      "@type": "Question",
      "name": "What is the difference between fluid ounces and ounces?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Fluid ounces (fl oz) measure volume, while ounces (oz) measure weight. One fluid ounce of water happens to weigh about one ounce, but this is not true for other ingredients. For example, 1 fl oz of honey weighs about 1.5 oz because honey is denser than water. Always check whether a recipe calls for fluid ounces (volume) or ounces (weight)."
      }
    },
    {
      "@type": "Question",
      "name": "How do I convert Fahrenheit to Celsius for oven temperatures?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "To convert Fahrenheit to Celsius, subtract 32 and multiply by 5/9. Common oven temperatures: 325°F = 163°C, 350°F = 177°C, 375°F = 191°C, 400°F = 204°C, 425°F = 218°C, and 450°F = 232°C. Most baking recipes use temperatures between 325°F and 450°F (163°C–232°C)."
      }
    },
    {
      "@type": "Question",
      "name": "How many teaspoons are in a tablespoon?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "There are 3 teaspoons in 1 tablespoon. This is a universal standard in cooking measurement. So 1 teaspoon is ⅓ of a tablespoon, and 6 teaspoons equal 2 tablespoons. For very small amounts, ½ teaspoon and ¼ teaspoon measuring spoons are also widely available."
      }
    }
  ]
};

export const meta = {
  title: "Cooking Measurement Converter — Cups, Grams & More",
  description: "Convert cooking measurements instantly — cups to grams, tablespoons to cups, fluid oz to ml. Ingredient-aware conversions for flour, sugar, butter and 20+ ingredients. Free cooking unit converter.",
  category: "tool",
  published: "2026-03-21",
};
