    .faq summary { padding: 1rem; color: white; cursor: pointer; font-weight: 600; font-size: 0.95rem; }
    .faq summary:hover { color: #C2185B; }
    .faq .answer { padding: 0 1rem 1rem; color: #c0b0c0; font-size: 0.9rem; line-height: 1.7; }

    @media (max-width: 600px) {
      .hero h1 { font-size: 1.6rem; }
      .compare-grid { grid-template-columns: 1fr; }
      .card-stats { grid-template-columns: 1fr 1fr; }
    }
  </style>

  <div class="hero">
    <h1>Best Nugget Ice Makers 2026</h1>
    <p class="subtitle">Compare countertop nugget ice machines side-by-side — production rates, noise levels, costs, and real ratings</p>
    <span class="data-badge">📊 6 machines · 8 data points each · Updated March 2026</span>
  </div>

  <div class="section">
    <h2 class="section-title">🧊 All Machines</h2>
    <p style="color:#a090a0; margin-bottom:1rem; font-size:0.9rem;">Click "Compare" on any two machines to see them side-by-side.</p>
    <div class="compare-grid" id="machineGrid"></div>
    <div class="compare-panel" id="comparePanel">
      <h3>⚖️ Head-to-Head Comparison</h3>
      <table class="compare-table" id="compareTable"></table>
    </div>
  </div>

  <div class="section">
    <h2 class="section-title">📊 Production & Value Chart</h2>
    <div class="chart-container">
      <canvas id="iceChart"></canvas>
    </div>
  </div>

  <div class="section">
    <h2 class="section-title">💡 Cost Calculator</h2>
    <div class="calc-box">
      <p style="color:#a090a0; font-size:0.9rem; margin-bottom:0.5rem;">Estimate your daily and yearly cost of running a nugget ice maker.</p>
      <div class="calc-grid">
        <div class="calc-field">
          <label>Machine</label>
          <select id="calcMachine"></select>
        </div>
        <div class="calc-field">
          <label>Hours per Day</label>
          <input type="number" id="calcHours" value="12" min="1" max="24" step="1" />
        </div>
        <div class="calc-field">
          <label>Electricity Rate ($/kWh)</label>
          <input type="number" id="calcRate" value="0.14" min="0.01" max="1" step="0.01" />
        </div>
        <div class="calc-field">
          <label>Water Cost ($/gallon)</label>
          <input type="number" id="calcWater" value="0.005" min="0" max="0.1" step="0.001" />
        </div>
      </div>
      <div class="calc-results" id="calcResults"></div>
    </div>
  </div>

  <div class="section">
    <h2 class="section-title">📖 Buyer's Guide</h2>

    <div class="guide-section">
      <h3>What Is Nugget Ice?</h3>
      <p>Nugget ice — also called pebble ice, Sonic ice, or chewable ice — is made by compacting layers of thin ice flakes into small, soft, irregularly shaped pieces. Unlike solid cubes from a freezer, nugget ice is porous, which means it absorbs the flavor of whatever drink it's in. That's why a Sonic Cherry Limeade tastes different from one made with regular ice cubes.</p>
      <p style="margin-top:0.5rem;">The soft texture makes it satisfying to chew (there's an entire community of ice chewers), and the high surface area cools drinks faster than traditional cubes. Countertop nugget ice makers have turned this restaurant-grade ice into a home kitchen staple.</p>
    </div>

    <div class="guide-section">
      <h3>What to Look For</h3>
      <ul>
        <li><strong>Daily production:</strong> Most countertop models make 30–44 lbs per day. A family of four typically uses 8–12 lbs daily. Higher output means ice is always available, but also higher energy use.</li>
        <li><strong>First batch time:</strong> Ranges from 20–35 minutes. If you want ice ready fast in the morning, prioritize models under 25 minutes.</li>
        <li><strong>Noise level:</strong> Measured in decibels (dB). Under 45 dB is comparable to a quiet library. Over 48 dB gets noticeable in open kitchens.</li>
        <li><strong>Reservoir size:</strong> Larger reservoirs mean fewer refills. If you don't want to hook up a water line, look for 2.5+ quart reservoirs.</li>
        <li><strong>Self-cleaning:</strong> Nearly all modern models include this. Run it weekly to prevent mineral buildup and keep ice tasting fresh.</li>
        <li><strong>WiFi/smart features:</strong> Only the GE Opal offers app control and scheduling. Useful if you want ice ready when you wake up without leaving it running overnight.</li>
      </ul>
    </div>

    <div class="guide-section">
      <h3>Maintenance Tips</h3>
      <ul>
        <li>Run the self-cleaning cycle once a week with a citric acid solution</li>
        <li>Use filtered water to reduce mineral buildup and improve ice taste</li>
        <li>Descale every 3 months (monthly if you have hard water)</li>
        <li>Empty the ice basket and drain water if you won't use the machine for more than 2 days</li>
        <li>Wipe down the exterior and drip tray weekly to prevent mold</li>
        <li>Replace the water filter (if applicable) every 3–6 months</li>
      </ul>
    </div>
  </div>

  <div class="section">
    <h2 class="section-title">❓ Frequently Asked Questions</h2>
    <div class="faq">
      <details><summary>What is nugget ice?</summary><div class="answer">Nugget ice (also called pebble ice, Sonic ice, or chewable ice) is soft, compacted ice made from layers of frozen flaked ice. Unlike solid cubes, nugget ice is porous and chewable, absorbs drink flavors, and cools beverages faster. It's the same type of ice used at Sonic Drive-In restaurants.</div></details>
      <details><summary>How much does a nugget ice maker cost to run?</summary><div class="answer">A typical countertop nugget ice maker uses 150–300 watts and costs $0.50 to $1.50 per day in electricity, depending on your local rates and how many hours it runs. Annual operating costs range from $180 to $550. Use the cost calculator above for a personalized estimate.</div></details>
      <details><summary>How long do nugget ice makers last?</summary><div class="answer">Most countertop nugget ice makers last 3–5 years with proper maintenance. Running the self-cleaning cycle weekly, using filtered water, and descaling every 3–6 months can extend the lifespan significantly.</div></details>
      <details><summary>Do nugget ice makers need a water line?</summary><div class="answer">Most countertop nugget ice makers use a manual-fill reservoir and don't require a water line. Some models like the KBice offer optional water line hookups for continuous production without refilling.</div></details>
      <details><summary>Why is nugget ice so popular?</summary><div class="answer">Nugget ice gained cult status through Sonic Drive-In, where fans loved its soft, chewable texture. It absorbs drink flavors (making sodas and cocktails taste better), cools drinks faster than cubes, and is satisfying to chew. Social media and the rise of affordable countertop makers turned it into a kitchen trend.</div></details>
    </div>
  </div>

  <script is:inline define:vars={{ machines }}>
    const data = machines;
    const wattage = { "GE Profile Opal 2.0": 260, "Silonn Nugget Ice Maker": 180, "Frigidaire EFIC235": 280, "Cowsar Nugget Ice Maker": 150, "Hicon Countertop Nugget": 200, "KBice Self-Dispensing": 240 };
    const waterPerLb = 0.8; // gallons per lb of ice

    // Render machine cards
    const grid = document.getElementById('machineGrid');
    let selected = [];

    function renderCards() {
      grid.innerHTML = data.map((m, i) => `
        <div class="machine-card ${selected.includes(i) ? 'selected' : ''}" data-idx="${i}">
          <span class="card-badge">${m.badge}</span>
          <div class="card-name">${m.name}</div>
          <div class="card-price">$${m.price}</div>
          <div class="card-stats">
            <div class="stat"><div class="stat-value">${m.icePerDay} lbs</div><div class="stat-label">Ice / Day</div></div>
            <div class="stat"><div class="stat-value">${m.firstBatch} min</div><div class="stat-label">First Batch</div></div>
            <div class="stat"><div class="stat-value">${m.noise} dB</div><div class="stat-label">Noise</div></div>
            <div class="stat"><div class="stat-value">${m.reservoir} qt</div><div class="stat-label">Reservoir</div></div>
          </div>
          <div class="card-features">
            <span class="feature-tag ${m.wifi ? 'feature-yes' : 'feature-no'}">${m.wifi ? '✓' : '✗'} WiFi</span>
            <span class="feature-tag ${m.selfClean ? 'feature-yes' : 'feature-no'}">${m.selfClean ? '✓' : '✗'} Self-Clean</span>
          </div>
          <div style="margin:0.5rem 0;">
            <div style="display:flex;justify-content:space-between;font-size:0.8rem;"><span>Rating</span><span style="color:#C2185B;font-weight:700;">${m.rating}/10</span></div>
            <div class="rating-bar"><div class="rating-fill" style="width:${m.rating*10}%"></div></div>
          </div>
          <div class="card-pros"><strong style="font-size:0.8rem;color:#2ecc71;">Pros</strong><ul>${m.pros.map(p=>`<li>${p}</li>`).join('')}</ul></div>
          <div class="card-cons"><strong style="font-size:0.8rem;color:#e74c3c;">Cons</strong><ul>${m.cons.map(c=>`<li>${c}</li>`).join('')}</ul></div>
          <button class="compare-btn ${selected.includes(i) ? 'active' : ''}" onclick="toggleCompare(${i})">
            ${selected.includes(i) ? '✓ Selected' : 'Compare'}
          </button>
        </div>
      `).join('');
    }

    window.toggleCompare = function(idx) {
      if (selected.includes(idx)) {
        selected = selected.filter(i => i !== idx);
      } else if (selected.length < 2) {
        selected.push(idx);
      } else {
        selected = [selected[1], idx];
      }
      renderCards();
      updateCompare();
    };

    function updateCompare() {
      const panel = document.getElementById('comparePanel');
      if (selected.length < 2) { panel.classList.remove('visible'); return; }
      panel.classList.add('visible');
      const a = data[selected[0]], b = data[selected[1]];
      const metrics = [
        ['Price', `$${a.price}`, `$${b.price}`, a.price < b.price],
        ['Ice Per Day', `${a.icePerDay} lbs`, `${b.icePerDay} lbs`, a.icePerDay > b.icePerDay],
        ['First Batch', `${a.firstBatch} min`, `${b.firstBatch} min`, a.firstBatch < b.firstBatch],
        ['Noise Level', `${a.noise} dB`, `${b.noise} dB`, a.noise < b.noise],
        ['Reservoir', `${a.reservoir} qt`, `${b.reservoir} qt`, a.reservoir > b.reservoir],
        ['Weight', `${a.weight} lbs`, `${b.weight} lbs`, a.weight < b.weight],
        ['WiFi', a.wifi ? 'Yes' : 'No', b.wifi ? 'Yes' : 'No', a.wifi && !b.wifi],
        ['Rating', `${a.rating}/10`, `${b.rating}/10`, a.rating > b.rating],
        ['Value (lbs/$)', (a.icePerDay/a.price*1000).toFixed(1), (b.icePerDay/b.price*1000).toFixed(1), (a.icePerDay/a.price) > (b.icePerDay/b.price)],
      ];
      document.getElementById('compareTable').innerHTML = `
        <tr><th>Metric</th><th>${a.name}</th><th>${b.name}</th></tr>
        ${metrics.map(([label, va, vb, aWins]) => `
          <tr>
            <td>${label}</td>
            <td class="${aWins ? 'best-value' : ''}">${va}</td>
            <td class="${!aWins ? 'best-value' : ''}">${vb}</td>
          </tr>
        `).join('')}
      `;
    }

    // Cost calculator
    const calcSelect = document.getElementById('calcMachine');
    data.forEach((m,i) => {
      const opt = document.createElement('option');
      opt.value = i; opt.textContent = `${m.name} ($${m.price})`;
      calcSelect.appendChild(opt);
    });

    function updateCalc() {
      const m = data[calcSelect.value];
      const hours = parseFloat(document.getElementById('calcHours').value) || 12;
      const rate = parseFloat(document.getElementById('calcRate').value) || 0.14;
      const waterCost = parseFloat(document.getElementById('calcWater').value) || 0.005;
      const watts = wattage[m.name] || 200;
      const dailyKwh = (watts * hours) / 1000;
      const dailyElec = dailyKwh * rate;
      const iceProduced = m.icePerDay * (hours / 24);
      const dailyWater = iceProduced * waterPerLb * waterCost;
      const dailyTotal = dailyElec + dailyWater;
      const yearlyTotal = dailyTotal * 365;
      const costPerLb = dailyTotal / iceProduced;

      document.getElementById('calcResults').innerHTML = `
        <div class="calc-result"><div class="big">${dailyKwh.toFixed(1)}</div><div class="label">kWh / Day</div></div>
        <div class="calc-result"><div class="big">$${dailyTotal.toFixed(2)}</div><div class="label">Daily Cost</div></div>
        <div class="calc-result"><div class="big">$${yearlyTotal.toFixed(0)}</div><div class="label">Yearly Cost</div></div>
        <div class="calc-result"><div class="big">$${costPerLb.toFixed(2)}</div><div class="label">Cost / lb Ice</div></div>
        <div class="calc-result"><div class="big">${iceProduced.toFixed(0)}</div><div class="label">lbs Ice / Day</div></div>
        <div class="calc-result"><div class="big">$${(m.price / (m.icePerDay * 365) * 1000).toFixed(0)}</div><div class="label">Break-even (lbs)</div></div>
      `;
    }

    calcSelect.addEventListener('change', updateCalc);
    document.getElementById('calcHours').addEventListener('input', updateCalc);
    document.getElementById('calcRate').addEventListener('input', updateCalc);
    document.getElementById('calcWater').addEventListener('input', updateCalc);
    updateCalc();

    // Chart
    function loadChart() {
      const ctx = document.getElementById('iceChart').getContext('2d');
      const sorted = [...data].sort((a,b) => b.icePerDay - a.icePerDay);
      new Chart(ctx, {
        type: 'bar',
        data: {
          labels: sorted.map(m => m.name.split(' ').slice(0,2).join(' ')),
          datasets: [
            { label: 'Ice/Day (lbs)', data: sorted.map(m => m.icePerDay), backgroundColor: 'rgba(194,24,91,0.7)', yAxisID: 'y' },
            { label: 'Price ($)', data: sorted.map(m => m.price), backgroundColor: 'rgba(194,24,91,0.25)', yAxisID: 'y1' }
          ]
        },
        options: {
          responsive: true,
          interaction: { mode: 'index', intersect: false },
          plugins: { legend: { labels: { color: '#a090a0' } } },
          scales: {
            x: { ticks: { color: '#a090a0' }, grid: { color: '#1a1018' } },
            y: { type: 'linear', position: 'left', title: { display: true, text: 'lbs/day', color: '#a090a0' }, ticks: { color: '#a090a0' }, grid: { color: '#1a1018' } },
            y1: { type: 'linear', position: 'right', title: { display: true, text: 'Price $', color: '#a090a0' }, ticks: { color: '#a090a0' }, grid: { drawOnChartArea: false } }
          }
        }
      });
    }

    if (typeof Chart !== 'undefined') { loadChart(); }
    else {
      const s = document.createElement('script');
      s.src = 'https://cdn.jsdelivr.net/npm/chart.js';
      s.onload = loadChart;
      document.head.appendChild(s);
    }

    renderCards();
  </script>

