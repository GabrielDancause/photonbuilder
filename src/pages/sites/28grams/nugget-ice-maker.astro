    .machine-card.selected { border-color: #C2185B; box-shadow: 0 0 0 2px rgba(194,24,91,0.3); }
    .card-badge { position: absolute; top: -10px; right: 16px; background: #C2185B; color: white; padding: 0.2rem 0.7rem; border-radius: 999px; font-size: 0.75rem; font-weight: 600; }
    .card-name { font-size: 1.2rem; color: white; font-weight: 700; margin-bottom: 0.3rem; }
    .card-price { font-size: 1.5rem; color: #C2185B; font-weight: 800; }
    .card-stats { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin: 1rem 0; }
