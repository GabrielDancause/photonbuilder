  canonical="https://28grams.vip/nugget-ice-maker" schema={schema}
>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Inter', sans-serif; background: #0a060a; color: #e0d0d8; }
    .hero { text-align: center; padding: 3rem 1rem 2rem; max-width: 800px; margin: 0 auto; }
    .hero h1 { font-size: 2.2rem; color: #C2185B; margin-bottom: 0.5rem; line-height: 1.2; }
    .hero .subtitle { color: #a090a0; font-size: 1.1rem; }
    .hero .data-badge { display: inline-block; background: rgba(194,24,91,0.15); color: #C2185B; padding: 0.3rem 0.8rem; border-radius: 999px; font-size: 0.85rem; margin-top: 0.8rem; }

    .section { max-width: 1100px; margin: 0 auto; padding: 2rem 1rem; }
    .section-title { font-size: 1.5rem; color: #C2185B; margin-bottom: 1rem; display: flex; align-items: center; gap: 0.5rem; }

    /* Comparison cards */
    .compare-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 1.2rem; }
    .machine-card { background: #1a1018; border: 1px solid #2a1828; border-radius: 12px; padding: 1.5rem; transition: transform 0.2s, box-shadow 0.2s; position: relative; }
