    .feature-no { background: rgba(160,144,160,0.1); color: #605060; }
    .card-pros, .card-cons { margin-top: 0.5rem; }
    .card-pros li, .card-cons li { font-size: 0.82rem; color: #c0b0c0; margin: 0.2rem 0; padding-left: 0.3rem; }
    .card-pros li::marker { color: #2ecc71; }
