    .compare-btn { display: block; width: 100%; margin-top: 0.8rem; padding: 0.6rem; border: 1px solid #C2185B; background: transparent; color: #C2185B; border-radius: 8px; cursor: pointer; font-size: 0.85rem; font-weight: 600; transition: all 0.2s; }
