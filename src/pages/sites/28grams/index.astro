  <!-- Hero -->
  <div class="hero">
    <div class="hero-content">
      <div class="tagline">Food, Cooking & Baking</div>
      <h1>28 Grams</h1>
      <p>Cooking calculators, baking tools, recipe guides, and kitchen equipment reviews.</p>
