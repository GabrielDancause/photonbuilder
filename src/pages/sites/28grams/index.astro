---
import SiteLayout from '../../../layouts/SiteLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "28 Grams — Food, Cooking & Baking",
  "url": "https://28grams.vip/",
  "description": "Cooking calculators, baking tools, recipe guides, and kitchen equipment reviews."
};
