          </tr>
          <tr class="brand-row">
            <td class="brand-name">KitchenAid K400</td>
            <td class="type-mid">Mid-Range</td>
            <td class="price-tag mono">$$$</td>
            <td>1200W</td>
            <td>56 oz</td>
            <td>5</td>
            <td>Moderate</td>
            <td>Self-Clean</td>
            <td>5 Years</td>
          </tr>
          <tr class="brand-row">
            <td class="brand-name">NutriBullet Pro 900</td>
            <td class="type-personal">Personal</td>
            <td class="price-tag mono">$</td>
            <td>900W</td>
            <td>32 oz</td>
            <td>1</td>
            <td>Loud</td>
            <td>Dishwasher Safe</td>
            <td>1 Year</td>
          </tr>
          <tr class="brand-row">
            <td class="brand-name">Breville Control Grip</td>
            <td class="type-immersion">Immersion</td>
            <td class="price-tag mono">$</td>
            <td>280W</td>
            <td>42 oz (Jug)</td>
            <td>15</td>
            <td>Quiet</td>
            <td>Hand Wash</td>
            <td>1 Year</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  <div class="review-section">
    <div class="review-card">
