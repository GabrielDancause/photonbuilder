  const tableBody = document.getElementById('tableBody');

  // Sort logic
  headers.forEach(header => {
    header.addEventListener('click', () => {
      const sortType = header.getAttribute('data-sort');
      const isAsc = !header.classList.contains('asc');

      headers.forEach(h => { h.classList.remove('asc', 'desc'); });
      header.classList.add(isAsc ? 'asc' : 'desc');

      const rowsArray = Array.from(rows);

      rowsArray.sort((a, b) => {
        let aVal, bVal;

        if (sortType === 'brand') {
          aVal = a.children[0].innerText.toLowerCase();
          bVal = b.children[0].innerText.toLowerCase();
        } else if (sortType === 'type') {
          aVal = a.children[1].innerText.toLowerCase();
          bVal = b.children[1].innerText.toLowerCase();
        } else if (sortType === 'price') {
          aVal = a.children[8].innerText.length; // Compare number of '$'
          bVal = b.children[8].innerText.length;
        } else if (sortType === 'power') {
          aVal = parseFloat(a.children[2].innerText) || 0;
          bVal = parseFloat(b.children[2].innerText) || 0;
        } else if (sortType === 'size') {
          aVal = parseFloat(a.children[3].innerText) || 0;
          bVal = parseFloat(b.children[3].innerText) || 0;
        } else if (sortType === 'speed') {
          aVal = a.children[4].innerText.toLowerCase();
          bVal = b.children[4].innerText.toLowerCase();
        } else if (sortType === 'noise') {
          const noiseOrder = { 'low': 1, 'moderate': 2, 'high': 3, 'very high': 4 };
          aVal = noiseOrder[a.children[5].innerText.toLowerCase()] || 0;
          bVal = noiseOrder[b.children[5].innerText.toLowerCase()] || 0;
        } else if (sortType === 'clean') {
          aVal = a.children[6].innerText.toLowerCase();
          bVal = b.children[6].innerText.toLowerCase();
        } else if (sortType === 'warranty') {
          aVal = parseFloat(a.children[7].innerText) || 0;
          bVal = parseFloat(b.children[7].innerText) || 0;
        }

        if (aVal < bVal) return isAsc ? -1 : 1;
        if (aVal > bVal) return isAsc ? 1 : -1;
        return 0;
      });

      rowsArray.forEach(row => tableBody.appendChild(row));
    });
  });
</script>

</SiteLayout>
