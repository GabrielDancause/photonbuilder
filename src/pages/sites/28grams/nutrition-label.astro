}

function switchTab(name) {
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
  document.getElementById('tab-' + name).classList.add('active');
  event.target.classList.add('active');
}

function parseIngredients(text) {
  // Remove parenthetical sub-ingredients for matching, but keep for display
  let cleaned = text.replace(/\([^)]*\)/g, ',').replace(/\./g, '');
  let parts = cleaned.split(/,|;/).map(s => s.trim()).filter(s => s.length > 1);
  return parts;
}

function lookupIngredient(name) {
  let lower = name.toLowerCase().trim();
  // Direct match
  if (INGREDIENTS_DB[lower]) return { name: name, ...INGREDIENTS_DB[lower] };
  // Partial match
  for (let key in INGREDIENTS_DB) {
    if (lower.includes(key) || key.includes(lower)) return { name: name, ...INGREDIENTS_DB[key] };
  }
  return { name: name, cat: 'unknown', desc: 'Not in database', gras: 'Unknown' };
}

function analyzeIngredients() {
  let text = document.getElementById('ingredient-input').value.trim();
  if (!text) return;
  let parts = parseIngredients(text);
  let results = parts.map(p => lookupIngredient(p));

  let counts = { green: 0, yellow: 0, red: 0, unknown: 0 };
  results.forEach(r => counts[r.cat]++);

  let total = results.length;
  let summaryEl = document.getElementById('analyzer-summary');
  let redPct = total > 0 ? Math.round((counts.red / total) * 100) : 0;
  let greenPct = total > 0 ? Math.round((counts.green / total) * 100) : 0;
  summaryEl.innerHTML = '<strong>' + total + ' ingredients detected</strong> — ' +
    '<span style="color:#16a34a">' + counts.green + ' safe</span>, ' +
    '<span style="color:#ca8a04">' + counts.yellow + ' additives</span>, ' +
    '<span style="color:#dc2626">' + counts.red + ' controversial</span>, ' +
    '<span style="color:#666">' + counts.unknown + ' unknown</span>' +
    (counts.red > 0 ? '<br><span style="color:#dc2626; font-size: 0.82rem;">⚠️ Contains ' + counts.red + ' ingredient(s) that are banned or restricted in other countries.</span>' : '');

  let html = '';
  results.forEach(r => {
    let cls = 'ingr-' + r.cat;
    html += '<div class="ingr-item ' + cls + '">' +
      '<span class="dot"></span>' +
      '<span class="name">' + r.name + '</span>' +
      '<span class="desc">' + r.desc + '</span>' +
      '</div>';
  });

  document.getElementById('analyzer-results').innerHTML = html;
  document.getElementById('analyzer-output').style.display = 'block';
}

function loadExampleIngredients(type) {
  document.getElementById('ingredient-input').value = EXAMPLE_INGREDIENTS[type] || '';
  analyzeIngredients();
}

function copyCode() {
  let container = document.querySelector('.label-container').outerHTML;
  let fullHtml = '<style>.label-container{font-family:Inter,Helvetica,Arial,sans-serif;background:#fff;color:#000;padding:12px;width:100%;max-width:360px;box-sizing:border-box}.nutrition-label{border:1px solid #000;padding:8px;width:100%;box-sizing:border-box}.label-title{font-size:2.2rem;font-weight:900;letter-spacing:-0.5px;margin:0 0 4px;line-height:1;border-bottom:1px solid #000;padding-bottom:4px}.label-line{display:flex;justify-content:space-between;padding:4px 0;border-bottom:1px solid #000;font-size:0.95rem}.label-line.thick{border-bottom-width:6px}.label-line.medium{border-bottom-width:4px}.label-line.li-indent{padding-left:16px}.label-line.li-indent-double{padding-left:32px}.label-bold{font-weight:800}.label-dv-title{font-size:0.8rem;font-weight:800;text-align:right;border-bottom:1px solid #000;padding-bottom:2px}.label-calories-row{display:flex;justify-content:space-between;align-items:flex-end;padding:4px 0;border-bottom:4px solid #000}.label-calories-title{font-weight:800;font-size:1.2rem;line-height:1}.label-calories-val{font-weight:900;font-size:2.4rem;line-height:1}.label-footer{font-size:0.75rem;line-height:1.2;padding-top:6px}</style>\n' + container;
  navigator.clipboard.writeText(fullHtml).then(function() {
