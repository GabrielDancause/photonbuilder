function formatNum(val) { let n = parseFloat(val); return isNaN(n) ? 0 : n; }
function calcDV(val, dvTotal) { return dvTotal === 0 ? 0 : Math.round((val / dvTotal) * 100); }

function updateLabel() {
  let servings = document.getElementById('inp-servings').value || '1';
  let servingSize = document.getElementById('inp-servingSize').value || '1 serving';
  let calories = formatNum(document.getElementById('inp-calories').value);
  let totalFat = formatNum(document.getElementById('inp-totalFat').value);
  let satFat = formatNum(document.getElementById('inp-satFat').value);
  let transFat = formatNum(document.getElementById('inp-transFat').value);
  let cholesterol = formatNum(document.getElementById('inp-cholesterol').value);
  let sodium = formatNum(document.getElementById('inp-sodium').value);
  let totalCarb = formatNum(document.getElementById('inp-totalCarb').value);
  let fiber = formatNum(document.getElementById('inp-fiber').value);
  let totalSugars = formatNum(document.getElementById('inp-totalSugars').value);
  let addedSugars = formatNum(document.getElementById('inp-addedSugars').value);
  let protein = formatNum(document.getElementById('inp-protein').value);
  let vitD = formatNum(document.getElementById('inp-vitD').value);
  let calcium = formatNum(document.getElementById('inp-calcium').value);
  let iron = formatNum(document.getElementById('inp-iron').value);
  let potassium = formatNum(document.getElementById('inp-potassium').value);

  document.getElementById('out-servings').textContent = servings + ' servings per container';
  document.getElementById('out-servingSize').textContent = servingSize;
  document.getElementById('out-calories').textContent = calories;
  document.getElementById('out-totalFat').textContent = totalFat + 'g';
  document.getElementById('out-satFat').textContent = satFat + 'g';
  document.getElementById('out-transFat').textContent = transFat + 'g';
  document.getElementById('out-cholesterol').textContent = cholesterol + 'mg';
  document.getElementById('out-sodium').textContent = sodium + 'mg';
  document.getElementById('out-totalCarb').textContent = totalCarb + 'g';
  document.getElementById('out-fiber').textContent = fiber + 'g';
  document.getElementById('out-totalSugars').textContent = totalSugars + 'g';
  document.getElementById('out-addedSugars').textContent = addedSugars + 'g';
  document.getElementById('out-protein').textContent = protein + 'g';
  document.getElementById('out-vitD').textContent = vitD + 'mcg';
  document.getElementById('out-calcium').textContent = calcium + 'mg';
  document.getElementById('out-iron').textContent = iron + 'mg';
  document.getElementById('out-potassium').textContent = potassium + 'mg';

  let dvTotalFat = calcDV(totalFat, DV.totalFat);
  let dvSatFat = calcDV(satFat, DV.satFat);
  let dvCholesterol = calcDV(cholesterol, DV.cholesterol);
  let dvSodium = calcDV(sodium, DV.sodium);
  let dvTotalCarb = calcDV(totalCarb, DV.totalCarb);
  let dvFiber = calcDV(fiber, DV.fiber);
  let dvAddedSugars = calcDV(addedSugars, DV.addedSugars);
  let dvVitD = calcDV(vitD, DV.vitD);
  let dvCalcium = calcDV(calcium, DV.calcium);
  let dvIron = calcDV(iron, DV.iron);
  let dvPotassium = calcDV(potassium, DV.potassium);

  document.getElementById('out-totalFat-dv').textContent = dvTotalFat + '%';
  document.getElementById('out-satFat-dv').textContent = dvSatFat + '%';
  document.getElementById('out-cholesterol-dv').textContent = dvCholesterol + '%';
  document.getElementById('out-sodium-dv').textContent = dvSodium + '%';
  document.getElementById('out-totalCarb-dv').textContent = dvTotalCarb + '%';
  document.getElementById('out-fiber-dv').textContent = dvFiber + '%';
  document.getElementById('out-addedSugars-dv').textContent = dvAddedSugars + '%';
  document.getElementById('out-vitD-dv').textContent = dvVitD + '%';
  document.getElementById('out-calcium-dv').textContent = dvCalcium + '%';
  document.getElementById('out-iron-dv').textContent = dvIron + '%';
  document.getElementById('out-potassium-dv').textContent = dvPotassium + '%';

  // Update score
  document.getElementById('score-sugars').textContent = dvAddedSugars + '% DV';
  document.getElementById('score-sodium').textContent = dvSodium + '% DV';
  document.getElementById('score-satfat').textContent = dvSatFat + '% DV';
  document.getElementById('score-fiber').textContent = dvFiber + '% DV';

  // Calculate grade
  let penalty = 0;
  if (dvAddedSugars > 40) penalty += 3; else if (dvAddedSugars > 20) penalty += 2; else if (dvAddedSugars > 10) penalty += 1;
  if (dvSodium > 30) penalty += 3; else if (dvSodium > 15) penalty += 2; else if (dvSodium > 8) penalty += 1;
  if (dvSatFat > 25) penalty += 2; else if (dvSatFat > 10) penalty += 1;
  let bonus = 0;
  if (dvFiber > 20) bonus += 2; else if (dvFiber > 10) bonus += 1;
  let score = Math.max(0, Math.min(10, 7 - penalty + bonus));

  let grade, title, desc, cls;
  if (score >= 8) { grade = 'A'; title = 'Excellent'; desc = 'Low in harmful nutrients, good fiber content.'; cls = 'grade-A'; }
  else if (score >= 6) { grade = 'B'; title = 'Good'; desc = 'Reasonable nutritional profile with minor concerns.'; cls = 'grade-B'; }
  else if (score >= 4) { grade = 'C'; title = 'Average'; desc = 'Moderate levels of sugars, sodium, or sat fat.'; cls = 'grade-C'; }
  else if (score >= 2) { grade = 'D'; title = 'Below Average'; desc = 'High in sugars, sodium, or saturated fat.'; cls = 'grade-D'; }
  else { grade = 'F'; title = 'Poor'; desc = 'Very high in harmful nutrients. Consume sparingly.'; cls = 'grade-F'; }

  let badge = document.getElementById('grade-badge');
  badge.textContent = grade;
  badge.className = 'grade-badge ' + cls;
  document.getElementById('grade-title').textContent = title;
  document.getElementById('grade-desc').textContent = desc;
}

function loadPreset(name) {
  let p = PRESETS[name]; if (!p) return;
  document.getElementById('inp-servings').value = p.servings;
  document.getElementById('inp-servingSize').value = p.servingSize;
  document.getElementById('inp-calories').value = p.calories;
  document.getElementById('inp-totalFat').value = p.totalFat;
  document.getElementById('inp-satFat').value = p.satFat;
  document.getElementById('inp-transFat').value = p.transFat;
  document.getElementById('inp-cholesterol').value = p.cholesterol;
  document.getElementById('inp-sodium').value = p.sodium;
  document.getElementById('inp-totalCarb').value = p.totalCarb;
  document.getElementById('inp-fiber').value = p.fiber;
