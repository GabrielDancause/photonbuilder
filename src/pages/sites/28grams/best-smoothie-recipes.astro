---
import SiteLayout from '../../../layouts/SiteLayout.astro';


export const meta = {
  title: 'Best Smoothie Recipes',
  description: 'Best Smoothie Recipes',
  category: 'list',
};

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Best Smoothie Recipes for Every Goal",
    "description": "Discover 20 delicious and nutritious smoothie recipes tailored to your goals, including weight loss, muscle building, energy boost, immunity, kid-friendly, and dessert replacements.",
    "url": "https://28grams.vip/best-smoothie-recipes",
    "author": {
      "@type": "Organization",
      "name": "28grams"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is the best order to put ingredients in a blender?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Always start with liquids at the bottom to get the blades moving. Follow with soft ingredients like fresh fruit or greens, then add seeds, nuts, or powders. Finish with hard or frozen ingredients like ice and frozen fruit at the top."
        }
      },
      {
        "@type": "Question",
        "name": "How can I meal prep smoothies for the week?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Create 'smoothie packs' by measuring out all your dry and frozen ingredients (fruits, greens, seeds) into reusable freezer bags or containers. Store them in the freezer. When you are ready, just dump the pack into your blender and add your liquid base."
        }
      },
      {
        "@type": "Question",
        "name": "Why is my smoothie too thick or too thin?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "If it's too thick, add more of your liquid base, a splash at a time, until it reaches your desired consistency. If it's too thin, add more ice, frozen fruit (like bananas), or a thickener like oats, chia seeds, or avocado."
        }
      },
      {
        "@type": "Question",
        "name": "Can I make a smoothie without a banana?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Absolutely! Bananas are popular for their creamy texture, but you can achieve a similar creaminess by using frozen avocado, mango, silken tofu, Greek yogurt, or even frozen cauliflower/zucchini."
        }
      },
      {
        "@type": "Question",
        "name": "How long do blended smoothies last in the fridge?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "While best consumed immediately, you can store a blended smoothie in an airtight container (like a mason jar filled to the brim to prevent oxidation) in the fridge for up to 24 hours. Shake well before drinking as separation is natural."
        }
      }
    ]
  }
];
---

<SiteLayout
  site="28grams"
  canonical="https://28grams.vip/best-smoothie-recipes"
  schema={JSON.stringify(schema)}
  title={meta.title}
  description={meta.description}>
  <style>
* { margin: 0; padding: 0; box-sizing: border-box; }
.page-wrapper {
  font-family: 'Inter', sans-serif;
  background: #0a060a;
  color: #e0d0d8;
  min-height: 100vh;
  --card-bg: #120c10;
  --border-color: #2a1820;
  --accent-color: #C2185B;
  --text-secondary: #888;
}

code, .mono { font-family: 'JetBrains Mono', monospace; }

.hero { text-align: center; padding: 48px 24px 24px; background: linear-gradient(180deg, #1a0a14 0%, #0a060a 100%); }
.hero h1 { font-size: 2.4rem; font-weight: 900; color: #fff; margin-bottom: 6px; }
.hero h1 span { background: linear-gradient(135deg, var(--accent-color), #ff6b9d); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
.hero p { color: #666; font-size: 0.95rem; max-width: 560px; margin: 0 auto; }
.main { max-width: 1000px; margin: 0 auto; padding: 32px 20px 40px; }

/* Formula Card */
.formula-card, .guide-card {
  background: var(--card-bg);
  border: 2px solid var(--border-color);
  border-radius: 16px;
  overflow: hidden;
  margin-bottom: 32px;
}
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 20px;
  background: #150d12;
  border-bottom: 1px solid var(--border-color);
}
.card-header h2 { font-size: 1.2rem; font-weight: 700; color: #fff; margin: 0; }
.card-content {
  padding: 20px;
}
.card-content p { color: #c8b8c0; line-height: 1.6; margin-bottom: 12px; }
.card-content ul { padding-left: 20px; color: #c8b8c0; line-height: 1.6; }
.card-content li { margin-bottom: 6px; }
.formula-highlight {
  background: #1a1015;
  padding: 16px;
  border-radius: 8px;
  text-align: center;
  font-weight: 700;
  color: var(--accent-color);
  margin-top: 16px;
  font-size: 1.1rem;
}

/* SEO content */
.content { max-width: 800px; margin: 0 auto; padding: 0 20px; }
.content h2 { font-size: 1.4rem; font-weight: 800; color: #fff; margin: 40px 0 14px; }
.content h2:first-child { margin-top: 0; }
.content h3 { font-size: 1.1rem; font-weight: 700; color: #ddd; margin: 24px 0 10px; }
.content p { font-size: 0.9rem; color: #777; line-height: 1.8; margin-bottom: 14px; }
.content ul, .content ol { padding-left: 20px; margin-bottom: 14px; }
.content li { font-size: 0.88rem; color: #777; line-height: 1.8; margin-bottom: 4px; }
.content strong { color: #ccc; }

/* Recipe Details */
.recipe-section { margin-bottom: 40px; padding-bottom: 24px; border-bottom: 1px solid var(--border-color); }
.recipe-section:last-of-type { border-bottom: none; }
.recipe-header { display: flex; align-items: baseline; gap: 12px; margin-bottom: 16px; }
.recipe-header h3 { margin: 0; font-size: 1.3rem; color: var(--accent-color); }
.recipe-meta { font-size: 0.85rem; color: var(--text-secondary); background: #1a1015; padding: 4px 8px; border-radius: 4px; border: 1px solid var(--border-color); }

.recipe-info-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 16px;
    margin-bottom: 16px;
}
.recipe-info-card {
    background: #150d12;
    padding: 12px 16px;
    border-radius: 8px;
    border: 1px solid var(--border-color);
}
.recipe-info-label {
    font-size: 0.75rem;
    color: var(--text-secondary);
    text-transform: uppercase;
    font-weight: 600;
    margin-bottom: 4px;
}
.recipe-info-value {
    color: #fff;
    font-size: 0.95rem;
}

/* FAQ */
.faq-list { margin-top: 24px; }
.faq-item { margin-bottom: 24px; }
.faq-q { font-weight: 700; color: #fff; margin-bottom: 8px; font-size: 1.05rem; }
.faq-a { color: #777; font-size: 0.95rem; line-height: 1.6; }

@media (max-width: 600px) {
  .hero h1 { font-size: 1.8rem; }
  .recipe-header { flex-direction: column; gap: 4px; }
}
  </style>

