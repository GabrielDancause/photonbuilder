<script is:inline>
  const searchInput = document.getElementById('searchInput');
  const filterBtns = document.querySelectorAll('.filter-btn');
  const rows = document.querySelectorAll('.ferm-row');
  const headers = document.querySelectorAll('th[data-sort]');
  const tableBody = document.getElementById('tableBody');

  let currentFilter = 'all';
  let searchQuery = '';

  function applyFilters() {
    rows.forEach(row => {
      const category = row.getAttribute('data-category');
      const text = row.innerText.toLowerCase();
      const matchesFilter = currentFilter === 'all' || category === currentFilter;
      const matchesSearch = text.includes(searchQuery);
      if (matchesFilter && matchesSearch) {
        row.classList.remove('hidden');
      } else {
        row.classList.add('hidden');
      }
    });
  }

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      currentFilter = btn.getAttribute('data-filter');
      applyFilters();
    });
  });

  searchInput.addEventListener('input', (e) => {
    searchQuery = e.target.value.toLowerCase();
    applyFilters();
  });

  headers.forEach(header => {
    header.addEventListener('click', () => {
      const sortType = header.getAttribute('data-sort');
      const isAsc = !header.classList.contains('asc');
      headers.forEach(h => { h.classList.remove('asc', 'desc'); });
      header.classList.add(isAsc ? 'asc' : 'desc');
      const rowsArray = Array.from(rows);
      rowsArray.sort((a, b) => {
        let aVal, bVal;
        if (sortType === 'name') {
          aVal = a.children[0].innerText.replace(/[^a-zA-Z ]/g, '').trim();
          bVal = b.children[0].innerText.replace(/[^a-zA-Z ]/g, '').trim();
        } else if (sortType === 'temp') {
          aVal = parseInt(a.getAttribute('data-temp-low')) || 0;
          bVal = parseInt(b.getAttribute('data-temp-low')) || 0;
        } else if (sortType === 'time') {
          const parseTime = (s) => {
            const t = s.toLowerCase();
            if (t.includes('month') || t.includes('year')) return 99999;
            if (t.includes('week')) return parseInt(t) * 7 * 24;
            if (t.includes('day')) return parseInt(t) * 24;
            return parseInt(t) || 0;
          };
          aVal = parseTime(a.children[2].innerText);
          bVal = parseTime(b.children[2].innerText);
        }
        if (aVal < bVal) return isAsc ? -1 : 1;
        if (aVal > bVal) return isAsc ? 1 : -1;
        return 0;
      });
      rowsArray.forEach(row => tableBody.appendChild(row));
    });
  });

  // Identifier logic
  const ferments = [
    { name: 'Sourdough Bread', low: 75, high: 82, timeDesc: '4-12 hours bulk ferment', icon: '\u{1F35E}' },
    { name: 'Yogurt', low: 108, high: 115, timeDesc: '6-12 hours', icon: '\u{1F95B}' },
    { name: 'Sauerkraut', low: 65, high: 75, timeDesc: '2-6 weeks', icon: '\u{1F966}' },
    { name: 'Kimchi', low: 60, high: 72, timeDesc: '3-7 days initial', icon: '\u{1F336}\u{FE0F}' },
    { name: 'Kombucha', low: 75, high: 85, timeDesc: '7-14 days (1F)', icon: '\u{1F375}' },
    { name: 'Tempeh', low: 86, high: 90, timeDesc: '24-48 hours', icon: '\u{1FAD8}' },
    { name: 'Miso', low: 60, high: 77, timeDesc: '3 months - 3 years', icon: '\u{1F372}' },
    { name: 'Beer (Ale)', low: 60, high: 72, timeDesc: '1-2 weeks primary', icon: '\u{1F37A}' },
    { name: 'Beer (Lager)', low: 45, high: 55, timeDesc: '2-3 weeks primary', icon: '\u{1F37A}' },
    { name: 'Wine', low: 55, high: 75, timeDesc: '1-2 weeks primary', icon: '\u{1F377}' },
    { name: 'Cheese (Aging)', low: 50, high: 55, timeDesc: '2-24 months', icon: '\u{1F9C0}' },
    { name: 'Hot Sauce', low: 68, high: 78, timeDesc: '5-14 days', icon: '\u{1F525}' },
    { name: 'Pickles', low: 65, high: 75, timeDesc: '3 days - 6 weeks', icon: '\u{1F952}' },
    { name: 'Kefir', low: 65, high: 75, timeDesc: '24-48 hours', icon: '\u{1F95B}' },
  ];

  document.getElementById('idBtn').addEventListener('click', () => {
    const tempVal = parseFloat(document.getElementById('idTemp').value);
    const unit = document.getElementById('idUnit').value;
    const resultsDiv = document.getElementById('idResults');

    if (isNaN(tempVal)) {
      resultsDiv.innerHTML = '<p class="no-match">Enter a temperature to identify possible ferments.</p>';
      return;
    }

    const tempF = unit === 'C' ? (tempVal * 9/5) + 32 : tempVal;

    const matches = ferments.map(f => {
      const mid = (f.low + f.high) / 2;
      const range = (f.high - f.low) / 2;
      const diff = Math.abs(tempF - mid);

      let confidence, cls;
      if (tempF >= f.low && tempF <= f.high) {
        confidence = 'Exact Match';
        cls = 'confidence-high';
      } else if (diff <= range + 5) {
        confidence = 'Close';
        cls = 'confidence-med';
      } else if (diff <= range + 15) {
        confidence = 'Possible';
        cls = 'confidence-low';
      } else {
        return null;
      }
      return { ...f, confidence, cls, diff };
    }).filter(Boolean).sort((a, b) => a.diff - b.diff);

    if (matches.length === 0) {
      resultsDiv.innerHTML = '<p class="no-match">No common ferments match this temperature. Most ferments happen between 45-115°F (7-46°C).</p>';
      return;
    }

    resultsDiv.innerHTML = matches.map(m =>
      `<div class="identifier-match">
        <div>
          <div class="match-name">${m.icon} ${m.name}</div>
          <div class="match-detail">Optimal: ${m.low}-${m.high}°F &middot; ${m.timeDesc}</div>
        </div>
        <span class="match-confidence ${m.cls}">${m.confidence}</span>
      </div>`
    ).join('');
  });
</script>


