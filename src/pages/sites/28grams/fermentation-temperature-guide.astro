---
import SiteLayout from '../../../layouts/SiteLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      "name": "Fermentation Temperature Guide",
      "description": "Interactive reference for fermentation temperatures and times. Covers sourdough, yogurt, sauerkraut, kimchi, kombucha, tempeh, miso, beer, wine, cheese, hot sauce, pickles, and kefir.",
      "url": "https://28grams.vip/fermentation-temperature-guide",
      "applicationCategory": "FoodApplication",
      "operatingSystem": "Any",
      "author": {
        "@type": "Organization",
        "name": "28grams"
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is the most important factor in fermentation?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Temperature is the single most important factor in fermentation. It controls the speed of microbial activity, flavor development, and whether beneficial or harmful organisms dominate. Even a few degrees outside the optimal range can dramatically affect your results."
          }
        },
        {
          "@type": "Question",
          "name": "Can I ferment at room temperature?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Many ferments like sauerkraut, kimchi, pickles, hot sauce, and sourdough starter work well at typical room temperature (65-75°F / 18-24°C). However, yogurt, tempeh, and some cheese cultures require warmer temperatures that usually need a dedicated fermentation chamber, oven with light on, or heating mat."
          }
        },
        {
          "@type": "Question",
          "name": "How do I know when my ferment is done?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Signs vary by ferment but generally include: active bubbling slowing down, sour or tangy taste developing, pH dropping below 4.6 for safety, expected texture changes (like yogurt thickening), and characteristic aromas. Use a pH meter for precision — most safe ferments reach pH 3.5-4.5."
          }
        },
        {
          "@type": "Question",
          "name": "What happens if my fermentation temperature is too high?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Temperatures that are too high can kill beneficial bacteria and yeast, produce off-flavors (fusel alcohols in beer, excessive sourness in bread), create mushy textures in vegetable ferments, and promote harmful bacterial growth. For most ferments, staying below 85°F (29°C) is safe."
          }
        },
        {
          "@type": "Question",
          "name": "What happens if my fermentation temperature is too low?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Cold temperatures slow or stall fermentation. While this isn't dangerous (cold actually preserves food), your ferment may take much longer or never fully develop. Some ferments like lager beer intentionally use cold temperatures (45-55°F) for a clean flavor profile, but most need at least 65°F to be active."
          }
        }
      ]
    }
  ]
};

export const meta = {
  title: "Fermentation Temperature Guide | Complete Reference Chart",
  description: "Interactive fermentation temperature and time guide for sourdough, yogurt, sauerkraut, kimchi, kombucha, tempeh, miso, beer, wine, cheese, hot sauce, pickles, and kefir.",
  category: "guide",
  published: "2024-09-10",
};
---

<SiteLayout
  site="28grams"
  title="Fermentation Temperature Guide | Complete Reference Chart"
  description="Interactive fermentation temperature and time guide for sourdough, yogurt, sauerkraut, kimchi, kombucha, tempeh, miso, beer, wine, cheese, hot sauce, pickles, and kefir."
  canonical="https://28grams.vip/fermentation-temperature-guide"
  schema={schema}
>
  <style>
* { margin: 0; padding: 0; box-sizing: border-box; }
body { font-family: 'Inter', sans-serif; background: #0a060a; color: #e0d0d8; min-height: 100vh; }
code, .mono { font-family: 'JetBrains Mono', monospace; }
.hero { text-align: center; padding: 48px 24px 24px; background: linear-gradient(180deg, #1a0a14 0%, #0a060a 100%); }
.hero h1 { font-size: 2.4rem; font-weight: 900; color: #fff; margin-bottom: 6px; }
.hero h1 span { background: linear-gradient(135deg, #C2185B, #ff6b9d); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
.hero p { color: #666; font-size: 0.95rem; max-width: 520px; margin: 0 auto; }
.main { max-width: 1100px; margin: 0 auto; padding: 32px 20px 40px; }

/* Filters */
.filters {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 8px;
  margin-bottom: 24px;
}
.filter-btn {
  background: #120c10;
  border: 1px solid #2a1820;
  color: #c8b8c0;
  padding: 8px 16px;
  border-radius: 20px;
  font-size: 0.85rem;
  font-weight: 600;
  cursor: pointer;
  font-family: 'Inter', sans-serif;
  transition: all 0.2s;
}
.filter-btn:hover { border-color: #C2185B; color: #fff; }
.filter-btn.active { background: #C2185B; border-color: #C2185B; color: #fff; }

/* Identifier Tool */
.identifier-card {
  background: #120c10;
  border: 2px solid #2a1820;
  border-radius: 16px;
  padding: 24px;
  margin-bottom: 32px;
}
.identifier-card h3 { font-size: 1.1rem; font-weight: 700; color: #fff; margin-bottom: 16px; }
.identifier-card h3 em { font-style: normal; background: linear-gradient(135deg, #C2185B, #ff6b9d); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
.identifier-form {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  align-items: flex-end;
  margin-bottom: 16px;
}
.identifier-field { display: flex; flex-direction: column; gap: 4px; }
.identifier-field label { font-size: 0.75rem; color: #888; text-transform: uppercase; font-weight: 600; letter-spacing: 0.5px; }
.identifier-field input, .identifier-field select {
  background: #1a1015;
  border: 1px solid #2a1820;
  border-radius: 8px;
  padding: 10px 14px;
  color: #fff;
  font-family: 'Inter', sans-serif;
  font-size: 0.9rem;
  outline: none;
  width: 160px;
}
.identifier-field input:focus, .identifier-field select:focus { border-color: #C2185B; }
.identifier-btn {
  background: #C2185B;
  border: none;
  color: #fff;
  padding: 10px 20px;
  border-radius: 8px;
  font-family: 'Inter', sans-serif;
  font-size: 0.9rem;
  font-weight: 600;
  cursor: pointer;
  transition: background 0.2s;
}
.identifier-btn:hover { background: #d81b60; }
.identifier-results { margin-top: 12px; }
.identifier-match {
  background: #1a1015;
  border: 1px solid #2a1820;
  border-radius: 10px;
  padding: 12px 16px;
  margin-bottom: 8px;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.identifier-match .match-name { font-weight: 600; color: #fff; font-size: 0.9rem; }
.identifier-match .match-detail { font-size: 0.8rem; color: #888; }
.identifier-match .match-confidence {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.8rem;
  font-weight: 700;
  padding: 4px 10px;
  border-radius: 6px;
}
.confidence-high { background: rgba(76, 175, 80, 0.15); color: #66bb6a; }
.confidence-med { background: rgba(255, 152, 0, 0.15); color: #ffa726; }
.confidence-low { background: rgba(244, 67, 54, 0.15); color: #ef5350; }
.no-match { color: #666; font-size: 0.85rem; font-style: italic; }

/* Chart Card */
.chart-card {
  background: #120c10;
  border: 2px solid #2a1820;
  border-radius: 16px;
  overflow: hidden;
  margin-bottom: 32px;
}
.chart-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16px 20px;
  background: #150d12;
  border-bottom: 1px solid #2a1820;
}
.chart-header h2 { font-size: 1rem; font-weight: 700; color: #fff; }

/* Search */
.search-wrap {
  position: relative;
  width: 100%;
  max-width: 300px;
}
.search-input {
  width: 100%;
  background: #1a1015;
  border: 1px solid #2a1820;
  border-radius: 8px;
  padding: 8px 12px 8px 32px;
  color: #fff;
  font-family: 'Inter', sans-serif;
  font-size: 0.85rem;
  outline: none;
}
.search-input:focus { border-color: #C2185B; }
.search-icon {
  position: absolute;
  left: 10px;
  top: 50%;
  transform: translateY(-50%);
  color: #888;
  font-size: 0.85rem;
}

/* Table Container */
.table-container {
  width: 100%;
  overflow-x: auto;
}
.ferm-table {
  width: 100%;
  border-collapse: collapse;
  min-width: 900px;
}
.ferm-table th {
  text-align: left;
  font-size: 0.75rem;
  color: #888;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  padding: 12px 14px;
  background: #1a1015;
  border-bottom: 2px solid #2a1820;
  position: sticky;
  top: 0;
  cursor: pointer;
  user-select: none;
}
.ferm-table th:hover { color: #ccc; }
.ferm-table td {
  padding: 12px 14px;
  font-size: 0.85rem;
  color: #c8b8c0;
  border-bottom: 1px solid #1a1015;
}
.ferm-table tr:hover td { background: #1a1015; }
.ferm-table tr.hidden { display: none; }
.ferm-table td:first-child { font-weight: 600; color: #fff; }
.temp-cell { color: #f97316; font-weight: 600; }
.time-cell { color: #C2185B; font-weight: 600; }
.signs-cell { font-size: 0.78rem; color: #aaa; }
.problems-cell { font-size: 0.78rem; color: #ef5350; }
.cat-icon { margin-right: 6px; font-size: 1.1em; }

/* Sort Icons */
.sort-icon {
  display: inline-block;
  width: 0;
  height: 0;
  border-left: 4px solid transparent;
  border-right: 4px solid transparent;
  border-bottom: 4px solid #888;
  margin-left: 4px;
  vertical-align: middle;
  transition: transform 0.2s;
}
th.asc .sort-icon { transform: rotate(0deg); border-bottom-color: #C2185B; }
th.desc .sort-icon { transform: rotate(180deg); border-bottom-color: #C2185B; }

/* Quick Ref */
.quickref-card {
  background: #120c10;
  border: 2px solid #2a1820;
  border-radius: 16px;
  padding: 24px;
  margin-bottom: 32px;
}
.quickref-card h3 { font-size: 1.1rem; font-weight: 700; color: #fff; margin-bottom: 16px; }
.quickref-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 16px;
}
.quickref-item {
  background: #1a1015;
  border-radius: 12px;
  padding: 16px;
  border: 1px solid #2a1820;
}
.quickref-item h4 { font-size: 0.9rem; color: #ccc; margin-bottom: 8px; }
.quickref-item .qr-detail { font-family: 'JetBrains Mono', monospace; font-size: 0.85rem; color: #888; }
.quickref-item .qr-detail span { color: #f97316; font-weight: 600; }

/* SEO content */
.content { max-width: 800px; margin: 0 auto; padding: 0 20px; }
.content h2 { font-size: 1.4rem; font-weight: 800; color: #fff; margin: 40px 0 14px; }
.content h2:first-child { margin-top: 0; }
.content h3 { font-size: 1.1rem; font-weight: 700; color: #ddd; margin: 24px 0 10px; }
.content p { font-size: 0.9rem; color: #777; line-height: 1.8; margin-bottom: 14px; }
.content ul, .content ol { padding-left: 20px; margin-bottom: 14px; }
.content li { font-size: 0.88rem; color: #777; line-height: 1.8; margin-bottom: 4px; }
.content strong { color: #ccc; }

/* FAQ */
.faq-list { margin-bottom: 40px; }
.faq-item { border-bottom: 1px solid #1a1015; padding: 16px 0; }
.faq-item:last-child { border-bottom: none; }
.faq-q { font-size: 0.95rem; font-weight: 700; color: #ddd; margin-bottom: 8px; }
.faq-a { font-size: 0.88rem; color: #777; line-height: 1.8; }

/* Related */
.related-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 12px;
  margin-top: 12px;
}
.related-link {
  display: block;
  background: #120c10;
  border: 1px solid #2a1820;
  border-radius: 12px;
  padding: 16px;
  text-decoration: none;
  transition: all 0.2s;
}
.related-link:hover { border-color: #C2185B; transform: translateY(-2px); }
.related-link h4 { font-size: 0.85rem; color: #fff; font-weight: 700; margin-bottom: 4px; }
.related-link p { font-size: 0.75rem; color: #666; }

@media (max-width: 600px) {
  .hero h1 { font-size: 1.8rem; }
  .chart-header { flex-direction: column; gap: 12px; align-items: flex-start; }
  .search-wrap { max-width: 100%; }
  .identifier-form { flex-direction: column; }
  .identifier-field input, .identifier-field select { width: 100%; }
}
  </style>

<div class="hero">
  <h1>Fermentation <span>Temperature Guide</span> </h1>
  <p>The complete reference for fermentation temperatures and times. Search by food type, identify ferments by temperature, and get perfect results every time.</p>
</div>

<div class="main">

  <div class="filters" id="filters">
    <button class="filter-btn active" data-filter="all">All Ferments</button>
    <button class="filter-btn" data-filter="bread">Bread</button>
    <button class="filter-btn" data-filter="dairy">Dairy</button>
    <button class="filter-btn" data-filter="vegetables">Vegetables</button>
    <button class="filter-btn" data-filter="beverages">Beverages</button>
    <button class="filter-btn" data-filter="condiments">Condiments</button>
  </div>

  <div class="identifier-card">
    <h3>What's <em>Fermenting</em>?</h3>
    <div class="identifier-form">
      <div class="identifier-field">
        <label>Temperature</label>
        <input type="number" id="idTemp" placeholder="e.g. 75">
      </div>
      <div class="identifier-field">
        <label>Unit</label>
        <select id="idUnit">
          <option value="F">°F</option>
          <option value="C">°C</option>
        </select>
      </div>
      <div class="identifier-field">
        <label>Time So Far</label>
        <input type="text" id="idTime" placeholder="e.g. 3 days">
      </div>
      <button class="identifier-btn" id="idBtn">Identify</button>
    </div>
    <div class="identifier-results" id="idResults"></div>
  </div>

  <div class="chart-card">
    <div class="chart-header">
      <h2>Fermentation Temperature Chart</h2>
      <div class="search-wrap">
        <span class="search-icon">&#x1F50D;</span>
        <input type="text" id="searchInput" class="search-input" placeholder="Search ferments (e.g., yogurt, kimchi)...">
      </div>
    </div>
    <div class="table-container">
      <table class="ferm-table" id="fermTable">
        <thead>
          <tr>
            <th data-sort="name">Ferment <span class="sort-icon"></span></th>
            <th data-sort="temp">Temp Range <span class="sort-icon"></span></th>
            <th data-sort="time">Time <span class="sort-icon"></span></th>
            <th>Signs It's Ready</th>
            <th>Problems at Wrong Temp</th>
          </tr>
        </thead>
        <tbody id="tableBody">
        <tr class="ferm-row" data-category="bread" data-temp-low="75" data-temp-high="82">
          <td><span class="cat-icon">&#x1F35E;</span> Sourdough Bread</td>
          <td class="mono temp-cell">75-82°F / 24-28°C</td>
          <td class="mono time-cell">4-12 hrs (bulk), 12-16 hrs (cold retard)</td>
          <td class="signs-cell">Dough doubles, jiggles, airy bubbles on surface, passes poke test</td>
          <td class="problems-cell">Too hot: over-ferments, sour/gummy. Too cold: dense, under-risen, bland</td>
        </tr>
        <tr class="ferm-row" data-category="dairy" data-temp-low="108" data-temp-high="115">
          <td><span class="cat-icon">&#x1F95B;</span> Yogurt</td>
          <td class="mono temp-cell">108-115°F / 42-46°C</td>
          <td class="mono time-cell">6-12 hrs</td>
          <td class="signs-cell">Thick, tangy, pulls away from container sides, pH 4.0-4.5</td>
          <td class="problems-cell">Too hot: grainy, whey separation, kills cultures. Too cold: runny, won't set</td>
        </tr>
        <tr class="ferm-row" data-category="vegetables" data-temp-low="65" data-temp-high="75">
          <td><span class="cat-icon">&#x1F966;</span> Sauerkraut</td>
          <td class="mono temp-cell">65-75°F / 18-24°C</td>
          <td class="mono time-cell">2-6 weeks</td>
          <td class="signs-cell">Tangy, sour smell, no more active bubbling, translucent cabbage</td>
          <td class="problems-cell">Too hot: mushy, off-flavors, mold risk. Too cold: very slow, may stall</td>
        </tr>
        <tr class="ferm-row" data-category="vegetables" data-temp-low="60" data-temp-high="72">
          <td><span class="cat-icon">&#x1F336;&#xFE0F;</span> Kimchi</td>
          <td class="mono temp-cell">60-72°F / 16-22°C</td>
          <td class="mono time-cell">3-7 days (initial), then refrigerate</td>
          <td class="signs-cell">Sour, fizzy, pungent aroma, bubbles when jar is opened</td>
          <td class="problems-cell">Too hot: overly sour quickly, mushy. Too cold: slow development, mild flavor</td>
        </tr>
        <tr class="ferm-row" data-category="beverages" data-temp-low="75" data-temp-high="85">
          <td><span class="cat-icon">&#x1F375;</span> Kombucha</td>
          <td class="mono temp-cell">75-85°F / 24-29°C</td>
          <td class="mono time-cell">7-14 days (1F), 2-4 days (2F)</td>
          <td class="signs-cell">Tart-sweet balance, new SCOBY forming, pH 2.5-3.5, fizzy</td>
          <td class="problems-cell">Too hot: vinegary, yeasty. Too cold: mold risk, very slow, sweet</td>
        </tr>
        <tr class="ferm-row" data-category="condiments" data-temp-low="86" data-temp-high="90">
          <td><span class="cat-icon">&#x1FAD8;</span> Tempeh</td>
          <td class="mono temp-cell">86-90°F / 30-32°C</td>
          <td class="mono time-cell">24-48 hrs</td>
          <td class="signs-cell">Dense white mycelium binds beans into firm cake, slight mushroom aroma</td>
          <td class="problems-cell">Too hot: black spores, ammonia smell. Too cold: patchy growth, doesn't bind</td>
        </tr>
        <tr class="ferm-row" data-category="condiments" data-temp-low="60" data-temp-high="77">
          <td><span class="cat-icon">&#x1F372;</span> Miso</td>
          <td class="mono temp-cell">60-77°F / 16-25°C</td>
          <td class="mono time-cell">3-12 months (white), 1-3 years (red)</td>
          <td class="signs-cell">Deep umami flavor, darkened color, smooth paste, tamari liquid on surface</td>
          <td class="problems-cell">Too hot: over-ferments, off-flavors. Too cold: extremely slow maturation</td>
        </tr>
        <tr class="ferm-row" data-category="beverages" data-temp-low="60" data-temp-high="72">
          <td><span class="cat-icon">&#x1F37A;</span> Beer (Ale)</td>
          <td class="mono temp-cell">60-72°F / 16-22°C</td>
          <td class="mono time-cell">1-2 weeks (primary), 2-4 weeks (conditioning)</td>
          <td class="signs-cell">Airlock activity stops, gravity stable 2-3 days, beer clears</td>
          <td class="problems-cell">Too hot: fusel alcohols, fruity esters, harsh. Too cold: stalled fermentation</td>
        </tr>
        <tr class="ferm-row" data-category="beverages" data-temp-low="45" data-temp-high="55">
          <td><span class="cat-icon">&#x1F37A;</span> Beer (Lager)</td>
          <td class="mono temp-cell">45-55°F / 7-13°C</td>
          <td class="mono time-cell">2-3 weeks (primary), 4-8 weeks (lagering)</td>
          <td class="signs-cell">Gravity stable, very clear, clean taste, minimal off-flavors</td>
          <td class="problems-cell">Too hot: ale-like esters, not clean. Too cold: stalled, incomplete attenuation</td>
        </tr>
        <tr class="ferm-row" data-category="beverages" data-temp-low="55" data-temp-high="75">
          <td><span class="cat-icon">&#x1F377;</span> Wine</td>
          <td class="mono temp-cell">55-75°F / 13-24°C</td>
          <td class="mono time-cell">1-2 weeks (primary), months (aging)</td>
          <td class="signs-cell">Airlock stops, gravity at 0.990-0.998, clear, balanced taste</td>
          <td class="problems-cell">Too hot: harsh, volatile, fusel. Too cold: stuck fermentation, reduced aroma</td>
        </tr>
        <tr class="ferm-row" data-category="dairy" data-temp-low="50" data-temp-high="55">
          <td><span class="cat-icon">&#x1F9C0;</span> Cheese (Aging/Hard)</td>
          <td class="mono temp-cell">50-55°F / 10-13°C</td>
          <td class="mono time-cell">2-24 months</td>
          <td class="signs-cell">Rind develops, firm texture, complex flavor, proper moisture level</td>
          <td class="problems-cell">Too hot: sweating, bacterial contamination, cracking. Too cold: flavor won't develop</td>
        </tr>
        <tr class="ferm-row" data-category="condiments" data-temp-low="68" data-temp-high="78">
          <td><span class="cat-icon">&#x1F525;</span> Hot Sauce</td>
          <td class="mono temp-cell">68-78°F / 20-26°C</td>
          <td class="mono time-cell">5-14 days</td>
          <td class="signs-cell">Active bubbling stops, tangy/sour aroma, pH below 3.5, stable brine</td>
          <td class="problems-cell">Too hot: mushy peppers, yeasty off-flavors. Too cold: slow start, mold risk</td>
        </tr>
        <tr class="ferm-row" data-category="vegetables" data-temp-low="65" data-temp-high="75">
          <td><span class="cat-icon">&#x1F952;</span> Pickles (Lacto-fermented)</td>
          <td class="mono temp-cell">65-75°F / 18-24°C</td>
          <td class="mono time-cell">3-7 days (half-sour), 2-6 weeks (full sour)</td>
          <td class="signs-cell">Sour taste, cloudy brine, bubbles, pickles change from bright to olive green</td>
          <td class="problems-cell">Too hot: hollow, mushy, overly sour. Too cold: slow, crunchy but mild</td>
        </tr>
        <tr class="ferm-row" data-category="dairy" data-temp-low="65" data-temp-high="75">
          <td><span class="cat-icon">&#x1F95B;</span> Kefir</td>
          <td class="mono temp-cell">65-75°F / 18-24°C</td>
          <td class="mono time-cell">24-48 hrs</td>
          <td class="signs-cell">Thick, slightly fizzy, tangy smell, thickens and separates slightly</td>
          <td class="problems-cell">Too hot: over-sour, grainy, whey separation. Too cold: thin, slow, inactive grains</td>
        </tr>
        </tbody>
      </table>
    </div>
  </div>

  <div class="quickref-card">
    <h3>Temperature Zones at a Glance</h3>
    <div class="quickref-grid">
      <div class="quickref-item">
        <h4>Cold Zone</h4>
