---
import SiteLayout from '../../../layouts/SiteLayout.astro';


export const meta = {
  title: 'Fermentation Guide',
  description: 'Fermentation Guide',
  category: 'guide',
};

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Home Fermentation Guide for Beginners",
    "description": "Master home fermentation basics: lacto-fermented veggies, sauerkraut, kimchi, kombucha, water kefir, yogurt, sourdough, and hot sauce. Includes safety, timeline chart, and troubleshooting.",
    "url": "https://28grams.vip/fermentation-guide",
    "author": {
      "@type": "Organization",
      "name": "28grams"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Is home fermentation safe from botulism?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, lacto-fermentation is incredibly safe. The good lactic acid bacteria create an acidic environment (pH below 4.6) where Clostridium botulinum cannot survive. The risk of botulism from properly salted and submerged ferments is essentially zero."
        }
      },
      {
        "@type": "Question",
        "name": "What is the white film on top of my ferment?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "This is likely Kahm yeast, a harmless surface yeast that forms when the ferment is exposed to oxygen. It smells somewhat cheesy or yeasty, unlike mold, which is fuzzy and colorful. Simply skim it off; the ferment below is still safe."
        }
      },
      {
        "@type": "Question",
        "name": "What is the difference between fermented pickles and vinegar pickles?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Fermented pickles (like traditional kosher dills) sour naturally through lactic acid bacteria breaking down sugars, creating complex flavors and probiotics. Vinegar pickles (quick pickles) are simply preserved in a pre-made acidic solution (vinegar) and lack probiotics."
        }
      },
      {
        "@type": "Question",
        "name": "Do I need special equipment to start fermenting?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No. You only need a clean glass jar, salt, water, and your ingredients. While airlocks and glass fermentation weights are helpful for keeping produce submerged and preventing Kahm yeast, a cabbage leaf and a smaller jar filled with water work perfectly as DIY weights."
        }
      },
      {
        "@type": "Question",
        "name": "How do I know when my ferment is done?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Fermentation relies on taste, not strict timelines. It is done when it reaches your preferred level of tanginess and sourness. Taste it every few days; once you like it, move it to the refrigerator to drastically slow the fermentation process."
        }
      }
    ]
  }
];
