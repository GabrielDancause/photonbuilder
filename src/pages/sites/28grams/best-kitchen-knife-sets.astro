.main { max-width: 1000px; margin: 0 auto; padding: 32px 20px 40px; }

/* Chart Card */
.chart-card {
  background: var(--card-bg);
  border: 2px solid var(--border-color);
  border-radius: 16px;
  overflow: hidden;
  margin-bottom: 32px;
}
.chart-header {
