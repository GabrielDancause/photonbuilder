---
import SiteLayout from '../../layouts/SiteLayout.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Health Tools — Free Health & Fitness Calculators",
  "url": "https://photonbuilder.com/health/",
  "description": "Free health and fitness calculators. BMI, TDEE, macros, body fat, heart rate zones, and more. No sign-ups, no ads."
};
---

<SiteLayout
  site="health"
  title="Health Tools — Free Health & Fitness Calculators"
  description="Free health and fitness calculators. BMI, TDEE, macros, body fat, heart rate zones, and more. No sign-ups, no ads."
  canonical="https://photonbuilder.com/health/"
  schema={schema}
>
  <!-- Hero -->
  <div class="text-center pt-24 pb-16 px-6 relative">
    <div class="absolute inset-0 bg-gradient-to-b from-[#1a0a0a] to-transparent opacity-50"></div>
    <div class="relative z-10">
      <p class="text-[var(--accent-color)] text-sm font-bold tracking-[3px] uppercase mb-4">Health & Fitness</p>
      <h1 class="text-4xl md:text-5xl font-black tracking-tight mb-5 bg-gradient-to-br from-white to-[var(--accent-color)] bg-clip-text text-transparent">Your body, your data.</h1>
      <p class="text-[var(--text-secondary)] text-lg max-w-xl mx-auto">Free calculators for nutrition, fitness, and wellness. No sign-ups. No ads. Just answers.</p>
    </div>
  </div>

  <!-- Calculators -->
  <div class="max-w-6xl mx-auto px-6 py-14" id="tools">
    <div class="text-center mb-10">
      <span class="inline-block bg-[var(--accent-color)]/10 text-[var(--accent-color)] text-xs font-extrabold px-4 py-1.5 rounded-full tracking-wide mb-3">🧮 CALCULATORS</span>
      <h2 class="text-3xl font-black text-white tracking-tight">Health Calculators</h2>
      <p class="text-[var(--text-secondary)] mt-2">Quick, accurate results for the numbers that matter.</p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      <a href="/health/tdee-calculator" class="block bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-5 hover:border-[var(--accent-color)] hover:-translate-y-0.5 transition-all">
        <span class="text-xl mb-2 block">🔥</span>
        <h3 class="text-[0.95rem] font-bold text-[#e0e8f0] mb-1">TDEE Calculator</h3>
        <p class="text-xs text-[#6a7a90]">Total daily energy expenditure with BMR and macro splits</p>
      </a>
      <a href="/health/bmr-calculator" class="block bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-5 hover:border-[var(--accent-color)] hover:-translate-y-0.5 transition-all">
        <span class="text-xl mb-2 block">🔥</span>
        <h3 class="text-[0.95rem] font-bold text-[#e0e8f0] mb-1">BMR Calculator</h3>
        <p class="text-xs text-[#6a7a90]">Basal metabolic rate using Mifflin-St Jeor and Harris-Benedict</p>
      </a>
      <a href="/health/bmi-calculator" class="block bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-5 hover:border-[var(--accent-color)] hover:-translate-y-0.5 transition-all">
        <span class="text-xl mb-2 block">⚖️</span>
        <h3 class="text-[0.95rem] font-bold text-[#e0e8f0] mb-1">BMI Calculator</h3>
        <p class="text-xs text-[#6a7a90]">Body Mass Index with category, healthy weight range, and limitations</p>
      </a>
      <a href="/health/macro-calculator" class="block bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-5 hover:border-[var(--accent-color)] hover:-translate-y-0.5 transition-all">
        <span class="text-xl mb-2 block">🥩</span>
        <h3 class="text-[0.95rem] font-bold text-[#e0e8f0] mb-1">Macro Calculator</h3>
        <p class="text-xs text-[#6a7a90]">Daily macronutrient targets for cutting, maintenance, or bulking</p>
      </a>
      <a href="/health/calorie-deficit" class="block bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-5 hover:border-[var(--accent-color)] hover:-translate-y-0.5 transition-all">
        <span class="text-xl mb-2 block">📉</span>
        <h3 class="text-[0.95rem] font-bold text-[#e0e8f0] mb-1">Calorie Deficit Calculator</h3>
        <p class="text-xs text-[#6a7a90]">Calculate calorie deficit for weight loss with safety warnings</p>
      </a>
      <a href="/health/body-fat" class="block bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-5 hover:border-[var(--accent-color)] hover:-translate-y-0.5 transition-all">
        <span class="text-xl mb-2 block">📏</span>
        <h3 class="text-[0.95rem] font-bold text-[#e0e8f0] mb-1">Body Fat Calculator</h3>
        <p class="text-xs text-[#6a7a90]">Body fat percentage using U.S. Navy or Jackson-Pollock methods</p>
      </a>
      <a href="/health/ideal-weight" class="block bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-5 hover:border-[var(--accent-color)] hover:-translate-y-0.5 transition-all">
        <span class="text-xl mb-2 block">⚖️</span>
        <h3 class="text-[0.95rem] font-bold text-[#e0e8f0] mb-1">Ideal Weight Calculator</h3>
        <p class="text-xs text-[#6a7a90]">Ideal weight using BMI, Devine, Robinson, and Hamwi formulas</p>
      </a>
      <a href="/health/water-intake" class="block bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-5 hover:border-[var(--accent-color)] hover:-translate-y-0.5 transition-all">
        <span class="text-xl mb-2 block">💧</span>
        <h3 class="text-[0.95rem] font-bold text-[#e0e8f0] mb-1">Water Intake Calculator</h3>
        <p class="text-xs text-[#6a7a90]">Daily water needs based on weight, activity, and climate</p>
      </a>
      <a href="/health/one-rep-max" class="block bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-5 hover:border-[var(--accent-color)] hover:-translate-y-0.5 transition-all">
        <span class="text-xl mb-2 block">🏋️</span>
        <h3 class="text-[0.95rem] font-bold text-[#e0e8f0] mb-1">One Rep Max Calculator</h3>
        <p class="text-xs text-[#6a7a90]">Estimate your max lift from any rep range with multiple formulas</p>
      </a>
      <a href="/health/heart-rate-zones" class="block bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-5 hover:border-[var(--accent-color)] hover:-translate-y-0.5 transition-all">
        <span class="text-xl mb-2 block">❤️</span>
        <h3 class="text-[0.95rem] font-bold text-[#e0e8f0] mb-1">Heart Rate Zone Calculator</h3>
        <p class="text-xs text-[#6a7a90]">Personalized training zones using the Karvonen method</p>
      </a>
      <a href="/health/pace-calculator" class="block bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-5 hover:border-[var(--accent-color)] hover:-translate-y-0.5 transition-all">
        <span class="text-xl mb-2 block">🏃</span>
        <h3 class="text-[0.95rem] font-bold text-[#e0e8f0] mb-1">Pace Calculator</h3>
        <p class="text-xs text-[#6a7a90]">Calculate running pace, finish time, or distance</p>
      </a>
      <a href="/health/vo2max-estimator" class="block bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-5 hover:border-[var(--accent-color)] hover:-translate-y-0.5 transition-all">
        <span class="text-xl mb-2 block">🫁</span>
        <h3 class="text-[0.95rem] font-bold text-[#e0e8f0] mb-1">VO2 Max Estimator</h3>
        <p class="text-xs text-[#6a7a90]">Estimate VO2 max from timed run with fitness comparisons</p>
      </a>
      <a href="/health/interval-timer" class="block bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-5 hover:border-[var(--accent-color)] hover:-translate-y-0.5 transition-all">
        <span class="text-xl mb-2 block">⏱️</span>
        <h3 class="text-[0.95rem] font-bold text-[#e0e8f0] mb-1">Interval Timer</h3>
        <p class="text-xs text-[#6a7a90]">Customizable timer for HIIT, Tabata, circuit training</p>
      </a>
      <a href="/health/sleep-cycle" class="block bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-5 hover:border-[var(--accent-color)] hover:-translate-y-0.5 transition-all">
        <span class="text-xl mb-2 block">😴</span>
        <h3 class="text-[0.95rem] font-bold text-[#e0e8f0] mb-1">Sleep Cycle Calculator</h3>
        <p class="text-xs text-[#6a7a90]">Find best bedtime or wake time based on 90-minute cycles</p>
      </a>
      <a href="/health/pregnancy-calculator" class="block bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-5 hover:border-[var(--accent-color)] hover:-translate-y-0.5 transition-all">
        <span class="text-xl mb-2 block">👶</span>
        <h3 class="text-[0.95rem] font-bold text-[#e0e8f0] mb-1">Pregnancy Due Date Calculator</h3>
        <p class="text-xs text-[#6a7a90]">Due date from LMP or conception with trimester timeline</p>
      </a>
    </div>
  </div>

  <!-- Studies -->
  <div class="max-w-6xl mx-auto px-6 py-14" id="studies">
    <div class="text-center mb-10">
      <span class="inline-block bg-[var(--accent-color)]/10 text-[var(--accent-color)] text-xs font-extrabold px-4 py-1.5 rounded-full tracking-wide mb-3">🔬 STUDIES</span>
      <h2 class="text-3xl font-black text-white tracking-tight">Original Research</h2>
      <p class="text-[var(--text-secondary)] mt-2">Data-driven health insights.</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      <a href="/health/gym-costs" class="block bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 hover:border-[var(--accent-color)] hover:-translate-y-0.5 transition-all">
        <span class="inline-block bg-[var(--accent-color)]/10 text-[var(--accent-color)] text-xs font-extrabold px-3 py-1 rounded-full tracking-wide mb-3">ORIGINAL RESEARCH</span>
        <h3 class="text-base font-bold text-[#e0e8f0] mb-2">Gym Membership Costs Compared 2026</h3>
        <div class="mb-3 p-3 bg-white/[0.03] rounded-lg">
          <strong class="text-[var(--accent-color)] text-xl block mb-1">$59.15</strong>
          <span class="text-xs text-[#888] uppercase">Average Monthly Cost</span>
        </div>
        <p class="text-sm text-[#6a7a90]">20 major gym chains analyzed. 9 budget options under $25/mo, avg initiation fee $51.94.</p>
      </a>
      <a href="/health/protein-per-dollar" class="block bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 hover:border-[var(--accent-color)] hover:-translate-y-0.5 transition-all">
        <span class="inline-block bg-[var(--accent-color)]/10 text-[var(--accent-color)] text-xs font-extrabold px-3 py-1 rounded-full tracking-wide mb-3">ORIGINAL RESEARCH</span>
        <h3 class="text-base font-bold text-[#e0e8f0] mb-2">Protein Per Dollar: Cheapest Sources Ranked 2026</h3>
        <div class="mb-3 p-3 bg-white/[0.03] rounded-lg">
          <strong class="text-[var(--accent-color)] text-xl block mb-1">66.7g</strong>
          <span class="text-xs text-[#888] uppercase">Highest Protein Per $1</span>
        </div>
        <p class="text-sm text-[#6a7a90]">35 common foods ranked by cost-effectiveness using 2026 retail prices.</p>
      </a>
    </div>
  </div>

  <!-- Guides -->
  <div class="max-w-6xl mx-auto px-6 py-14" id="guides">
    <div class="text-center mb-10">
      <span class="inline-block bg-[var(--accent-color)]/10 text-[var(--accent-color)] text-xs font-extrabold px-4 py-1.5 rounded-full tracking-wide mb-3">📚 GUIDES</span>
      <h2 class="text-3xl font-black text-white tracking-tight">How-To Guides</h2>
      <p class="text-[var(--text-secondary)] mt-2">Step-by-step guides for a healthier life.</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
      <a href="/health/guide-home-gym" class="block bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 hover:border-[var(--accent-color)] hover:-translate-y-0.5 transition-all">
        <span class="text-2xl mb-3 block">🏠</span>
        <h3 class="text-base font-bold text-[#e0e8f0] mb-1">Home Gym Setup Guide</h3>
        <p class="text-sm text-[#6a7a90]">Build a home gym on any budget with equipment and layout tips</p>
      </a>
      <a href="/health/guide-meal-prep" class="block bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 hover:border-[var(--accent-color)] hover:-translate-y-0.5 transition-all">
        <span class="text-2xl mb-3 block">🥗</span>
        <h3 class="text-base font-bold text-[#e0e8f0] mb-1">Meal Prep Guide</h3>
        <p class="text-sm text-[#6a7a90]">Weekly meal prep plans, grocery lists, and batch cooking tips</p>
      </a>
      <a href="/health/guide-running-plan" class="block bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 hover:border-[var(--accent-color)] hover:-translate-y-0.5 transition-all">
        <span class="text-2xl mb-3 block">🏃</span>
        <h3 class="text-base font-bold text-[#e0e8f0] mb-1">Couch to 5K Running Plan</h3>
        <p class="text-sm text-[#6a7a90]">8-week running plan for beginners with injury prevention</p>
      </a>
    </div>
  </div>

  <!-- Lists -->
  <div class="max-w-6xl mx-auto px-6 py-14" id="lists">
    <div class="text-center mb-10">
      <span class="inline-block bg-[var(--accent-color)]/10 text-[var(--accent-color)] text-xs font-extrabold px-4 py-1.5 rounded-full tracking-wide mb-3">📋 LISTS</span>
      <h2 class="text-3xl font-black text-white tracking-tight">Curated Lists</h2>
      <p class="text-[var(--text-secondary)] mt-2">The best gear and apps for your health goals.</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      <a href="/health/list-standing-desks" class="block bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 hover:border-[var(--accent-color)] hover:-translate-y-0.5 transition-all">
        <span class="text-2xl mb-3 block">🪑</span>
        <h3 class="text-base font-bold text-[#e0e8f0] mb-1">Best Standing Desks</h3>
        <p class="text-sm text-[#6a7a90]">Compare standing desks by height range, stability, presets, price</p>
      </a>
      <a href="/health/list-workout-apps" class="block bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl p-6 hover:border-[var(--accent-color)] hover:-translate-y-0.5 transition-all">
        <span class="text-2xl mb-3 block">💪</span>
        <h3 class="text-base font-bold text-[#e0e8f0] mb-1">Best Workout Apps</h3>
        <p class="text-sm text-[#6a7a90]">Top workout and fitness apps for home and gym training</p>
      </a>
    </div>
  </div>
</SiteLayout>
