---
const features = [
  {
    title: 'Zero config publishing',
    description: 'Write in Markdown. Hit publish. Your site is live on the global edge in seconds.',
    icon: '⚡',
  },
  {
    title: 'Blazing fast by default',
    description: 'Static-first architecture. No JavaScript shipped unless your page needs it. Perfect Lighthouse scores out of the box.',
    icon: '🚀',
  },
  {
    title: 'Custom tools & interactivity',
    description: 'Embed calculators, utilities, and interactive components directly in your pages.',
    icon: '🛠',
  },
  {
    title: 'Your brand, your corner',
    description: 'Get your own space at photonbuilder.com/you. Clean URLs. No watermarks.',
    icon: '✨',
  },
];
---

<section id="features" class="relative py-24 md:py-32">
  <div class="mx-auto max-w-6xl px-6">
    <div class="mx-auto max-w-2xl text-center" data-animate>
      <h2 class="text-3xl font-bold text-white md:text-4xl">Everything you need to publish</h2>
      <p class="mt-4 text-slate-400">Powerful defaults. Zero boilerplate. Ship faster.</p>
    </div>

    <div class="mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {features.map((feature, i) => (
        <div
          data-animate
          style={`animation-delay: ${i * 0.1}s`}
          class="group rounded-xl border border-white/5 bg-[var(--color-navy-light)] p-6 transition hover:border-white/10 hover:bg-[var(--color-navy-lighter)]"
        >
          <div class="mb-4 text-3xl">{feature.icon}</div>
          <h3 class="text-lg font-semibold text-white">{feature.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-slate-400">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
