---
const sites = [
  {
    name: 'FirePath',
    description: 'FIRE & early retirement tools',
    url: 'photonbuilder.com/firepath',
    gradient: 'from-orange-500 to-red-500',
  },
  {
    name: 'DevForge',
    description: 'Developer utilities & references',
    url: 'photonbuilder.com/devforge',
    gradient: 'from-cyan-500 to-blue-500',
  },
  {
    name: 'NomadBase',
    description: 'Digital nomad guides & cost calculators',
    url: 'photonbuilder.com/nomadbase',
    gradient: 'from-emerald-500 to-teal-500',
  },
  {
    name: 'GameStack',
    description: 'Gaming guides & tier lists',
    url: 'photonbuilder.com/gamestack',
    gradient: 'from-purple-500 to-pink-500',
  },
];
---

<section id="examples" class="relative py-24 md:py-32">
  <div class="mx-auto max-w-6xl px-6">
    <div class="mx-auto max-w-2xl text-center" data-animate>
      <h2 class="text-3xl font-bold text-white md:text-4xl">Built on PhotonBuilder</h2>
      <p class="mt-4 text-slate-400">See what creators are publishing.</p>
    </div>

    <div class="mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {sites.map((site, i) => (
        <div
          data-animate
          style={`animation-delay: ${i * 0.1}s`}
          class="overflow-hidden rounded-xl border border-white/5 bg-[var(--color-navy-light)] transition hover:border-white/10"
        >
          <div class={`h-24 bg-gradient-to-br ${site.gradient} opacity-80`}></div>
          <div class="p-5">
            <h3 class="text-lg font-semibold text-white">{site.name}</h3>
            <p class="mt-1 text-sm text-slate-400">{site.description}</p>
            <p class="mt-3 text-xs text-slate-500">{site.url}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
