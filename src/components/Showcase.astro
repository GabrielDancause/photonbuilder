---
const sites = [
  {
    name: 'HPV Research',
    description: 'Open-access virology research & E2 protein analysis',
    url: 'photonbuilder.com/hpvresearch',
    link: '/hpvresearch/',
    gradient: 'from-emerald-500 to-green-600',
  },
  {
    name: 'Westmount Fundamentals',
    description: 'Equity research, valuation studies & investment tools',
    url: 'westmountfundamentals.com',
    link: 'https://westmountfundamentals.com',
    gradient: 'from-blue-500 to-indigo-600',
  },
  {
    name: 'SiliconBased',
    description: 'Developer tools, benchmarks & technical research',
    url: 'siliconbased.dev',
    link: 'https://siliconbased.dev',
    gradient: 'from-violet-500 to-purple-600',
  },
  {
    name: 'FireMaths',
    description: 'Finance calculators & FIRE planning tools',
    url: 'firemaths.info',
    link: 'https://firemaths.info',
    gradient: 'from-amber-500 to-orange-600',
  },
];
---

<section id="examples" class="relative py-24 md:py-32">
  <div class="mx-auto max-w-6xl px-6">
    <div class="mx-auto max-w-2xl text-center" data-animate>
      <h2 class="text-3xl font-bold text-white md:text-4xl">Built on PhotonBuilder</h2>
      <p class="mt-4 text-slate-400">See what creators are publishing.</p>
    </div>

    <div class="mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {sites.map((site, i) => (
        <a
          href={site.link}
          data-animate
          style={`animation-delay: ${i * 0.1}s`}
          class="overflow-hidden rounded-xl border border-white/5 bg-[var(--color-navy-light)] transition hover:border-white/10 block"
        >
          <div class={`h-24 bg-gradient-to-br ${site.gradient} opacity-80`}></div>
          <div class="p-5">
            <h3 class="text-lg font-semibold text-white">{site.name}</h3>
            <p class="mt-1 text-sm text-slate-400">{site.description}</p>
            <p class="mt-3 text-xs text-slate-500">{site.url}</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
