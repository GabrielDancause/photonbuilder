---
const plans = [
  {
    name: 'Starter',
    price: 'Free',
    period: '',
    features: ['1 site', 'photonbuilder.com/you URL', 'Unlimited pages'],
    highlight: false,
    badge: null,
  },
  {
    name: 'Pro',
    price: '$7',
    period: '/mo',
    features: ['Custom domain', 'Analytics', 'Priority builds', 'No badge'],
    highlight: true,
    badge: null,
  },
  {
    name: 'Team',
    price: '$19',
    period: '/mo',
    features: ['Multiple collaborators', 'Shared workspace', 'API access'],
    highlight: false,
    badge: 'Coming soon',
  },
];
---

<section id="pricing" class="relative py-24 md:py-32">
  <div class="mx-auto max-w-6xl px-6">
    <div class="mx-auto max-w-2xl text-center" data-animate>
      <h2 class="text-3xl font-bold text-white md:text-4xl">Simple, transparent pricing</h2>
      <p class="mt-4 text-slate-400">Start free. Upgrade when you're ready.</p>
    </div>

    <div class="mt-16 grid gap-6 md:grid-cols-3 max-w-4xl mx-auto">
      {plans.map((plan, i) => (
        <div
          data-animate
          style={`animation-delay: ${i * 0.1}s`}
          class:list={[
            'relative rounded-xl border p-6 transition',
            plan.highlight
              ? 'border-[var(--color-accent-blue)]/50 bg-gradient-to-b from-[var(--color-accent-blue)]/10 to-transparent shadow-lg shadow-[var(--color-accent-blue)]/5'
              : 'border-white/5 bg-[var(--color-navy-light)]',
          ]}
        >
          {plan.badge && (
            <span class="absolute -top-3 right-4 rounded-full bg-[var(--color-accent-violet)] px-3 py-1 text-xs font-medium text-white">
              {plan.badge}
            </span>
          )}
          <h3 class="text-lg font-semibold text-white">{plan.name}</h3>
          <div class="mt-4 flex items-baseline gap-1">
            <span class="text-4xl font-bold text-white">{plan.price}</span>
            {plan.period && <span class="text-slate-400">{plan.period}</span>}
          </div>
          <ul class="mt-6 space-y-3">
            {plan.features.map((feature) => (
              <li class="flex items-center gap-2 text-sm text-slate-300">
                <svg class="h-4 w-4 shrink-0 text-[var(--color-accent-blue)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                {feature}
              </li>
            ))}
          </ul>
          <a
            href="#waitlist"
            class:list={[
              'mt-8 block rounded-full py-2.5 text-center text-sm font-semibold transition',
              plan.highlight
                ? 'bg-gradient-to-r from-[var(--color-accent-blue)] to-[var(--color-accent-violet)] text-white hover:opacity-90'
                : 'border border-white/10 text-slate-300 hover:border-white/25 hover:text-white',
            ]}
          >
            Get started
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
