---
import hierarchyData from '../data/seo-hierarchy.json';

interface Props {
  domain: string;
  pagePath: string;
  pageTitle: string;
  section?: 'breadcrumbs' | 'related' | 'both';
}

const { domain, pagePath, pageTitle = '', section = 'both' } = Astro.props;
const showBreadcrumbSection = section === 'breadcrumbs' || section === 'both';
const showRelatedSection = section === 'related' || section === 'both';

// Look up this page in the hierarchy
const domainData = (hierarchyData as any).hierarchy?.[domain];
const pageInfo = domainData?.[pagePath];
const apexNames = (hierarchyData as any).apexNames || {};
const clusterPages = (hierarchyData as any).clusterPages || {};

// Skip if page not in hierarchy or is homepage
const showBreadcrumbs = pageInfo && pagePath !== '/';
const isGabAe = domain === 'gab.ae';

// Build breadcrumb items
let breadcrumbs: { name: string; url?: string }[] = [];
if (showBreadcrumbs) {
  breadcrumbs = [
    { name: 'Apex Guides', url: 'https://gab.ae/apex-guides' },
    { name: pageInfo.apexName, url: `https://gab.ae/${pageInfo.apex}` },
  ];
  if (pageInfo.cluster && pageInfo.cluster !== 'sub-guide') {
    breadcrumbs.push({ name: pageInfo.cluster.replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase()) });
  }
  breadcrumbs.push({ name: (pageTitle || 'Page').split('|')[0].split('—')[0].trim() });
}

// Build related pages (skip for gab.ae hub pages)
let relatedPages: { domain: string; path: string; title: string }[] = [];
if (pageInfo && !isGabAe) {
  const clusterKey = `${pageInfo.apex}|${pageInfo.cluster}`;
  const allInCluster = clusterPages[clusterKey] || [];
  
  // Filter out current page
  const others = allInCluster.filter((p: any) => !(p.domain === domain && p.path === pagePath));
  
  // Prefer same domain, then shuffle
  const sameDomain = others.filter((p: any) => p.domain === domain);
  const diffDomain = others.filter((p: any) => p.domain !== domain);
  
  // Deterministic "shuffle" based on pagePath to avoid different results per build
  const hash = pagePath.split('').reduce((a: number, c: string) => a + c.charCodeAt(0), 0);
  const pick = (arr: any[], n: number) => {
    if (arr.length <= n) return arr;
    const start = hash % arr.length;
    const result = [];
    for (let i = 0; i < n; i++) {
      result.push(arr[(start + i) % arr.length]);
    }
    return result;
  };
  
  // Pick up to 5: prefer 3 same domain + 2 cross-domain
  const fromSame = pick(sameDomain, Math.min(3, sameDomain.length));
  const needed = 5 - fromSame.length;
  const fromDiff = pick(diffDomain, Math.min(needed, diffDomain.length));
  relatedPages = [...fromSame, ...fromDiff];
}

// BreadcrumbList schema
const breadcrumbSchema = showBreadcrumbs ? {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": breadcrumbs.map((item, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": item.name,
    ...(item.url ? { "item": item.url } : {}),
  })),
} : null;
---

{showBreadcrumbs && showBreadcrumbSection && (
  <nav class="seo-breadcrumbs" aria-label="Breadcrumb">
    {breadcrumbs.map((item, i) => (
      <>
        {i > 0 && <span class="seo-bc-sep">›</span>}
        {item.url ? (
          <a href={item.url} class="seo-bc-link">{item.name}</a>
        ) : (
          <span class={i === breadcrumbs.length - 1 ? "seo-bc-current" : "seo-bc-text"}>{item.name}</span>
        )}
      </>
    ))}
  </nav>
)}

{breadcrumbSchema && showBreadcrumbSection && (
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
)}

{relatedPages.length > 0 && showRelatedSection && (
  <section class="seo-related">
    <h3 class="seo-related-title">Related Resources</h3>
    <div class="seo-related-grid">
      {relatedPages.map((page) => (
        <a href={`https://${page.domain}${page.path}`} class="seo-related-card">
          <span class="seo-related-domain">{page.domain}</span>
          <span class="seo-related-name">{((page.title || page.path) || '').split('|')[0].split('—')[0].trim().slice(0, 60)}</span>
        </a>
      ))}
    </div>
  </section>
)}

<style>
  .seo-breadcrumbs {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem;
    padding: 0.75rem 0;
    margin-bottom: 0.5rem;
    font-size: 0.78rem;
    max-width: 900px;
    margin-left: auto;
    margin-right: auto;
  }
  .seo-bc-link {
    color: var(--text-secondary, #64748b);
    text-decoration: none;
    transition: color 0.2s;
  }
  .seo-bc-link:hover {
    color: var(--accent-color, #818cf8);
    text-decoration: underline;
  }
  .seo-bc-sep {
    color: var(--text-secondary, #475569);
    font-size: 0.7rem;
  }
  .seo-bc-text {
    color: var(--text-secondary, #64748b);
  }
  .seo-bc-current {
    color: var(--text-primary, #e2e8f0);
    font-weight: 600;
  }

  .seo-related {
    max-width: 900px;
    margin: 3rem auto 0;
    padding-top: 2rem;
    border-top: 1px solid var(--border-color, rgba(255,255,255,0.08));
  }
  .seo-related-title {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-secondary, #64748b);
    margin: 0 0 1rem;
    font-weight: 600;
  }
  .seo-related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 0.75rem;
  }
  .seo-related-card {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding: 1rem;
    background: var(--card-bg, #12121a);
    border: 1px solid var(--border-color, rgba(255,255,255,0.08));
    border-radius: 10px;
    text-decoration: none;
    transition: border-color 0.2s, transform 0.15s;
  }
  .seo-related-card:hover {
    border-color: var(--accent-color, #818cf8);
    transform: translateY(-1px);
  }
  .seo-related-domain {
    font-size: 0.68rem;
    color: var(--text-secondary, #475569);
    font-weight: 500;
  }
  .seo-related-name {
    font-size: 0.85rem;
    color: var(--text-primary, #e2e8f0);
    font-weight: 600;
    line-height: 1.3;
  }
  @media (max-width: 640px) {
    .seo-related-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
